<!--
    SchedulingAssistant.Browser — thin WebAssembly head project.

    WHY THIS EXISTS:
    This project is the browser entry point for the live demo hosted at GitHub Pages.
    It contains only the bootstrap wiring (~10 lines of code) and the HTML shell page.
    All application logic, ViewModels, and Views live in the main SchedulingAssistant project.

    The data layer is swapped at DI registration time (App.InitializeDemoServices) so no
    SQLite binaries are included in the WASM output.  Demo repositories serve static data
    from the DemoData partial class generated by DemoDataGenerator.

    To build and publish:
        dotnet publish -c Release
    Output goes to bin/Release/net8.0-browser/browser-wasm/AppBundle/
    Copy the AppBundle/ contents to the GitHub Pages branch (gh-pages).
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-browser</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Suppress the Avalonia.Browser entry-point warning — Program.Main is our entry point. -->
    <NoWarn>$(NoWarn);CS8632</NoWarn>
    <!--
      Lower wasm-opt from the default -O2 to -O1 so the optimizer doesn't OOM
      on the (large, un-trimmed-at-native-level) dotnet.native.wasm.
      WasmNativeOptimization maps to the -Ox flag passed to wasm-opt.
    -->
    <WasmNativeOptimization>-O1</WasmNativeOptimization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SchedulingAssistant\SchedulingAssistant.csproj" />
  </ItemGroup>

  <!--
    Preserve all types in the main assembly from IL trimming.
    The app uses x:CompileBindings="False" (reflection-based bindings) throughout.
    Without this, the trimmer strips the reflection infrastructure that Avalonia's
    ReflectionBindingExtension needs, silently breaking all {Binding} expressions:
    ComboBox ItemsSource, Button Command, TextBlock Text — anything driven by a
    non-compiled binding fails to update.  Rooting the assembly keeps every ViewModel,
    View, Model, and Converter type reachable so runtime reflection works correctly.
  -->
  <ItemGroup>
    <TrimmerRootAssembly Include="SchedulingAssistant" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Browser" Version="11.3.12" />
  </ItemGroup>

  <!--
    WasmExtraFilesToDeploy copies files into the AppBundle output directory.
    This is how static shell files (index.html etc.) get placed alongside
    the generated _framework/ folder so the bundle is ready to serve as-is.
  -->
  <ItemGroup>
    <WasmExtraFilesToDeploy Include="wwwroot/index.html" TargetPath="index.html" />
  </ItemGroup>

</Project>
