<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="using:TermPoint.Helpers"
             x:Class="TermPoint.Controls.WorkflowCardChrome"
             x:Name="Root"
             x:CompileBindings="False"
             Width="280">

    <UserControl.Styles>
        <!-- Chevron points down when collapsed, up when expanded -->
        <Style Selector="ToggleButton#ExpandToggle Path">
            <Setter Property="Fill" Value="{StaticResource TextFaint}" />
        </Style>
        <Style Selector="ToggleButton#ExpandToggle:checked Viewbox">
            <Setter Property="RenderTransform" Value="rotate(180deg)" />
        </Style>
    </UserControl.Styles>

    <Border CornerRadius="6"
            BorderThickness="1"
            BorderBrush="{StaticResource WorkflowCardBorder}"
            BoxShadow="{StaticResource PanelBoxShadow}"
            Padding="14,10"
            Background="{Binding Accent, ElementName=Root}">

        <StackPanel Spacing="4">

            <!-- Top row: title (left) + chevron/detach (right). Story flows full width below. -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Title, ElementName=Root}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <ToggleButton Grid.Column="1"
                              x:Name="ExpandToggle"
                              IsChecked="{Binding IsExpanded, ElementName=Root, Mode=TwoWay}"
                              Width="24" Height="24"
                              Padding="4"
                              Background="Transparent"
                              VerticalAlignment="Top"
                              ToolTip.Tip="Show steps"
                              BorderThickness="0">
                    <Viewbox Width="12" Height="12">
                        <Path Data="{StaticResource caretdown}" Stretch="Uniform" />
                    </Viewbox>
                </ToggleButton>

                <Button Grid.Column="2"
                        x:Name="DetachButton"
                        Width="24" Height="24"
                        Padding="4"
                        Background="Transparent"
                        VerticalAlignment="Top"
                        ToolTip.Tip="Pop out as a floating sticky note"
                        Click="OnDetachClick">
                    <Viewbox Width="15" Height="15">
                        <Path Data="{StaticResource detachwindow}"
                              Fill="{StaticResource TextFaint}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>
            </Grid>

            <!-- Story: spans the full card width and flows beneath the buttons -->
            <TextBlock h:InlineFormatter.Text="{Binding StoryText, ElementName=Root}"
                       FontSize="{StaticResource FontSizeNormal}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextPrimary}" />

            <!-- Steps body (collapsible in flyout; always shown when detached) -->
            <Border x:Name="StepsArea"
                    Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource WorkflowCardBorder}">
                <TextBlock h:InlineFormatter.Text="{Binding StepsText, ElementName=Root}"
                           FontSize="{StaticResource FontSizeNormal}"
                           TextWrapping="Wrap" />
            </Border>

        </StackPanel>
    </Border>

</UserControl>
