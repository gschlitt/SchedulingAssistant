<Window
	x:Class="TermPoint.MainWindow"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:TermPoint.ViewModels"
	xmlns:panelViews="using:TermPoint.Views"
	x:Name="RootWindow"
	Icon="/Assets/app.ico"
	Title="TermPoint"
	Width="1400"
	Height="800"
	MinHeight="600"
	x:CompileBindings="False"
	x:DataType="vm:MainWindowViewModel"
	Background="{StaticResource AppBackground}">

	<Panel>
		<panelViews:MainView x:Name="MainViewControl" />

		<!-- Loading curtain: a full-window gradient overlay shown from launch until the
		     schedule grid renders its first frame, so the user never watches the window
		     assemble itself. Lifted (with a fade) from MainWindow.axaml.cs. -->
		<Border x:Name="LoadingCurtain" IsHitTestVisible="True">
			<Border.Transitions>
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.35" />
				</Transitions>
			</Border.Transitions>
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
					<GradientStop Color="{StaticResource SplashGradientStart}" Offset="0" />
					<GradientStop Color="{StaticResource SplashGradientEnd}" Offset="1" />
				</LinearGradientBrush>
			</Border.Background>
			<StackPanel HorizontalAlignment="Center"
						VerticalAlignment="Center">
				<TextBlock HorizontalAlignment="Center"
						   FontSize="{StaticResource FontSizeSplash}"
						   FontWeight="ExtraLight"
						   Foreground="White"
						   Text="TermPoint" />
				<TextBlock HorizontalAlignment="Center"
						   FontSize="{StaticResource FontSizeLarge}"
						   Foreground="#99FFFFFF"
						   Text="Loading..." />
			</StackPanel>
		</Border>
	</Panel>

</Window>
