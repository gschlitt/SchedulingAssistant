<UserControl
    x:Class="TermPoint.Views.Wizard.Steps.Step6BlockPatternsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mgmt="using:TermPoint.Views.Management"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    x:CompileBindings="False">

    <StackPanel MaxWidth="900" Spacing="16">
        <Border>
            <Border.Resources>
                <sys:Double x:Key="FontSizeXLarge">22</sys:Double>
                <sys:Double x:Key="FontSizeNormal">16</sys:Double>
                <sys:Double x:Key="FontSizeSmall">14</sys:Double>
            </Border.Resources>
            <mgmt:BlockPatternListView DataContext="{Binding BlockPatterns}" />
        </Border>
    </StackPanel>
</UserControl>



