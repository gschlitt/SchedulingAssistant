<UserControl
    x:Class="TermPoint.Views.Wizard.Steps.Step2DatabaseView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="860" Spacing="20">

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            Text="Choose where your database file and automated backups will be stored. Both locations are required. "
            TextWrapping="Wrap" />

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            Text="If you share scheduling duties with someone else (perhaps a department head or assistant) place the database in a shared network location. "
            TextWrapping="Wrap" />

        <!--  Database folder  -->
        <StackPanel Spacing="6">
            <TextBlock
                FontSize="{DynamicResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Database folder" />

            <TextBlock
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                IsVisible="{Binding SuggestedFolders.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Text="Suggestions" />

            <!--  Suggested locations  -->
            <ItemsControl
                IsVisible="{Binding SuggestedFolders.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                ItemsSource="{Binding SuggestedFolders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Margin="0,2"
                            Padding="10,8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="{StaticResource SuggestionBackground}"
                            CornerRadius="6"
                            Command="{Binding $parent[ItemsControl].DataContext.SelectSuggestionCommand}"
                            CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Text="{Binding Path}" />
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource ForegroundMuted}"
                                    Text="{Binding Description, StringFormat='({0})'}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Margin="0,2,0,0"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                IsVisible="{Binding SuggestedFolders.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Text="Or choose a different location:" />

            <Grid ColumnDefinitions="*,8,Auto">
                <TextBox
                    Grid.Column="0"
                    IsReadOnly="True"
                    Text="{Binding DbFolder}"
                    PlaceholderText="Choose a folder…" />
                <Button
                    Grid.Column="2"
                    Command="{Binding BrowseDbFolderCommand}"
                    Content="Browse…" />
            </Grid>

            <!--  Folder suitability warnings (non-blocking advisories)  -->
            <ItemsControl
                IsVisible="{Binding DbFolderWarnings.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                ItemsSource="{Binding DbFolderWarnings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,2"
                            Padding="10,6"
                            Background="{StaticResource NotificationWarningBackground}"
                            BorderBrush="{StaticResource NotificationWarningBorder}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="{DynamicResource FontSizeSmall}"
                                Foreground="{StaticResource NotificationWarningText}"
                                Text="{Binding Message}"
                                TextWrapping="Wrap" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!--  Database filename — shown once a folder is chosen  -->
        <StackPanel IsVisible="{Binding DbFolder, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Spacing="6">
            <TextBlock
                FontSize="{DynamicResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Database filename" />
            <TextBlock
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                TextWrapping="Wrap">
                This filename was suggested from your abbreviation. You may edit it before continuing.
            </TextBlock>
            <TextBox Text="{Binding DbFilename}" PlaceholderText="e.g. CS-TT.db" />
            <!--  Inline validation error  -->
            <TextBlock
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource NotificationErrorText}"
                IsVisible="{Binding DbFilenameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Text="{Binding DbFilenameError}" />
            <!--  Full path confirmation  -->
            <TextBlock
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                IsVisible="{Binding DbFullPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Run Text="Full path: " />
                <Run FontWeight="SemiBold" Text="{Binding DbFullPath}" />
            </TextBlock>
        </StackPanel>

        <!--  Backup folder — revealed only after a valid DB folder + filename are confirmed  -->
        <StackPanel
            Margin="0,0"
            IsVisible="{Binding IsFilenameReady}"
            Spacing="6">
            <TextBlock
                FontSize="{DynamicResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Backup folder" />
            <TextBlock
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                TextWrapping="Wrap">
                TermPoint saves automatic backups here. Ideally choose a different drive for safety.
            </TextBlock>
            <Grid ColumnDefinitions="*,8,Auto">
                <TextBox
                    Grid.Column="0"
                    IsReadOnly="True"
                    Text="{Binding BackupFolder}"
                    PlaceholderText="Choose a folder…" />
                <Button
                    Grid.Column="2"
                    Command="{Binding BrowseBackupFolderCommand}"
                    Content="Browse…" />
            </Grid>

            <!--  Backup folder suitability warnings (non-blocking advisories)  -->
            <ItemsControl
                IsVisible="{Binding BackupFolderWarnings.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                ItemsSource="{Binding BackupFolderWarnings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,2"
                            Padding="10,6"
                            Background="{StaticResource NotificationWarningBackground}"
                            BorderBrush="{StaticResource NotificationWarningBorder}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="{DynamicResource FontSizeSmall}"
                                Foreground="{StaticResource NotificationWarningText}"
                                Text="{Binding Message}"
                                TextWrapping="Wrap" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Same-folder recommendation — appears only when both folders are the same path  -->
            <Border
                Padding="12,8"
                Background="{StaticResource NotificationWarningBackground}"
                BorderBrush="{StaticResource NotificationWarningBorder}"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding SameFolderWarning}">
                <TextBlock
                    FontSize="{DynamicResource FontSizeNormal}"
                    Foreground="{StaticResource NotificationWarningText}"
                    TextWrapping="Wrap">
                    <Bold>⚠ Recommendation:</Bold>
                    Your backup folder is the same as your database folder.
                    For best data protection, choose a backup location on a <Bold>different drive.</Bold>
                    If your primary drive fails, backups stored alongside the database would be lost too.<LineBreak />
                </TextBlock>
            </Border>

        </StackPanel>

    </StackPanel>
</UserControl>
