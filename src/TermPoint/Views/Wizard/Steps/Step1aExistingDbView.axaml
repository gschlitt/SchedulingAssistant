<UserControl
    x:Class="TermPoint.Views.Wizard.Steps.Step1aExistingDbView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="860" Spacing="20">


        <TextBlock Text="Do you or your team have a TermPoint database (.db file) set up already? If not you should proceed with a fresh install." TextWrapping="Wrap" />

        <!--  Radio: fresh install  -->
        <RadioButton
            Content="This is a fresh install. I need to set up my own database."
            FontSize="{DynamicResource FontSizeNormal}"
            IsChecked="{Binding IsNewSetupChoice}" />

        <!--  Radio: existing database  -->
        <StackPanel Spacing="12">
            <RadioButton
                Content="I already have a database and want to use that."
                FontSize="{DynamicResource FontSizeNormal}"
                IsChecked="{Binding IsExistingDbChoice}" />

            <!--  Detail pane — revealed when existing DB is chosen  -->
            <StackPanel
                Margin="28,0,0,0"
                IsVisible="{Binding IsExistingDbChoice}"
                Spacing="16">

                <!--  Placeholder text — user will supply  -->
                <TextBlock
                    FontSize="{DynamicResource FontSizeNormal}"
                    Foreground="{StaticResource ForegroundMuted}"
                    Text="[Placeholder — instructions for connecting to a shared database.]"
                    TextWrapping="Wrap" />

                <!--  Database file  -->
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="{DynamicResource FontSizeNormal}"
                        FontWeight="SemiBold"
                        Text="Database file" />
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding DbPath}"
                            PlaceholderText="Choose the .db file…" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding BrowseDbFileCommand}"
                            Content="Browse…" />
                    </Grid>

                    <!--  Folder suitability warnings (non-blocking advisories)  -->
                    <ItemsControl
                        IsVisible="{Binding DbFolderWarnings.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        ItemsSource="{Binding DbFolderWarnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,2"
                                    Padding="10,6"
                                    Background="{StaticResource NotificationWarningBackground}"
                                    BorderBrush="{StaticResource NotificationWarningBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource NotificationWarningText}"
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!--  Backup folder  -->
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="{DynamicResource FontSizeNormal}"
                        FontWeight="SemiBold"
                        Text="Backup folder" />
                    <TextBlock
                        FontSize="{DynamicResource FontSizeSmall}"
                        Foreground="{StaticResource ForegroundMuted}"
                        Text="[Placeholder — backup location guidance.]"
                        TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding BackupFolder}"
                            PlaceholderText="Choose a folder…" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding BrowseBackupFolderCommand}"
                            Content="Browse…" />
                    </Grid>
                </StackPanel>

                <!--  Backup folder suitability warnings  -->
                <ItemsControl
                    IsVisible="{Binding BackupFolderWarnings.Count, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    ItemsSource="{Binding BackupFolderWarnings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,2"
                                Padding="10,6"
                                Background="{StaticResource NotificationWarningBackground}"
                                BorderBrush="{StaticResource NotificationWarningBorder}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource NotificationWarningText}"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Reader (observer) mode  -->
                <StackPanel Spacing="6">
                    <CheckBox
                        Content="Always open as a read-only observer (reader mode)"
                        FontSize="{DynamicResource FontSizeNormal}"
                        IsChecked="{Binding OpenInReaderMode}" />
                    <TextBlock
                        Margin="28,0,0,0"
                        FontSize="{DynamicResource FontSizeSmall}"
                        Foreground="{StaticResource ForegroundMuted}"
                        Text="Choose this if you only need to view and filter the schedule, not edit it. Reader mode never locks the database, so you'll never block a colleague who needs to make changes. You can change this later under Configuration → Preferences (it takes effect on the next start)."
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  Error message  -->
                <TextBlock
                    FontSize="{DynamicResource FontSizeSmall}"
                    Foreground="{StaticResource NotificationErrorText}"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />

            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
