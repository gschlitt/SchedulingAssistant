<UserControl
    x:Class="TermPoint.Views.Wizard.Steps.Step10ClosingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TermPoint.ViewModels.Wizard.Steps"
    x:CompileBindings="False"
    x:DataType="vm:Step10ClosingViewModel">

    <StackPanel
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="20">


        <!--  Body paragraph 1  -->
        <TextBlock FontSize="{DynamicResource FontSizeNormal}" TextWrapping="Wrap">
            You've finished configuring TermPoint. If you skipped a step and wish to revise the configuration later, you can do so under "Configuration" in the application.
        </TextBlock>

        <!--  Body paragraph 2  -->
        <TextBlock FontSize="{DynamicResource FontSizeNormal}" TextWrapping="Wrap">
            Clicking "Finish" will start-up TermPoint, with your first academic year set-up and ready to go. Your first steps
            should be entering Subjects, Courses and probably Instructors.
        </TextBlock>

        <TextBlock FontSize="{DynamicResource FontSizeNormal}" TextWrapping="Wrap">
            If you're using TermPoint for the first time, you may find it useful to use help facilities under 'Help' and 'Workflows'.
        </TextBlock>





    </StackPanel>

</UserControl>
