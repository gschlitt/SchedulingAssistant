<UserControl
    x:Class="TermPoint.Views.Wizard.Steps.StepLicenseView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TermPoint.ViewModels.Wizard.Steps"
    x:CompileBindings="False"
    x:DataType="vm:StepLicenseViewModel">

    <StackPanel MaxWidth="840" Spacing="16">

        <TextBlock
            FontSize="{DynamicResource FontSizeXLarge}"
            FontWeight="Bold"
            Text="End User License Agreement" />

        <TextBlock FontSize="{DynamicResource FontSizeMedium}" TextWrapping="Wrap">
            This application is licensed under the following custom End User License Agreement
        </TextBlock>

        <ItemsControl ItemsSource="{Binding Paragraphs}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="0,0,0,10" Text="{Binding}" TextWrapping="Wrap" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Margin="0,10" TextWrapping="Wrap">
			By Clicking 'Next' and proceeding with the installation, you agree to be bound by the EULA as stated above.
            If you do not agree, click 'Back' and then 'Cancel'.
        </TextBlock>
    </StackPanel>

</UserControl>
