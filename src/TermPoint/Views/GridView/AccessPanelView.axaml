<UserControl
	x:Class="TermPoint.Views.GridView.AccessPanelView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:conv="using:TermPoint.Converters"
	xmlns:converters="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
	xmlns:vm="using:TermPoint.ViewModels.GridView"
	x:CompileBindings="False"
	x:DataType="vm:AccessPanelViewModel">

	<UserControl.Resources>
		<converters:BorderGapMaskConverter x:Key="BorderGapMaskConverter" />
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Reuse the GroupBox template override from GridFilterView for consistent border gap -->
		<Style Selector="GroupBox">
			<Setter Property="Template">
				<ControlTemplate>
					<Grid x:Name="RootGrid" UseLayoutRounding="true"
						  ColumnDefinitions="2,Auto,*,2"
						  RowDefinitions="Auto,Auto,*,2">
						<Border Grid.Row="1" Grid.RowSpan="3"
								Grid.Column="0" Grid.ColumnSpan="4"
								CornerRadius="{TemplateBinding CornerRadius}"
								BorderThickness="{TemplateBinding BorderThickness}"
								BorderBrush="{StaticResource AppBackground}"
								Background="{TemplateBinding Background}" />
						<Border Grid.Row="1" Grid.RowSpan="3"
								Grid.ColumnSpan="4"
								CornerRadius="{TemplateBinding CornerRadius}"
								BorderThickness="{TemplateBinding BorderThickness}"
								BorderBrush="{TemplateBinding BorderBrush}">
							<Border.OpacityMask>
								<MultiBinding Converter="{StaticResource BorderGapMaskConverter}"
											  ConverterParameter="2">
									<Binding ElementName="Header" Path="Bounds.Width" />
									<Binding RelativeSource="{RelativeSource Self}" Path="Bounds.Width" />
									<Binding RelativeSource="{RelativeSource Self}" Path="Bounds.Height" />
								</MultiBinding>
							</Border.OpacityMask>
						</Border>
						<Border x:Name="Header" Padding="2,0,2,0"
								Grid.Row="0" Grid.RowSpan="2" Grid.Column="1">
							<ContentPresenter Name="PART_HeaderPresenter"
											  Content="{TemplateBinding Header}"
											  ContentTemplate="{TemplateBinding HeaderTemplate}"
											  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
											  UseLayoutRounding="{TemplateBinding UseLayoutRounding}" />
						</Border>
						<ContentPresenter Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
										  Name="PART_ContentPresenter"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  Content="{TemplateBinding Content}"
										  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
										  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
										  UseLayoutRounding="{TemplateBinding UseLayoutRounding}"
										  Margin="{TemplateBinding Padding}" />
					</Grid>
				</ControlTemplate>
			</Setter>
		</Style>

		<!-- Toggle button style matching the filter bar -->
		<Style Selector="ToggleButton.AccessDim">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="3,1,0,0" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="MinWidth" Value="0" />
			<Setter Property="FontSize" Value="{StaticResource FontSizeNormal}" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						Padding="{TemplateBinding Padding}">
						<StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
							<ContentPresenter
								VerticalAlignment="Center"
								Content="{TemplateBinding Content}"
								ContentTemplate="{TemplateBinding ContentTemplate}"
								FontSize="{TemplateBinding FontSize}"
								FontWeight="{TemplateBinding FontWeight}"
								Foreground="{TemplateBinding Foreground}" />
							<Viewbox Width="9" Height="5" VerticalAlignment="Center" Margin="0,1,2,0">
								<Path Data="{StaticResource caretdown}" Fill="{TemplateBinding Foreground}" />
							</Viewbox>
						</StackPanel>
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="ToggleButton.AccessDim:pointerover">
			<Setter Property="Background" Value="{StaticResource ButtonHover}" />
		</Style>
		<Style Selector="ToggleButton.AccessDim:checked">
			<Setter Property="Background" Value="{StaticResource FilterExpanderBorder}" />
		</Style>

		<!-- Watch list item styles -->
		<Style Selector="ToggleSwitch.WatchToggle">
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="MinWidth" Value="0" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</UserControl.Styles>

	<WrapPanel VerticalAlignment="Top">
		<GroupBox
			Margin="5,0,5,0"
			Background="{StaticResource AppBackground}"
			BorderBrush="{StaticResource FilterGroupBorder}"
			Padding="0,-3,0,3"
			BorderThickness="2">
			<GroupBox.Header>
				<StackPanel Orientation="Horizontal">
					<Viewbox Width="13" Height="14">
						<Path
							Fill="Transparent"
							Stroke="Black"
							StrokeThickness="2"
							StrokeLineCap="Round"
							StrokeJoin="Round"
							Data="{StaticResource OpenDoorIcon}" />
					</Viewbox>
					<TextBlock Text="Access" Margin="5,0" />
				</StackPanel>
			</GroupBox.Header>

			<Panel>
				<ToggleButton
					x:Name="AccessToggle"
					Classes="AccessDim">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="{Binding SummaryPrefix}" />
						<TextBlock
							Text="{Binding SummaryConflictText}"
							Foreground="{StaticResource ProgramConflictBrush}"
							IsVisible="{Binding SummaryConflictText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
					</StackPanel>
				</ToggleButton>
				<Popup
					x:Name="AccessPopup"
					IsLightDismissEnabled="True"
					IsOpen="{Binding #AccessToggle.IsChecked, Mode=TwoWay}"
					Placement="Bottom"
					PlacementTarget="{Binding #AccessToggle}">
					<Border
						MinWidth="220"
						MaxHeight="500"
						Padding="8"
						Background="{StaticResource FilterExpanderContent}"
						BorderBrush="{StaticResource FilterPopupBorder}"
						BorderThickness="1"
						CornerRadius="5"
						BoxShadow="{StaticResource FilterPopupShadow}">
						<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="6">
							<!-- Watch list -->
							<ItemsControl ItemsSource="{Binding Watches}">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border
											Padding="4,3"
											Margin="0,0,0,2"
											BorderBrush="{StaticResource FilterGroupBorder}"
											BorderThickness="1"
											CornerRadius="3">
											<Grid ColumnDefinitions="*,Auto,Auto">
												<StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
													<TextBlock
														Text="{Binding Name}"
														FontSize="11"
														FontWeight="SemiBold"
														TextTrimming="CharacterEllipsis" />
													<StackPanel Orientation="Horizontal" Spacing="6">
														<TextBlock
															Text="{Binding ModeSummary}"
															FontSize="10"
															Foreground="Gray" />
														<TextBlock
															Text="{Binding ConflictText}"
															FontSize="10"
															Foreground="{StaticResource ProgramConflictBrush}"
															IsVisible="{Binding ConflictText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
													</StackPanel>
													<!-- Conflict pair details -->
													<ItemsControl
														ItemsSource="{Binding ConflictDetails}"
														IsVisible="{Binding ConflictText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
														Margin="0,2,0,0">
														<ItemsControl.ItemTemplate>
															<DataTemplate>
																<TextBlock
																	Text="{Binding}"
																	FontSize="9"
																	Foreground="{StaticResource ProgramConflictBrush}"
																	Margin="6,0,0,0" />
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ItemsControl>
												</StackPanel>

												<!-- On/off toggle -->
												<CheckBox
													Grid.Column="1"
													IsChecked="{Binding IsEnabled}"
													VerticalAlignment="Center"
													Margin="4,0"
													Padding="0"
													MinHeight="0"
													ToolTip.Tip="Enable or disable this watch" />

												<!-- Delete button -->
												<Button
													Grid.Column="2"
													Background="Transparent"
													BorderThickness="0"
													Padding="2"
													VerticalAlignment="Center"
													Command="{Binding RequestDeleteCommand}"
													ToolTip.Tip="Delete this watch">
													<Viewbox Width="10" Height="10">
														<Path Data="{StaticResource RemoveIcon}" Fill="Gray" />
													</Viewbox>
												</Button>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<!-- Empty state -->
							<TextBlock
								Text="No watches configured."
								FontSize="10"
								Foreground="Gray"
								IsVisible="{Binding !Watches.Count}"
								Margin="0,2" />

							<!-- New Watch button (hidden when creation form is visible) -->
							<Button
								Content="+ New Watch"
								FontSize="10"
								Padding="6,3"
								HorizontalAlignment="Left"
								Command="{Binding BeginCreateWatchCommand}"
								IsVisible="{Binding !Creation.IsVisible}" />

							<!-- Inline creation form -->
							<Border
								IsVisible="{Binding Creation.IsVisible}"
								Padding="6"
								Margin="0,4,0,0"
								BorderBrush="{StaticResource FilterGroupBorder}"
								BorderThickness="1"
								CornerRadius="4">
								<StackPanel Spacing="6" DataContext="{Binding Creation}">
									<!-- Mode selector -->
									<StackPanel Orientation="Horizontal" Spacing="8">
										<RadioButton
											Content="Tag/Level-based"
											FontSize="10"
											IsChecked="{Binding IsTagMode}"
											GroupName="WatchMode"
											MinHeight="0"
											Padding="2,0" />
										<RadioButton
											Content="Course-based"
											FontSize="10"
											IsChecked="{Binding IsCourseMode}"
											GroupName="WatchMode"
											MinHeight="0"
											Padding="2,0" />
									</StackPanel>

									<!-- Tag/Level multi-select (visible in tag/level mode) -->
									<StackPanel IsVisible="{Binding IsTagMode}" Spacing="4">
										<!-- Tags -->
										<TextBlock Text="Tags (AND)" FontSize="9" Foreground="Gray" Margin="2,0,0,0" />
										<Border
											MaxHeight="100"
											BorderBrush="{StaticResource FilterGroupBorder}"
											BorderThickness="1"
											CornerRadius="3"
											Padding="2">
											<ScrollViewer VerticalScrollBarVisibility="Auto">
												<ItemsControl ItemsSource="{Binding Tags}">
													<ItemsControl.ItemTemplate>
														<DataTemplate>
															<CheckBox
																Content="{Binding Name}"
																IsChecked="{Binding IsSelected}"
																FontSize="10"
																MinHeight="0"
																Padding="4,1" />
														</DataTemplate>
													</ItemsControl.ItemTemplate>
												</ItemsControl>
											</ScrollViewer>
										</Border>

										<!-- Divider -->
										<Separator Margin="0,2" />

										<!-- Levels -->
										<TextBlock Text="Levels (OR)" FontSize="9" Foreground="Gray" Margin="2,0,0,0" />
										<Border
											MaxHeight="100"
											BorderBrush="{StaticResource FilterGroupBorder}"
											BorderThickness="1"
											CornerRadius="3"
											Padding="2">
											<ScrollViewer VerticalScrollBarVisibility="Auto">
												<ItemsControl ItemsSource="{Binding Levels}">
													<ItemsControl.ItemTemplate>
														<DataTemplate>
															<CheckBox
																Content="{Binding Name}"
																IsChecked="{Binding IsSelected}"
																FontSize="10"
																MinHeight="0"
																Padding="4,1" />
														</DataTemplate>
													</ItemsControl.ItemTemplate>
												</ItemsControl>
											</ScrollViewer>
										</Border>
									</StackPanel>

									<!-- Course multi-select (visible in course mode) -->
									<Border
										IsVisible="{Binding IsCourseMode}"
										MaxHeight="120"
										BorderBrush="{StaticResource FilterGroupBorder}"
										BorderThickness="1"
										CornerRadius="3"
										Padding="2">
										<ScrollViewer VerticalScrollBarVisibility="Auto">
											<ItemsControl ItemsSource="{Binding Courses}">
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<CheckBox
															Content="{Binding Name}"
															IsChecked="{Binding IsSelected}"
															FontSize="10"
															MinHeight="0"
															Padding="4,1" />
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</ScrollViewer>
									</Border>

									<!-- Auto-generated name -->
									<TextBox
										Text="{Binding WatchName, Mode=TwoWay}"
										PlaceholderText="Watch name (auto-generated)"
										FontSize="10"
										MinHeight="0"
										Padding="4,3" />

									<!-- Validation error -->
									<TextBlock
										Text="{Binding ValidationError}"
										FontSize="10"
										Foreground="Red"
										IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

									<!-- Save / Cancel buttons -->
									<StackPanel Orientation="Horizontal" Spacing="6">
										<Button
											Content="Create"
											FontSize="10"
											Padding="8,3"
											Command="{Binding SaveCommand}" />
										<Button
											Content="Cancel"
											FontSize="10"
											Padding="8,3"
											Command="{Binding CancelCommand}" />
									</StackPanel>
								</StackPanel>
							</Border>
						</StackPanel>
						</ScrollViewer>
					</Border>
				</Popup>
			</Panel>
		</GroupBox>
	</WrapPanel>
</UserControl>
