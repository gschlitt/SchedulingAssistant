<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TermPoint.Views.StickyNoteWindow"
        x:CompileBindings="False"
        WindowDecorations="None"
        Topmost="True"
        CanResize="True"
        ShowInTaskbar="False"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="Manual"
        SizeToContent="Height"
        Width="320"
        MinWidth="240" MinHeight="120">

    <!-- Margin leaves room for the card's drop shadow on the transparent window.
         Drag anywhere on the surface (links/buttons handle their own clicks).
         The note stays Topmost; a close button is the only window control. -->
    <Panel Margin="10" PointerPressed="OnDragPointerPressed">

        <!-- The detached card (a WorkflowCardChrome) is hosted here -->
        <ContentControl x:Name="Host" />

        <!-- Close button, overlaid where the card's chevron/detach used to sit -->
        <Button x:Name="CloseButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,8,0"
                Width="26" Height="26"
                Padding="6"
                Background="Transparent"
                ToolTip.Tip="Close"
                Click="OnCloseClicked">
            <Viewbox Width="12" Height="12">
                <Path Data="{StaticResource RemoveIcon}"
                      Fill="{StaticResource TextFaint}"
                      Stretch="Uniform" />
            </Viewbox>
        </Button>

    </Panel>

</Window>
