<UserControl
    x:Class="TermPoint.Views.Management.AcademicUnitListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TermPoint.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:AcademicUnitListViewModel">

    <StackPanel
        MaxWidth="400"
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="16">

        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Text="Academic Unit" />

        <!--  Display form (when not editing)  -->
        <StackPanel IsVisible="{Binding !IsEditing}" Spacing="8">

            <Border
                Padding="0,0"
                Background="{StaticResource ControlBackground}"
                BorderBrush="{StaticResource ControlBorder}"
                BorderThickness="1">
                <TextBlock VerticalAlignment="Center" Text="{Binding DisplaySummary}" />
            </Border>
            <Button
                Width="80"
                HorizontalAlignment="Left"
                Command="{Binding EditCommand}"
                Content="Edit"
                IsEnabled="{Binding IsWriteEnabled}" />
        </StackPanel>

        <!--  Edit form (when editing)  -->
        <StackPanel IsVisible="{Binding IsEditing}" Spacing="8">
            <TextBlock Text="Academic Unit Name" />
            <TextBox Text="{Binding Name}" />

            <TextBlock Text="Institution Name" />
            <TextBox Text="{Binding InstitutionName}" />

            <TextBlock Text="Institution Abbreviation" />
            <TextBox Text="{Binding InstitutionAbbrev}" />

            <TextBlock
                FontSize="12"
                Foreground="{StaticResource TextError}"
                IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                Text="{Binding ValidationError}" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding SaveCommand}" Content="Apply" />
                <Button Command="{Binding CancelCommand}" Content="Cancel" />
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
