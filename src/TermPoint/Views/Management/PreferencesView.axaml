<UserControl
    x:Class="TermPoint.Views.Management.PreferencesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TermPoint.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:PreferencesViewModel">

   

    <StackPanel
        MaxWidth="500"
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="24">

        <!--  Page title  -->
        <TextBlock
            FontSize="{StaticResource FontSizeXLarge}"
            FontWeight="SemiBold"
            Text="Preferences" />

        <!--  ═══ Section View ═══════════════════════════════════════  -->
        <StackPanel Spacing="12">

            <!--  Sub-heading + rule  -->
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Section View" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <!--  Open with all sections collapsed  -->
           
            <CheckBox 
                Content="Open with all sections collapsed"
                IsChecked="{Binding OpenWithAllSectionsCollapsed}">
                 <CheckBox.Styles>
             <Style Selector="CheckBox /template/ Border#NormalRectangle">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
              </Style>
           </CheckBox.Styles>                
                </CheckBox>
               

            <!--  Filter pass behavior  -->
           
            <StackPanel Spacing="6">
                <TextBlock Text="When a filter passes a section:" />
                <RadioButton 
                    
                    GroupName="FilterPassBehavior"
                    IsChecked="{Binding FilterHighlightsSection}">
                    <RadioButton.Content>
					Highlight the section
                    </RadioButton.Content>
                    </RadioButton>
                <RadioButton
                    Content="Expand the section (and collapse the others)"
                    GroupName="FilterPassBehavior"
                    IsChecked="{Binding FilterExpandsSection}" />
            </StackPanel>

   <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Schedule View" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <StackPanel >
                <StackPanel Orientation="Horizontal">
                <TextBlock Text="Start with FontSize set to "/>
                  <ComboBox
                    Background="Transparent"
					x:Name="TileFontSizeBox"
					Width="52"
					Height="18"
					Padding="4,0"
					VerticalAlignment="Center"
					FontSize="10"
					ItemsSource="{Binding FontSizeOptions}"
					SelectedItem="{Binding TileFontSize, Mode=TwoWay}" />  
                </StackPanel>
              </StackPanel>



        </StackPanel>

        <!--  ═══ Access Mode ═══════════════════════════════════════  -->
        <StackPanel Spacing="12">

            <!--  Sub-heading + rule  -->
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Access Mode" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <!--  Open in reader (observer) mode  -->
            <CheckBox
                Content="Open in reader mode (observe only — never lock the database)"
                IsChecked="{Binding OpenInReaderMode}">
                <CheckBox.Styles>
                    <Style Selector="CheckBox /template/ Border#NormalRectangle">
                        <Setter Property="Width" Value="18" />
                        <Setter Property="Height" Value="18" />
                    </Style>
                </CheckBox.Styles>
            </CheckBox>
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                Text="In reader mode you can view and filter the schedule but not edit it. This instance never takes the write lock, so it can never block someone who needs to make changes. Use Refresh to pull the latest saved data. Takes effect the next time you start the app."
                TextWrapping="Wrap" />

        </StackPanel>

        <!--  ═══ Developer ═══════════════════════════════════════════  -->
        <!--  Only present in DEBUG builds; the Debug menu does not exist in Release.  -->
        <StackPanel Spacing="12" IsVisible="{Binding IsDebugBuild}">

            <!--  Sub-heading + rule  -->
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Developer" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <!--  Show Debug menu  -->
            <CheckBox
                Content="Show Debug menu in the menu bar"
                IsChecked="{Binding ShowDebugMenu}">
                <CheckBox.Styles>
                    <Style Selector="CheckBox /template/ Border#NormalRectangle">
                        <Setter Property="Width" Value="18" />
                        <Setter Property="Height" Value="18" />
                    </Style>
                </CheckBox.Styles>
            </CheckBox>
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                Text="Hides the developer Debug menu (test-data generation, migration utilities) without recompiling. Takes effect the next time you start the app."
                TextWrapping="Wrap" />

        </StackPanel>

    </StackPanel>
</UserControl>
