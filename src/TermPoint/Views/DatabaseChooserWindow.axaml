<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TermPoint.ViewModels"
        x:Class="TermPoint.Views.DatabaseChooserWindow"
        x:CompileBindings="False"
        x:DataType="vm:DatabaseChooserViewModel"
        Title="{Binding WindowTitle}"
        Width="620"
        SizeToContent="Height"
        MinHeight="300"
        MaxHeight="700"
        CanResize="False"
        WindowDecorations="BorderOnly"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}">

    <!--  Slightly larger font scale than the main app, matching the wizard  -->
    <Window.Resources>
        <x:Double x:Key="FontSizeSmall">12</x:Double>
        <x:Double x:Key="FontSizeNormal">14</x:Double>
        <x:Double x:Key="FontSizeMedium">15</x:Double>
        <x:Double x:Key="FontSizeLarge">17</x:Double>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!--  Row 0: Header bar — PointerPressed enables drag since OS title bar is hidden  -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBackground}"
                BorderBrush="{StaticResource ChromeBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12"
                PointerPressed="OnHeaderPointerPressed">
            <StackPanel Spacing="4">
                <TextBlock Text="TermPoint"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{StaticResource TextMuted}" />
                <TextBlock Text="{Binding WindowTitle}"
                           FontSize="{StaticResource FontSizeLarge}"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <!--  Row 1: Scrollable content  -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,8" Spacing="14">

                <!--  ── Recovery banner (visible only in recovery mode) ──────────  -->
                <StackPanel IsVisible="{Binding IsRecoveryMode}" Spacing="8">
                    <TextBlock Text="{Binding ProblemDescription}"
                               FontSize="{StaticResource FontSizeNormal}"
                               TextWrapping="Wrap" />

                    <Border Background="{StaticResource SubtleBackground}"
                            BorderBrush="{StaticResource SubduedBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,7">
                        <TextBlock Text="{Binding LastKnownPath}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextError}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <!--  ── Recent Databases list ────────────────────────────────────  -->
                <StackPanel IsVisible="{Binding HasRecentDatabases}" Spacing="8">
                    <TextBlock Text="Recent Databases"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontWeight="SemiBold" />

                    <Border BorderBrush="{StaticResource SubduedBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="White"
                            MaxHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding RecentDatabases}"
                                     SelectedItem="{Binding SelectedRecentDatabase}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="12,8" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Path}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!--  Inline error when a recent entry fails validation  -->
                <TextBlock Text="{Binding RecentError}"
                           IsVisible="{Binding RecentError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{StaticResource TextError}"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextWrapping="Wrap"
                           Margin="0,-6,0,0" />

                <!--  Divider between recent list and action options  -->
                <StackPanel IsVisible="{Binding HasRecentDatabases}" Spacing="0">
                    <TextBlock Text="Or..."
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!--  ── Option: Open an existing database ─────────────────────────  -->
                <Border BorderBrush="{StaticResource SubduedBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="White">
                    <StackPanel>
                        <Button Background="Transparent"
                                Command="{Binding SelectOptionBrowseCommand}"
                                Padding="12,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <RadioButton IsChecked="{Binding IsOptionBrowseSelected, Mode=OneWay}"
                                             GroupName="ChooserOption"
                                             IsHitTestVisible="False"
                                             VerticalAlignment="Center" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Open an existing database"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Browse for a database file on your computer or network."
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource TextMuted}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <StackPanel IsVisible="{Binding IsOptionBrowseExpanded}"
                                    Margin="12,0,12,12"
                                    Spacing="8">
                            <Border Height="1" Background="{StaticResource SeparatorLine}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding BrowsedPath}"
                                         IsReadOnly="True"
                                         PlaceholderText="No file selected"
                                         VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseForDatabaseCommand}" />
                            </Grid>
                            <TextBlock Text="{Binding BrowseError}"
                                       IsVisible="{Binding BrowseError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource TextError}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── Option: Create a new database ─────────────────────────────  -->
                <Border BorderBrush="{StaticResource SubduedBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="White">
                    <StackPanel>
                        <Button Background="Transparent"
                                Command="{Binding SelectOptionCreateCommand}"
                                Padding="12,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <RadioButton IsChecked="{Binding IsOptionCreateSelected, Mode=OneWay}"
                                             GroupName="ChooserOption"
                                             IsHitTestVisible="False"
                                             VerticalAlignment="Center" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Create a new database"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Launch the setup wizard to create a fresh database from scratch."
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource TextMuted}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <StackPanel IsVisible="{Binding IsOptionCreateExpanded}"
                                    Margin="12,0,12,12"
                                    Spacing="8">
                            <Border Height="1" Background="{StaticResource SeparatorLine}" />
                            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"
                                       Text="The setup wizard will open and guide you through creating a new database. Your existing database files will not be affected." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── Option: Restore from a backup ─────────────────────────────  -->
                <Border BorderBrush="{StaticResource SubduedBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="White">
                    <StackPanel>
                        <Button Background="Transparent"
                                Command="{Binding SelectOptionRestoreCommand}"
                                Padding="12,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <RadioButton IsChecked="{Binding IsOptionRestoreSelected, Mode=OneWay}"
                                             GroupName="ChooserOption"
                                             IsHitTestVisible="False"
                                             VerticalAlignment="Center" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Restore from a backup"
                                               FontSize="{StaticResource FontSizeNormal}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Choose a backup file and pick where to restore it."
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource TextMuted}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <StackPanel IsVisible="{Binding IsOptionRestoreExpanded}"
                                    Margin="12,0,12,12"
                                    Spacing="10">
                            <Border Height="1" Background="{StaticResource SeparatorLine}" />

                            <!--  Step 1  -->
                            <TextBlock Text="Step 1 — Select a backup file"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding BackupPath}"
                                         IsReadOnly="True"
                                         PlaceholderText="No backup selected"
                                         VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseForBackupCommand}" />
                            </Grid>

                            <!--  Step 2 — only visible after a valid backup is chosen  -->
                            <StackPanel IsVisible="{Binding IsBackupStepTwoVisible}" Spacing="8">
                                <TextBlock Text="Step 2 — Confirm restore destination"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding RestorePath}"
                                             IsReadOnly="True"
                                             VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="Change folder…"
                                            Margin="8,0,0,0"
                                            Command="{Binding ChangeRestoreFolderCommand}" />
                                </Grid>
                                <TextBlock Text="The backup will be copied to this location. Your backup file will not be modified."
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{StaticResource TextMuted}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="{Binding RestoreError}"
                                       IsVisible="{Binding RestoreError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{StaticResource TextError}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── Always-open-recent checkbox ───────────────────────────────  -->
                <CheckBox IsChecked="{Binding AlwaysOpenRecent}"
                          Margin="0,4,0,0">
                    <CheckBox.Styles>
                        <Style Selector="CheckBox /template/ Border#NormalRectangle">
                            <Setter Property="Width" Value="18" />
                            <Setter Property="Height" Value="18" />
                        </Style>
                    </CheckBox.Styles>
                    <TextBlock Text="Always open my most recent database"
                               FontSize="{StaticResource FontSizeSmall}" />
                </CheckBox>

            </StackPanel>
        </ScrollViewer>

        <!--  Row 2: Footer with Exit and Continue  -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource SeparatorLine}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Button Grid.Column="1"
                        Content="Exit TermPoint"
                        Margin="0,0,8,0"
                        Command="{Binding ExitCommand}" />
                <Button Grid.Column="2"
                        Content="{Binding ContinueButtonText}"
                        IsEnabled="{Binding CanContinue}"
                        FontWeight="SemiBold"
                        Command="{Binding ContinueCommand}" />
            </Grid>
        </Border>

    </Grid>
</Window>
