<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step5LegalStartTimesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SchedulingAssistant.ViewModels.Wizard.Steps"
    x:CompileBindings="False">

    <StackPanel MaxWidth="900" Spacing="14">

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            Block lengths are the standard class durations at your institution (e.g. 1.5 hours, 3 hours).
            For each block length, specify the valid start times. (Often these are specified by your registrar.)<LineBreak /><LineBreak />
            Two example blocks are provided below. Edit or delete them and add your own.
            Times use 24-hour HHMM format (<Italic>0800</Italic>
            = 8:00 AM,<Italic>1330</Italic>
            = 1:30 PM).<LineBreak /><LineBreak />
            You are not confined to these lengths and times when editing sections, but they make data entry much faster.
            If you do not wish to supply these
            now, you can do so later in the application.</TextBlock>

        <!--  One card per block length  -->
        <ItemsControl ItemsSource="{Binding BlockLengths}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="local:WizardBlockLengthEntry">

                    <Border
                        Margin="0,0,0,8"
                        Padding="14,10"
                        BorderBrush="{StaticResource SeparatorLine}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Spacing="8">

                            <!--  Card header: label + remove button  -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource FontSizeNormal}"
                                    FontWeight="SemiBold"
                                    Text="{Binding Label}" />
                                <Button
                                    Grid.Column="1"
                                    Padding="8,3"
                                    Command="{Binding $parent[UserControl].DataContext.RemoveBlockLengthCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove block"
                                    FontSize="{DynamicResource FontSizeSmall}" />
                            </Grid>

                            <!--  Start time chips — each has a × remove button  -->
                            <ItemsControl ItemsSource="{Binding StartTimes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="local:WizardStartTimeEntry">
                                        <Border
                                            Margin="0,0,5,5"
                                            Padding="6,2"
                                            Background="{StaticResource ChromeBackground}"
                                            BorderBrush="{StaticResource ChromeBorder}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="{DynamicResource FontSizeSmall}"
                                                    Text="{Binding Hhmm}" />
                                                <Button
                                                    Padding="2,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding $parent[ItemsControl].DataContext.RemoveTimeCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="×"
                                                    FontSize="{DynamicResource FontSizeSmall}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Add time row  -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBox
                                        Width="80"
                                        FontFamily="Consolas"
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Text="{Binding NewTimeInput}"
                                        Watermark="HHMM" />
                                    <Button
                                        Command="{Binding AddTimeCommand}"
                                        Content="Add time"
                                        FontSize="{DynamicResource FontSizeSmall}" />
                                </StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource ErrorForeground}"
                                    IsVisible="{Binding AddTimeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding AddTimeError}" />
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  Add a new block length  -->
        <Border
            Padding="14,10"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel Spacing="6">
                <TextBlock
                    FontSize="{DynamicResource FontSizeNormal}"
                    FontWeight="SemiBold"
                    Text="Add a block length" />
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBox
                        Width="72"
                        FontFamily="Consolas"
                        FontSize="{DynamicResource FontSizeSmall}"
                        Text="{Binding NewBlockLengthInput}"
                        Watermark="e.g. 1.5" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeSmall}"
                        Text="hours" />
                    <Button
                        Command="{Binding AddBlockLengthCommand}"
                        Content="Add block length"
                        FontSize="{DynamicResource FontSizeSmall}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Weekend day availability  -->
        <StackPanel Spacing="6">
            <TextBlock
                FontSize="{DynamicResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Weekend days" />
            <CheckBox Content="Include Saturday as an available scheduling day"
                      IsChecked="{Binding IncludeSaturday}" />
            <CheckBox Content="Include Sunday as an available scheduling day"
                      IsChecked="{Binding IncludeSunday}" />
        </StackPanel>

    </StackPanel>
</UserControl>
