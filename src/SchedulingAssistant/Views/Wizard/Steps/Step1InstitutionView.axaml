<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step1InstitutionView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="820" Spacing="20">

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            Enter your institution's full name and a short abbreviation.
            The abbreviation is used to suggest a database filename.
        </TextBlock>

        <!--  Institution row  -->
        <Border
            Padding="0,0,0,16"
            BorderBrush="{StaticResource SeparatorLine}"
            BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,12,170" RowDefinitions="Auto,8,Auto">
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    FontSize="{DynamicResource FontSizeNormal}"
                    FontWeight="SemiBold"
                    Text="Institution" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="{Binding InstitutionName}"
                    Watermark="e.g. Greendale Community College" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="2"
                    Text="{Binding InstitutionAbbrev}"
                    Watermark="Abbrev (e.g. GCC)" />
            </Grid>
        </Border>

        <!--  Academic Unit row  -->
        <Grid ColumnDefinitions="*,12,170" RowDefinitions="Auto,8,Auto,8,Auto">
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                FontSize="{DynamicResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Academic Unit" />
            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                FontSize="{DynamicResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                TextWrapping="Wrap">
                The department or faculty using this schedule (e.g. "School of Arts", "Computer Science").
            </TextBlock>
            <TextBox
                Grid.Row="4"
                Grid.Column="0"
                Text="{Binding AcUnitName}"
                Watermark="e.g. School of Business" />
            <TextBox
                Grid.Row="4"
                Grid.Column="2"
                Text="{Binding AcUnitAbbrev}"
                Watermark="Abbrev (e.g. BUS)" />
        </Grid>

    </StackPanel>
</UserControl>
