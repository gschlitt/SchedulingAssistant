<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step3TpConfigView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="840" Spacing="20">

        <TextBlock
            FontSize="{StaticResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            The next few steps of the wizard allow you to configure the application to your institution's scheduling patterns, and to set up
            some tools that will greatly speed up your scheduling work. You can choose to exit the setup process now and to configure later, but
            the wizard makes it easier to do now.
        </TextBlock>
        <TextBlock
            FontSize="{StaticResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            If you have a .tpconfig file (perhaps from a colleague at your institution) you can choose to use that now, and import all the
            configuration settings automatically.
        </TextBlock>
        <TextBlock
            FontSize="{StaticResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            Otherwise, you can proceed through the wizard. Any of the steps can be passed over if you wish to take care of them later, but are easier to set now.
        </TextBlock>

        <!--  Radio: Manual setup  -->
        <RadioButton
            Content="I'll continue with the wizard"
            FontSize="{StaticResource FontSizeMedium}"
            IsChecked="{Binding IsManualChoice}" />

        <!--  Radio: Import .tpconfig  -->
        <StackPanel Spacing="10">
            <RadioButton
                Content="I have a .tpconfig file from a colleague or previous setup"
                FontSize="{StaticResource FontSizeMedium}"
                IsChecked="{Binding IsImportChoice}" />

            <!--  File picker — visible only when Import is selected  -->
            <Grid
                Margin="24,0,0,0"
                ColumnDefinitions="*,8,Auto"
                IsVisible="{Binding IsImportChoice}">
                <TextBox
                    Grid.Column="0"
                    IsReadOnly="True"
                    Text="{Binding TpConfigPath}"
                    Watermark="Path to .tpconfig file…" />
                <Button
                    Grid.Column="2"
                    Command="{Binding BrowseTpConfigCommand}"
                    Content="Browse…" />
            </Grid>
        </StackPanel>

        <!--  Radio: Exit now  -->
        <StackPanel Spacing="4">
            <RadioButton FontSize="{StaticResource FontSizeMedium}" IsChecked="{Binding IsExitNowChoice}">
                <RadioButton.Content>
                    <TextBlock Text="I'd like to exit the wizard now. I will configure settings later (under Settings), in the application." TextWrapping="Wrap" />
                </RadioButton.Content>
            </RadioButton>
            <TextBlock
                Margin="24,0,0,0"
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{StaticResource ForegroundMuted}"
                IsVisible="{Binding IsExitNowChoice}"
                TextWrapping="Wrap">
                The database has been created. You can configure block patterns, semesters, and
                other settings from within the application at any time.
            </TextBlock>
        </StackPanel>

    </StackPanel>
</UserControl>
