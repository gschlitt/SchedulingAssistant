<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step10ClosingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Wizard.Steps"
    x:CompileBindings="False"
    x:DataType="vm:Step10ClosingViewModel">

    <StackPanel
        MaxWidth="540"
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="20">


        <!--  Body paragraph 1  -->
        <TextBlock FontSize="{StaticResource FontSizeNormal}" TextWrapping="Wrap">
            You've finished configuring TermPoint. If you skipped a step and wish to revise the configuration later, you can do so under "Settings" in the application.
        </TextBlock>

        <!--  Body paragraph 2  -->
        <TextBlock FontSize="{StaticResource FontSizeNormal}" TextWrapping="Wrap">
            Clicking "Finish" will startup TermPoint, with your first academic year setup and ready to go.
            At the very least you'll want to enter some Courses using the Course Editor before you start
            scheduling, and possibly some Instructors.
            You may also wish to visit Section Properties to further choose things like reserve codes, tags, rooms
            and so on.
            You can view a short video which demonstrates the basics of TermPoint use here.
            There's lots of help available under "Help"!
        </TextBlock>

        <!--  Call-to-action note  -->
        <TextBlock
            FontSize="{StaticResource FontSizeSmall}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            [Footer note — e.g. "Click Finish to open the application."]
        </TextBlock>

    </StackPanel>

</UserControl>
