<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step1aExistingDbView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="860" Spacing="20">


        <TextBlock Text="Have you already been provided with a TermPoint database (.db file)? Unless someone has already set-up a database file for you should proceed with a fresh install." TextWrapping="Wrap" />

        <!--  Radio: fresh install  -->
        <RadioButton
            Content="This is a fresh install. I need to set up my own database."
            FontSize="{DynamicResource FontSizeNormal}"
            IsChecked="{Binding IsNewSetupChoice}" />

        <!--  Radio: existing database  -->
        <StackPanel Spacing="12">
            <RadioButton
                Content="I already have a database and want to use that."
                FontSize="{DynamicResource FontSizeNormal}"
                IsChecked="{Binding IsExistingDbChoice}" />

            <!--  Detail pane — revealed when existing DB is chosen  -->
            <StackPanel
                Margin="28,0,0,0"
                IsVisible="{Binding IsExistingDbChoice}"
                Spacing="16">

                <!--  Placeholder text — user will supply  -->
                <TextBlock
                    FontSize="{DynamicResource FontSizeNormal}"
                    Foreground="{StaticResource ForegroundMuted}"
                    Text="[Placeholder — instructions for connecting to a shared database.]"
                    TextWrapping="Wrap" />

                <!--  Database file  -->
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="{DynamicResource FontSizeNormal}"
                        FontWeight="SemiBold"
                        Text="Database file" />
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding DbPath}"
                            Watermark="Choose the .db file…" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding BrowseDbFileCommand}"
                            Content="Browse…" />
                    </Grid>
                </StackPanel>

                <!--  Backup folder  -->
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="{DynamicResource FontSizeNormal}"
                        FontWeight="SemiBold"
                        Text="Backup folder" />
                    <TextBlock
                        FontSize="{DynamicResource FontSizeSmall}"
                        Foreground="{StaticResource ForegroundMuted}"
                        Text="[Placeholder — backup location guidance.]"
                        TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,8,Auto">
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{Binding BackupFolder}"
                            Watermark="Choose a folder…" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding BrowseBackupFolderCommand}"
                            Content="Browse…" />
                    </Grid>
                </StackPanel>

                <!--  Error message  -->
                <TextBlock
                    FontSize="{DynamicResource FontSizeSmall}"
                    Foreground="{StaticResource NotificationErrorText}"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />

            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
