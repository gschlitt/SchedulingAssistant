<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step0WelcomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <StackPanel MaxWidth="560" Spacing="16">
        <TextBlock
            FontSize="22"
            FontWeight="Bold"
            Text="Welcome to TermPoint!" />

        <TextBlock FontSize="13" TextWrapping="Wrap">
            TermPoint helps university administrators visualize and manage how course sections
            fit together across a weekly schedule.
        </TextBlock>

        <TextBlock FontSize="13" TextWrapping="Wrap">
            This short setup wizard will guide you through:
        </TextBlock>

        <StackPanel Margin="16,0,0,0" Spacing="6">
            <TextBlock FontSize="13" Text="• Your institution and academic unit name" />
            <TextBlock FontSize="13" Text="• Where to store your database and backups" />
            <TextBlock FontSize="13" Text="• Block lengths, start times, and section prefixes" />
            <TextBlock FontSize="13" Text="• Your first academic year and its semesters" />
        </StackPanel>

        <TextBlock
            FontSize="12"
            Foreground="{DynamicResource ForegroundMuted}"
            TextWrapping="Wrap">
            Click Next to begin.
        </TextBlock>
    </StackPanel>
</UserControl>
