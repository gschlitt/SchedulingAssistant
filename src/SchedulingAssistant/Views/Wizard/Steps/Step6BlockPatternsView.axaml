<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mgmt="using:SchedulingAssistant.Views.Management"
             x:Class="SchedulingAssistant.Views.Wizard.Steps.Step6BlockPatternsView"
             x:CompileBindings="False">

    <StackPanel Spacing="16" MaxWidth="600">

        <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource FontSizeNormal}"
                   Foreground="{DynamicResource ForegroundMuted}">
            Block patterns define which days of the week a class meets for each block length.
            For example, a 1.5-hour block typically meets Monday/Wednesday/Friday (MWF)
            or Tuesday/Thursday (TR).
        </TextBlock>

        <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource FontSizeNormal}"
                   Foreground="{DynamicResource ForegroundMuted}">
            TermPoint uses these patterns to suggest meeting day combinations when you add a section.
            You can define multiple patterns per block length to cover all the day combinations
            used at your institution. Block patterns can be changed later in Settings.
        </TextBlock>

        <mgmt:BlockPatternListView DataContext="{Binding BlockPatterns}"/>

    </StackPanel>
</UserControl>
