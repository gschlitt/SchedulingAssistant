<UserControl
    x:Class="SchedulingAssistant.Views.Wizard.Steps.Step6BlockPatternsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mgmt="using:SchedulingAssistant.Views.Management"
    x:CompileBindings="False">

    <StackPanel MaxWidth="900" Spacing="16">

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            Block patterns define which days of the week a class typically meets.
            For example, a 1.5-hour block may typically meet Monday/Wednesday/Friday (MWF)
            or Tuesday/Thursday (TR).
        </TextBlock>

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource ForegroundMuted}"
            TextWrapping="Wrap">
            TermPoint uses these patterns to make data entry faster when you add a section.
            You can define multiple patterns per block length to cover all the day combinations
            used at your institution. Block patterns can be changed later in Settings, and you are not
            confined to use them when scheduling.
        </TextBlock>

        <mgmt:BlockPatternListView DataContext="{Binding BlockPatterns}" />

    </StackPanel>
</UserControl>
