<UserControl
	x:Class="SchedulingAssistant.Views.GridView.SharedScheduleStripView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:SchedulingAssistant.ViewModels.GridView"
	x:DataType="vm:SharedScheduleStripViewModel"
	IsVisible="{Binding IsVisible}">

	<Border
		Background="{StaticResource SharedScheduleStripBackground}"
		BorderBrush="{StaticResource SharedScheduleBorder}"
		BorderThickness="3,0,0,0"
		Padding="8,4">

		<DockPanel>

			<!-- Dismiss All button — right-aligned -->
			<Button
				DockPanel.Dock="Right"
				Padding="6,2"
				Command="{Binding DismissAllCommand}"
				Content="Dismiss All"
				FontSize="10"
				VerticalAlignment="Top" />

			<StackPanel>

				<!-- Collapsed header row -->
				<StackPanel Orientation="Horizontal" Spacing="6">
					<Button
						Padding="2"
						Background="Transparent"
						BorderThickness="0"
						Command="{Binding ToggleExpandCommand}"
						FontSize="10">
						<Panel>
							<TextBlock Text="▼" IsVisible="{Binding IsExpanded}" />
							<TextBlock Text="▶" IsVisible="{Binding !IsExpanded}" />
						</Panel>
					</Button>
					<TextBlock
						VerticalAlignment="Center"
						FontSize="11"
						FontWeight="SemiBold"
						Text="Shared Schedules:" />
					<TextBlock
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="{StaticResource SharedScheduleText}"
						IsVisible="{Binding !IsExpanded}"
						Text="{Binding CollapsedSummary}" />
				</StackPanel>

				<!-- Expanded per-source groups -->
				<ScrollViewer
					MaxHeight="200"
					Margin="0,4,0,0"
					IsVisible="{Binding IsExpanded}">
					<ItemsControl ItemsSource="{Binding SourceGroups}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:SharedScheduleSourceGroup">
								<Border
									Margin="0,2"
									Padding="6,4"
									BorderBrush="{StaticResource SharedScheduleBorder}"
									BorderThickness="1"
									CornerRadius="3">
									<StackPanel Spacing="2">

										<!-- Group header -->
										<DockPanel>
											<Button
												DockPanel.Dock="Right"
												Padding="4,1"
												FontSize="9"
												Content="×"
												Command="{Binding $parent[ItemsControl].DataContext.DismissSourceCommand}"
												CommandParameter="{Binding Set}" />
											<StackPanel Orientation="Horizontal" Spacing="6">
												<TextBlock
													FontSize="10"
													FontWeight="SemiBold"
													Foreground="{StaticResource SharedScheduleText}"
													Text="{Binding SourceLabel}" />
												<TextBlock
													FontSize="10"
													Foreground="{StaticResource TextFaint}"
													Text="{Binding ExportDate, StringFormat='exported {0}'}"
													IsVisible="{Binding ExportDate, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
											</StackPanel>
										</DockPanel>

										<!-- Section rows -->
										<ItemsControl ItemsSource="{Binding Rows}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="vm:SharedScheduleSourceRow">
													<StackPanel Orientation="Horizontal" Spacing="8">
														<TextBlock
															FontSize="10"
															FontWeight="SemiBold"
															Text="{Binding Label}" />
														<TextBlock
															FontSize="10"
															Text="{Binding Schedule}" />
														<TextBlock
															FontSize="10"
															FontStyle="Italic"
															Foreground="{StaticResource TextFaint}"
															Text="{Binding Notes}"
															MaxWidth="200"
															TextTrimming="CharacterEllipsis"
															IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
													</StackPanel>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>

									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

			</StackPanel>
		</DockPanel>
	</Border>
</UserControl>
