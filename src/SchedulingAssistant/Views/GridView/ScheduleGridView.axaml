<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.GridView"
             xmlns:local="using:SchedulingAssistant.Views.GridView"
             x:Class="SchedulingAssistant.Views.GridView.ScheduleGridView"
             x:DataType="vm:ScheduleGridViewModel"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="Button.CtxMenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.CtxMenuItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="CheckBox.CtxCheck">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="ListBox.CtxList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style Selector="ListBox.CtxList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Row 0: Filter bar - always visible -->
        <local:GridFilterView Grid.Row="0" DataContext="{Binding Filter}" />

        <!-- Row 1: Error banner (only visible when LastErrorMessage is set) -->
        <Border Grid.Row="1"
                IsVisible="{Binding LastErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{StaticResource ErrorBannerBackground}" BorderBrush="{StaticResource ErrorBannerBorder}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Command="{Binding DismissErrorCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="4,1" FontSize="11"
                        ToolTip.Tip="Dismiss" />
                <TextBlock Text="{Binding LastErrorMessage}"
                           FontSize="11" Foreground="{StaticResource ErrorBannerText}"
                           VerticalAlignment="Center"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Row 2: Grid canvas with zoom transform -->
        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Border x:Name="ZoomContainer" HorizontalAlignment="Left">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                </Border.RenderTransform>
                <Canvas x:Name="GridCanvas" />
            </Border>
        </ScrollViewer>

        <!-- Row 3: Zoom footer -->
        <Border Grid.Row="3"
                Background="{StaticResource ChromeBackground}"
                BorderBrush="{StaticResource ChromeBorder}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="ZoomPercentLabel"
                           FontSize="10"
                           Foreground="Black"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Width="40"
                           TextAlignment="Right" />
                <Slider DockPanel.Dock="Right"
                        x:Name="ZoomSlider"
                        Minimum="0.5"
                        Maximum="2.5"
                        TickFrequency="0.1"
                        TickPlacement="None"
                        Width="120"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center" />
                <TextBlock Text="Zoom:"
                           FontSize="10"
                           Foreground="Black"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Tile right-click context menu popup -->
        <Popup x:Name="TileContextPopup"
               Placement="Pointer"
               IsLightDismissEnabled="True"
               IsOpen="{Binding ContextMenu.IsOpen, Mode=TwoWay}"
               Grid.RowSpan="4">
            <Border Background="White"
                    BorderBrush="{StaticResource FilterExpanderBorder}"
                    BorderThickness="1"
                    CornerRadius="4"
                    BoxShadow="0 2 8 0 #33000000">
                <StackPanel Orientation="Horizontal">

                    <!-- Primary: 3 menu items -->
                    <StackPanel MinWidth="210">
                        <Button Classes="CtxMenuItem"
                                Command="{Binding ContextMenu.ShowInstructorsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Assign Instructor to Section" VerticalAlignment="Center" />
                                <TextBlock Text="▶" FontSize="9" VerticalAlignment="Center"
                                           Foreground="Gray" Margin="0,1,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Classes="CtxMenuItem"
                                Command="{Binding ContextMenu.ShowRoomCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Assign Room to Section Booking" VerticalAlignment="Center" />
                                <TextBlock Text="▶" FontSize="9" VerticalAlignment="Center"
                                           Foreground="Gray" Margin="0,1,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Classes="CtxMenuItem"
                                Command="{Binding ContextMenu.ShowTagsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Assign Tag to Section" VerticalAlignment="Center" />
                                <TextBlock Text="▶" FontSize="9" VerticalAlignment="Center"
                                           Foreground="Gray" Margin="0,1,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Sub-panel: appears when a menu item is chosen -->
                    <Border IsVisible="{Binding ContextMenu.HasSubPanel}"
                            BorderBrush="{StaticResource FilterExpanderBorder}"
                            BorderThickness="1,0,0,0"
                            MinWidth="180" MaxWidth="260">
                        <DockPanel>

                            <!-- OK / Cancel -->
                            <StackPanel DockPanel.Dock="Bottom"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="4"
                                        Margin="6,4">
                                <Button Content="OK"
                                        Command="{Binding ContextMenu.ConfirmCommand}"
                                        Padding="12,3" FontSize="11"
                                        MinHeight="0" MinWidth="0" />
                                <Button Content="Cancel"
                                        Command="{Binding ContextMenu.CancelCommand}"
                                        Padding="12,3" FontSize="11"
                                        MinHeight="0" MinWidth="0" />
                            </StackPanel>

                            <!-- Lists -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                <Panel>

                                    <!-- Instructors -->
                                    <ListBox Classes="CtxList"
                                             IsVisible="{Binding ContextMenu.IsInstructorPanelVisible}"
                                             ItemsSource="{Binding ContextMenu.Instructors}"
                                             SelectionMode="Multiple">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Classes="CtxCheck"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          Content="{Binding Label}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Room (single select) -->
                                    <ListBox Classes="CtxList"
                                             IsVisible="{Binding ContextMenu.IsRoomPanelVisible}"
                                             ItemsSource="{Binding ContextMenu.Rooms}"
                                             SelectedItem="{Binding ContextMenu.SelectedRoom, Mode=TwoWay}"
                                             SelectionMode="Single">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}"
                                                           FontSize="11"
                                                           Padding="4,2" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Tags -->
                                    <ListBox Classes="CtxList"
                                             IsVisible="{Binding ContextMenu.IsTagPanelVisible}"
                                             ItemsSource="{Binding ContextMenu.Tags}"
                                             SelectionMode="Multiple">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Classes="CtxCheck"
                                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                          Content="{Binding Label}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </Panel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Popup>

    </Grid>

</UserControl>
