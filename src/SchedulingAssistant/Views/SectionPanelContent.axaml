<UserControl
	x:Class="SchedulingAssistant.Views.SectionPanelContent"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:b="using:SchedulingAssistant.Behaviors"
	xmlns:views="using:SchedulingAssistant.Views.Management"
	x:CompileBindings="False">

	<!--
		Content area for the Section / Events panel.
		Contains the action button bars and the scrollable list views.
		Expects MainWindowViewModel as DataContext.
		Used inside the DetachablePanel (docked) and in the detached window.
	-->
	<Grid RowDefinitions="Auto,Auto,Auto,*" Background="{StaticResource AppBackground}">

		<!--  Action buttons  -->
		<StackPanel Grid.Row="0" IsEnabled="{Binding SemesterContext.HasSemesterSelected}">

			<!--
				Section action buttons.
				Collapse/expand and sort are always enabled (view-only operations).
				Add/Edit/Copy/Delete are gated by IsWriteEnabled via an inner StackPanel.
				Visibility of the whole row swaps with the Meeting action buttons.
			-->
			<StackPanel
				Margin="0,12,0,4"
				VerticalAlignment="Top"
				DataContext="{Binding SectionListVm}"
				IsVisible="{Binding DataContext.IsShowingSections, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Orientation="Horizontal"
				Spacing="3">
				<!--  Always enabled: collapse/expand do not write to the database  -->
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="4,1"
					Background="Transparent"
					BorderThickness="0"
					Command="{Binding ExpandAllCommand}"
					Content="▼"
					FontSize="9"
					ToolTip.Tip="Expand all cards" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="4,1"
					Background="Transparent"
					BorderThickness="0"
					Command="{Binding CollapseAllCommand}"
					Content="▶"
					FontSize="9"
					ToolTip.Tip="Collapse all cards" />
				<Border
					Width="1"
					Margin="2,2"
					Background="{StaticResource SeparatorLine}" />
				<!--  Write-gated: Add/Edit/Copy/Delete  -->
				<StackPanel
					IsEnabled="{Binding IsWriteEnabled}"
					Orientation="Horizontal"
					Spacing="3">
					<Button
						MinWidth="0"
						MinHeight="0"
						Padding="5,1"
						b:HelpTip.Text="Add a new section"
						Command="{Binding AddCommand}"
						Content="Add"
						FontSize="{StaticResource FontSizeNormal}" />
					<Button
						MinWidth="0"
						MinHeight="0"
						Padding="5,1"
						b:HelpTip.Text="Edit the selected section. You can also begin editing by double-clicking a section or by pressing 'Enter' with a section selected."
						Command="{Binding EditCommand}"
						Content="Edit"
						FontSize="{StaticResource FontSizeNormal}"
						IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
					<Button
						MinWidth="0"
						MinHeight="0"
						Padding="5,1"
						b:HelpTip.Text="Copy the selected section, incrementing the section code"
						Command="{Binding CopyCommand}"
						Content="Copy"
						FontSize="{StaticResource FontSizeNormal}"
						IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
					<Button
						MinWidth="0"
						MinHeight="0"
						Padding="5,1"
						Command="{Binding DeleteCommand}"
						Content="Delete"
						FontSize="{StaticResource FontSizeNormal}"
						IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				</StackPanel>
				<!--  Always enabled: sort is a view preference, not a data write  -->
				<TextBlock
					VerticalAlignment="Center"
					FontSize="{StaticResource FontSizeNormal}"
					Text="Sort:" />
				<ComboBox
					MinHeight="0"
					Padding="5,1"
					VerticalAlignment="Center"
					Background="{StaticResource ButtonBackground}"
					BorderThickness="0"
					CornerRadius="4"
					FontSize="{StaticResource FontSizeNormal}"
					ItemsSource="{Binding SortModeOptions}"
					SelectedIndex="{Binding SelectedSortModeIndex}" />
			</StackPanel>

			<!--  Event action buttons — shown when Events View is active  -->
			<StackPanel
				Margin="0,8,0,1"
				VerticalAlignment="Top"
				DataContext="{Binding MeetingListVm}"
				IsEnabled="{Binding IsWriteEnabled}"
				IsVisible="{Binding DataContext.IsShowingMeetings, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Orientation="Horizontal"
				Spacing="3">
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding AddCommand}"
					Content="Add"
					FontSize="14" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding EditCommand}"
					Content="Edit"
					FontSize="14"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding DeleteCommand}"
					Content="Delete"
					FontSize="14"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
			</StackPanel>

		</StackPanel>

		<!--  Hint shown when no semester is selected  -->
		<TextBlock
			Grid.Row="1"
			Margin="4,2,0,2"
			FontSize="10"
			Foreground="{StaticResource TextFaint}"
			IsVisible="{Binding !SemesterContext.HasSemesterSelected}"
			Text="Select a semester to load sections" />

		<!--  Edit-conflict advisory — always visible above the scroll area regardless of scroll position  -->
		<Border
			Grid.Row="2"
			Padding="6,3"
			Background="{StaticResource ErrorBannerBackground}"
			BorderBrush="{StaticResource ErrorBannerBorder}"
			BorderThickness="0,0,0,1"
			IsVisible="{Binding SectionListVm.LastErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
			<DockPanel>
				<Button
					Padding="3,1"
					Background="Transparent"
					BorderThickness="0"
					Command="{Binding SectionListVm.DismissErrorCommand}"
					Content="✕"
					DockPanel.Dock="Right"
					FontSize="10"
					ToolTip.Tip="Dismiss" />
				<TextBlock
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{StaticResource ErrorBannerText}"
					Text="{Binding SectionListVm.LastErrorMessage}"
					TextWrapping="Wrap" />
			</DockPanel>
		</Border>

		<!--  Content: swaps between Section View and Events View  -->
		<ScrollViewer
			Grid.Row="3"
			HorizontalScrollBarVisibility="Disabled"
			VerticalScrollBarVisibility="Auto">
			<StackPanel b:SuppressPopupScrollBehavior.IsEnabled="True">
				<views:SectionListView DataContext="{Binding SectionListVm}" IsVisible="{Binding DataContext.IsShowingSections, RelativeSource={RelativeSource AncestorType=UserControl}}" />
				<views:MeetingListView DataContext="{Binding MeetingListVm}" IsVisible="{Binding DataContext.IsShowingMeetings, RelativeSource={RelativeSource AncestorType=UserControl}}" />
			</StackPanel>
		</ScrollViewer>

	</Grid>

</UserControl>
