<UserControl
	x:Class="SchedulingAssistant.Views.SectionPanelContent"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:b="using:SchedulingAssistant.Behaviors"
	xmlns:views="using:SchedulingAssistant.Views.Management"
	x:CompileBindings="False">

	<!--
		Content area for the Section / Events panel.
		Contains the action button bars and the scrollable list views.
		Expects MainWindowViewModel as DataContext.
		Used inside the DetachablePanel (docked) and in the detached window.
	-->
	<Grid RowDefinitions="Auto,*">

		<!--  Action buttons  -->
		<StackPanel Grid.Row="0">

			<!--
				Section action buttons — the entire group is disabled in read-only mode
				via a single IsEnabled binding on the container.
				Visibility swaps with the Meeting action buttons based on IsShowingMeetings.
			-->
			<StackPanel
				Margin="0,4,0,4"
				VerticalAlignment="Top"
				DataContext="{Binding SectionListVm}"
				IsEnabled="{Binding IsWriteEnabled}"
				IsVisible="{Binding DataContext.IsShowingSections, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Orientation="Horizontal"
				Spacing="3">
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="4,1"
					Background="Transparent"
					BorderThickness="0"
					Command="{Binding ExpandAllCommand}"
					Content="▼"
					FontSize="9"
					ToolTip.Tip="Expand all cards" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="4,1"
					Background="Transparent"
					BorderThickness="0"
					Command="{Binding CollapseAllCommand}"
					Content="▶"
					FontSize="9"
					ToolTip.Tip="Collapse all cards" />
				<Border
					Width="1"
					Margin="2,2"
					Background="{StaticResource SeparatorLine}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					b:HelpTip.Text="Add a new section"
					Command="{Binding AddCommand}"
					Content="Add"
					FontSize="{StaticResource FontSizeNormal}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					b:HelpTip.Text="Edit the selected section. You can also begin editing by double-clicking a section or by pressing 'Enter' with a section selected."
					Command="{Binding EditCommand}"
					Content="Edit"
					FontSize="{StaticResource FontSizeNormal}"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					b:HelpTip.Text="Copy the selected section, incrementing the section code"
					Command="{Binding CopyCommand}"
					Content="Copy"
					FontSize="{StaticResource FontSizeNormal}"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding DeleteCommand}"
					Content="Delete"
					FontSize="{StaticResource FontSizeNormal}"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				<TextBlock
					VerticalAlignment="Center"
					FontSize="{StaticResource FontSizeNormal}"
					Text="Sort:" />
				<ComboBox
					MinHeight="0"
					Padding="5,1"
					VerticalAlignment="Center"
					Background="{StaticResource ButtonBackground}"
					BorderThickness="0"
					CornerRadius="4"
					FontSize="{StaticResource FontSizeNormal}"
					ItemsSource="{Binding SortModeOptions}"
					SelectedIndex="{Binding SelectedSortModeIndex}" />
			</StackPanel>

			<!--  Event action buttons — shown when Events View is active  -->
			<StackPanel
				Margin="0,8,0,1"
				VerticalAlignment="Top"
				DataContext="{Binding MeetingListVm}"
				IsEnabled="{Binding IsWriteEnabled}"
				IsVisible="{Binding DataContext.IsShowingMeetings, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Orientation="Horizontal"
				Spacing="3">
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding AddCommand}"
					Content="Add"
					FontSize="14" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding EditCommand}"
					Content="Edit"
					FontSize="14"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
				<Button
					MinWidth="0"
					MinHeight="0"
					Padding="5,1"
					Command="{Binding DeleteCommand}"
					Content="Delete"
					FontSize="14"
					IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
			</StackPanel>

		</StackPanel>

		<!--  Content: swaps between Section View and Events View  -->
		<ScrollViewer
			Grid.Row="1"
			HorizontalScrollBarVisibility="Disabled"
			VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<views:SectionListView DataContext="{Binding SectionListVm}" IsVisible="{Binding DataContext.IsShowingSections, RelativeSource={RelativeSource AncestorType=UserControl}}" />
				<views:MeetingListView DataContext="{Binding MeetingListVm}" IsVisible="{Binding DataContext.IsShowingMeetings, RelativeSource={RelativeSource AncestorType=UserControl}}" />
			</StackPanel>
		</ScrollViewer>

	</Grid>

</UserControl>
