<!-- ONE-TIME MIGRATION UTILITY — DELETE AFTER USE -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SchedulingAssistant.Views.MigrationView"
             x:CompileBindings="False">

    <ScrollViewer>
        <StackPanel Spacing="0" Margin="24,16" MaxWidth="640">

            <!-- ── Section 1: XYZ_FLOW_YEARS ─────────────────────────────── -->
            <TextBlock FontSize="{StaticResource FontSizeLarge}"
                       FontWeight="SemiBold"
                       Text="1 · Academic Years  (XYZ_FLOW_YEARS)" />

            <TextBlock Margin="0,4,0,12"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Text="Columns used: AcademicYearKey (filename) · JsonData (content). Writes one .json per row." />

            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <TextBox Grid.Column="0"
                         IsReadOnly="True"
                         Text="{Binding YearsCsvPath}"
                         Watermark="No file chosen — click Browse…"
                         FontSize="{StaticResource FontSizeNormal}" />
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Content="Browse…"
                        Command="{Binding BrowseYearsCsvCommand}"
                        Padding="12,4"
                        FontSize="{StaticResource FontSizeNormal}" />
            </Grid>

            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,8"
                       IsVisible="{Binding YearsOutputDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Text="{Binding YearsOutputDir, StringFormat='Output:  {0}'}"
                       TextTrimming="CharacterEllipsis" />

            <Button Content="Convert Years to JSON"
                    Command="{Binding ConvertYearsCommand}"
                    IsEnabled="{Binding !IsYearsRunning}"
                    Margin="0,0,0,8"
                    MinWidth="180" Padding="16,6"
                    FontSize="{StaticResource FontSizeNormal}" />

            <ScrollViewer MaxHeight="240" Margin="0,0,0,4"
                          IsVisible="{Binding YearsStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding YearsStatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontFamily="Courier New, Consolas, Menlo, monospace"
                           Foreground="{StaticResource TextPrimary}" />
            </ScrollViewer>

            <!-- ── Divider ─────────────────────────────────────────────────── -->
            <Border Margin="0,16,0,16"
                    Height="1"
                    Background="{StaticResource SeparatorLine}" />

            <!-- ── Section 2: XYZ_UNITS ──────────────────────────────────── -->
            <TextBlock FontSize="{StaticResource FontSizeLarge}"
                       FontWeight="SemiBold"
                       Text="2 · Academic Units  (XYZ_UNITS)" />

            <TextBlock Margin="0,4,0,12"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Text="Columns used: AcademicUnitName (filename) · PermanentProperties (content). Writes one .json per row." />

            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <TextBox Grid.Column="0"
                         IsReadOnly="True"
                         Text="{Binding UnitsCsvPath}"
                         Watermark="No file chosen — click Browse…"
                         FontSize="{StaticResource FontSizeNormal}" />
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Content="Browse…"
                        Command="{Binding BrowseUnitsCsvCommand}"
                        Padding="12,4"
                        FontSize="{StaticResource FontSizeNormal}" />
            </Grid>

            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,8"
                       IsVisible="{Binding UnitsOutputDir, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Text="{Binding UnitsOutputDir, StringFormat='Output:  {0}'}"
                       TextTrimming="CharacterEllipsis" />

            <Button Content="Convert Units to JSON"
                    Command="{Binding ConvertUnitsCommand}"
                    IsEnabled="{Binding !IsUnitsRunning}"
                    Margin="0,0,0,8"
                    MinWidth="180" Padding="16,6"
                    FontSize="{StaticResource FontSizeNormal}" />

            <ScrollViewer MaxHeight="240"
                          IsVisible="{Binding UnitsStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding UnitsStatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontFamily="Courier New, Consolas, Menlo, monospace"
                           Foreground="{StaticResource TextPrimary}" />
            </ScrollViewer>

            <!-- ── Divider ─────────────────────────────────────────────────── -->
            <Border Margin="0,24,0,16"
                    Height="1"
                    Background="{StaticResource SeparatorLine}" />

            <!-- ── Section 3: Phase 2 — JSON → new schema ─────────────────── -->
            <TextBlock FontSize="{StaticResource FontSizeLarge}"
                       FontWeight="SemiBold"
                       Text="3 · Import into Database  (Phase 2)" />

            <TextBlock Margin="0,4,0,12"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Text="Point at both json-output folders produced by steps 1 and 2 above. Run a dry run first to review what will be imported, then click Import to write to the database." />

            <!-- Units JSON folder -->
            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"
                       Text="Units JSON folder (XYZ_UNITS output):" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBox Grid.Column="0"
                         IsReadOnly="True"
                         Text="{Binding Phase2UnitsJsonDir}"
                         Watermark="No folder chosen — click Browse…"
                         FontSize="{StaticResource FontSizeNormal}" />
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Content="Browse…"
                        Command="{Binding BrowsePhase2UnitsDirCommand}"
                        Padding="12,4"
                        FontSize="{StaticResource FontSizeNormal}" />
            </Grid>

            <!-- Years JSON folder -->
            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,4"
                       Text="Years JSON folder (XYZ_FLOW_YEARS output):" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBox Grid.Column="0"
                         IsReadOnly="True"
                         Text="{Binding Phase2YearsJsonDir}"
                         Watermark="No folder chosen — click Browse…"
                         FontSize="{StaticResource FontSizeNormal}" />
                <Button Grid.Column="1" Margin="8,0,0,0"
                        Content="Browse…"
                        Command="{Binding BrowsePhase2YearsDirCommand}"
                        Padding="12,4"
                        FontSize="{StaticResource FontSizeNormal}" />
            </Grid>

            <!-- Dry Run / Import buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <Button Content="Dry Run"
                        Command="{Binding Phase2DryRunCommand}"
                        MinWidth="120" Padding="16,6"
                        FontSize="{StaticResource FontSizeNormal}" />

                <Button Content="Import"
                        Command="{Binding Phase2ImportCommand}"
                        MinWidth="120" Padding="16,6"
                        FontSize="{StaticResource FontSizeNormal}" />
            </StackPanel>

            <!-- Status / report -->
            <ScrollViewer MaxHeight="360"
                          IsVisible="{Binding Phase2StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding Phase2StatusMessage}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontFamily="Courier New, Consolas, Menlo, monospace"
                           Foreground="{StaticResource TextPrimary}" />
            </ScrollViewer>

            <!-- ── Divider ─────────────────────────────────────────────────── -->
            <Border Margin="0,24,0,16"
                    Height="1"
                    Background="{StaticResource SeparatorLine}" />

            <!-- ── Section 4: Meeting-time validator ─────────────────────── -->
            <TextBlock FontSize="{StaticResource FontSizeLarge}"
                       FontWeight="SemiBold"
                       Text="4 · Validate Meeting Times" />

            <TextBlock Margin="0,4,0,12"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap"
                       Text="Scans every section in the current database and flags meetings whose block length or start time doesn't match the academic year's legal schedule matrix. For each flagged section, choose an action and click Apply Fixes." />

            <!-- Scan button + status -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <Button Content="Seed Legal Start Times"
                        Command="{Binding SeedMissingLegalStartTimesCommand}"
                        ToolTip.Tip="Seeds the default block-length/start-time matrix for any academic year that doesn't have one yet. Run this first if the scan reports skipped years."
                        MinWidth="200" Padding="16,6"
                        FontSize="{StaticResource FontSizeNormal}" />

                <Button Content="Scan"
                        Command="{Binding ScanInvalidMeetingsCommand}"
                        MinWidth="100" Padding="16,6"
                        FontSize="{StaticResource FontSizeNormal}" />

                <Button Content="Apply Fixes"
                        Command="{Binding ApplyMeetingFixesCommand}"
                        MinWidth="120" Padding="16,6"
                        FontSize="{StaticResource FontSizeNormal}"
                        IsVisible="{Binding InvalidMeetingItems.Count}" />
            </StackPanel>

            <TextBlock Text="{Binding MeetingScanStatus}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondary}"
                       IsVisible="{Binding MeetingScanStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- One row per flagged section -->
            <ItemsControl ItemsSource="{Binding InvalidMeetingItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6"
                                Padding="10,8"
                                CornerRadius="4"
                                Background="{StaticResource EditorBackground}">
                            <StackPanel Spacing="6">

                                <!-- Section identifier -->
                                <TextBlock Text="{Binding SectionLabel}"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           FontWeight="SemiBold" />

                                <!-- Bad meeting times -->
                                <TextBlock FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{StaticResource TextValidationError}"
                                           TextWrapping="Wrap">
                                    <Run Text="Bad meetings: " />
                                    <Run Text="{Binding BadMeetingsLabel}" />
                                </TextBlock>

                                <!-- Action picker -->
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Action:"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeSmall}" />
                                    <ComboBox ItemsSource="{Binding AllActions}"
                                              SelectedItem="{Binding SelectedAction}"
                                              MinWidth="180"
                                              FontSize="{StaticResource FontSizeSmall}" />
                                </StackPanel>

                                <!-- Time pickers — visible only when ReviseTime is chosen -->
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding ShowTimePickers}">
                                    <TextBlock Text="Block length (hrs):"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeSmall}" />
                                    <ComboBox ItemsSource="{Binding LegalBlockLengths}"
                                              SelectedItem="{Binding SelectedBlockLength}"
                                              MinWidth="80"
                                              FontSize="{StaticResource FontSizeSmall}" />

                                    <TextBlock Text="Start (min):"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               FontSize="{StaticResource FontSizeSmall}" />
                                    <ComboBox ItemsSource="{Binding LegalStartTimesForBlock}"
                                              SelectedItem="{Binding SelectedStartTime}"
                                              MinWidth="80"
                                              FontSize="{StaticResource FontSizeSmall}" />
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>
