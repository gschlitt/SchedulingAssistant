<UserControl
    x:Class="SchedulingAssistant.Views.Management.NewDatabaseView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:NewDatabaseViewModel">

    <StackPanel
        MaxWidth="700"
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="14">

        <TextBlock
            FontSize="{StaticResource FontSizeLarge}"
            FontWeight="SemiBold"
            Text="Create New Database" />

        <TextBlock
            FontSize="{StaticResource FontSizeNormal}"
            Text="This facility creates a new database. It does not copy the scheduling data from an existing database. You can however choose to copy your current scheduling configuration (block lengths, start times, block patterns, semester names etc.) into the new database, so you don't have to set it up from scratch."
            TextWrapping="Wrap" />

        <!--  Database name  -->
        <StackPanel Spacing="4">
            <TextBlock
                FontSize="{StaticResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Database name" />
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Text="A short label used as the filename (e.g. CS → CS-TT.db)."
                TextWrapping="Wrap" />
            <TextBox Text="{Binding DbName}" PlaceholderText="e.g. CS" />
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{StaticResource MutedText}"
                IsVisible="{Binding DbFullPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Text="{Binding DbFullPath, StringFormat='Will save as: {0}'}" />
        </StackPanel>

        <!--  Database folder  -->
        <StackPanel Spacing="4">
            <TextBlock
                FontSize="{StaticResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Database folder" />
            <DockPanel>
                <Button
                    Margin="6,0,0,0"
                    Command="{Binding BrowseDbFolderCommand}"
                    Content="Browse…"
                    DockPanel.Dock="Right" />
                <TextBox
                    IsReadOnly="True"
                    Text="{Binding DbFolder}"
                    PlaceholderText="Choose a folder…" />
            </DockPanel>
        </StackPanel>

        <!--  Backup folder  -->
        <StackPanel Spacing="4">
            <TextBlock
                FontSize="{StaticResource FontSizeNormal}"
                FontWeight="SemiBold"
                Text="Backup folder" />
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Text="Automatic backups are saved here."
                TextWrapping="Wrap" />
            <DockPanel>
                <Button
                    Margin="6,0,0,0"
                    Command="{Binding BrowseBackupFolderCommand}"
                    Content="Browse…"
                    DockPanel.Dock="Right" />
                <TextBox
                    IsReadOnly="True"
                    Text="{Binding BackupFolder}"
                    PlaceholderText="Choose a folder…" />
            </DockPanel>
            <TextBlock
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{StaticResource NotificationInfoBackground}"
                IsVisible="{Binding SameFolderWarning}"
                Text="Recommendation: choose a different folder for backups than the database itself."
                TextWrapping="Wrap" />
        </StackPanel>

        <Separator />

        <!--  Transfer configuration  -->
        <StackPanel Spacing="6">
            <CheckBox Content="Transfer configuration from current database" IsChecked="{Binding TransferConfig}" />

            <Border
                Margin="20,0,0,0"
                Padding="10"
                Background="{StaticResource FilterBarBackground}"
                CornerRadius="4"
                IsVisible="{Binding TransferConfig}">
                <StackPanel Spacing="8">

                    <!--  Source notice — names the AY so the user can verify it is the right one  -->
                    <TextBlock
                        FontSize="{StaticResource FontSizeNormal}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource NotificationInfoText}"
                        Text="{Binding ConfigSourceLabel}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        FontSize="{StaticResource FontSizeNormal}"
                        Text="Transferring your configuration copies campuses, section prefixes/designators, block patterns, block lengths and legal start times, and semester templates (names and colors). It does not copy courses, instructors, sections or any other scheduling data. A configuration source year is used because block lengths/start times and semester names can vary with academic year."
                        TextWrapping="Wrap" />
                    <!--  First AY name — only shown when there is no config source to copy from  -->
                    <StackPanel IsVisible="{Binding ShowFirstAcademicYearField}" Spacing="4">
                        <TextBlock
                            FontSize="{StaticResource FontSizeSmall}"
                            FontWeight="SemiBold"
                            Text="Starting academic year" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeSmall}"
                            Text="Type just the start year (e.g. 2025) and it will expand to 2025-2026 automatically when you leave the field."
                            TextWrapping="Wrap" />
                        <TextBox
                            b:LostFocusCommandBehavior.Command="{Binding CommitFirstAcademicYearNameCommand}"
                            Text="{Binding FirstAcademicYearName}"
                            PlaceholderText="e.g. 2025  or  2025-2026" />
                        <TextBlock
                            FontSize="{StaticResource FontSizeSmall}"
                            Foreground="{StaticResource NotificationInfoText}"
                            IsVisible="{Binding FirstAcademicYearNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Text="{Binding FirstAcademicYearNameError}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                </StackPanel>
            </Border>
        </StackPanel>

        <!--  Error message  -->
        <TextBlock
            FontSize="{StaticResource FontSizeSmall}"
            Foreground="{StaticResource NotificationErrorText}"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Text="{Binding ErrorMessage}"
            TextWrapping="Wrap" />

        <!--  Create button  -->
        <Button
            Command="{Binding CreateDatabaseCommand}"
            Content="Create"
            IsEnabled="{Binding CanCreate}" />

    </StackPanel>

</UserControl>
