<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.SectionPropertyListView"
             x:DataType="vm:SectionPropertyListViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto" MaxWidth="420">

        <TextBlock Grid.Row="0" Text="{Binding DisplayName}"
                   FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

        <!-- Edit form (shown when EditVm is not null) -->
        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SectionPropertyEditViewModel}">
                    <StackPanel Spacing="10" MaxWidth="320" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Name" />
                        <TextBox Text="{Binding Name}" />
                        <TextBlock Text="{Binding ValidationError}"
                                   Foreground="{StaticResource TextError}" FontSize="12"
                                   IsVisible="{Binding ValidationError,
                                       Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <!-- Abbreviation field — only shown for Campus -->
                        <StackPanel IsVisible="{Binding ShowAbbreviation}" Spacing="4">
                            <TextBlock Text="Section Code Abbreviation" />
                            <TextBox Text="{Binding Abbreviation}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save" Command="{Binding SaveCommand}" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- List + move buttons (shown when EditVm is null) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto"
              IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="False">
                <DataGrid.Styles>
                    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                        <Setter Property="Fill" Value="{StaticResource ButtonBackground}" />
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Abbreviation"
                                        Binding="{Binding SectionCodeAbbreviation}"
                                        Width="140"
                                        IsVisible="{Binding $parent[UserControl].DataContext.ShowAbbreviation}" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Up/Down ordering buttons, aligned to top-right of the list -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4"
                        Margin="6,0,0,0" VerticalAlignment="Top">
                <Button Content="↑" Command="{Binding MoveUpCommand}" />
                <Button Content="↓" Command="{Binding MoveDownCommand}" />
            </StackPanel>

        </Grid>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">
            <Button Content="Add" Command="{Binding AddCommand}" />
            <Button Content="Edit" Command="{Binding EditCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>

    </Grid>
</UserControl>
