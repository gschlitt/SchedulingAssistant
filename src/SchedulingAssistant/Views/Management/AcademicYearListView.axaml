<UserControl
    x:Class="SchedulingAssistant.Views.Management.AcademicYearListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:AcademicYearListViewModel">

    <UserControl.Styles>
        <Style Selector="DataGrid DataGridRow:selected">
            <Setter Property="Background" Value="#FFE0E0E0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Add Academic Year form (shown while EditVm is active) -->
        <ContentControl
            Grid.Row="1"
            Margin="10,0"
            Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:AcademicYearEditViewModel}">
                    <StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Add Academic Year" />
                        <TextBlock Text="Enter the calendar year in which the new academic year begins (e.g. 2024 for 2024-2025)" TextWrapping="Wrap" />
                        <TextBox Text="{Binding Name}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding ValidationError}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding SaveCommand}" Content="Apply" />
                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- Two-column layout: AY list (left) + Semester manager (right) -->
        <Grid
            Grid.Row="1"
            Margin="10,0,10,0"
            ColumnDefinitions="280,Auto,*"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">

            <!-- Left: Academic Year list -->
            <DataGrid
                Grid.Column="0"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                IsReadOnly="True"
                ItemsSource="{Binding AcademicYears}"
                SelectedItem="{Binding SelectedAcademicYear}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="Academic Year" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Divider -->
            <Border
                Grid.Column="1"
                Width="1"
                Margin="12,0"
                Background="{StaticResource MenuBorderBrush}" />

            <!-- Right: Semester manager for selected year -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    IsVisible="{Binding SemesterManager, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Text="Semesters" />
                <ContentControl Grid.Row="1" Content="{Binding SemesterManager}" />
            </Grid>

        </Grid>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="2"
            Margin="10,12,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding AddCommand}" Content="Add" />
            <Button
                Command="{Binding DeleteCommand}"
                Content="Delete"
                IsEnabled="{Binding SelectedAcademicYear, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Command="{Binding CopySemesterCommand}" Content="Copy Semester" />
            <Button Command="{Binding EmptySemesterCommand}" Content="Empty Semester" />
        </StackPanel>

    </Grid>
</UserControl>
