<UserControl
    x:Class="SchedulingAssistant.Views.Management.AcademicYearListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    x:DataType="vm:AcademicYearListViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Add Academic Year form (shown while EditVm is active) -->
        <ContentControl
            Grid.Row="1"
            Margin="10,0"
            Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:AcademicYearEditViewModel}">
                    <StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Add Academic Year" />
                        <TextBlock Text="Enter the calendar year in which the new academic year begins (e.g. 2024 for 2024-2025)" TextWrapping="Wrap" />
                        <TextBox Text="{Binding Name}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding ValidationError}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding SaveCommand}" Content="Apply"/>
                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- Two-column layout: AY list (left) + Semester manager (right) -->
        <Grid 
            Grid.Row="1"
            Margin="10,0,10,0"
            ColumnDefinitions="340,10,200" RowDefinitions="Auto,*"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">

            <TextBlock Text="Academic Years" Grid.Row="0" FontWeight="SemiBold" />

            <!-- Left: Academic Year list -->
            <DataGrid
                Grid.Column="0" Grid.Row="1"
                AutoGenerateColumns="False"
                
                IsReadOnly="True"
                ItemsSource="{Binding AcademicYears}"
                SelectedItem="{Binding SelectedAcademicYear}"
               >
                 <!-- Workaround: HeadersVisibility="None" crashes Avalonia 12 WASM.
                     Hide the header row by collapsing its height instead. -->
                <DataGrid.Styles>
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="Height" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                         />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Divider -->
            <Border
                Grid.Column="1"
                Width="1"
                Margin="12,0"
                Background="{StaticResource MenuBorderBrush}" />

            <!-- Right: Semester manager for selected year -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                IsVisible="{Binding SemesterManager, Converter={x:Static ObjectConverters.IsNotNull}}"
                Text="{Binding SelectedAcademicYear.Name}" />
            <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding SemesterManager}" />

        </Grid>

        <!-- Toolbar -->
       <StackPanel
            Grid.Row="2"
            Margin="10,12,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding AddCommand}" Content="Add" />
            <Button
                Command="{Binding DeleteCommand}"
                Content="Delete"
                IsEnabled="{Binding SelectedAcademicYear, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Command="{Binding CopySemesterCommand}" Content="Copy" b:HelpTip.Text="Copy sections from one academic year to another. Copying is done one semester at a time" />
            <Button Command="{Binding EmptySemesterCommand}" Content="Empty" b:HelpTip.Text="Empty an academic year of sections. Emptying is done one semester at a time."/>
        </StackPanel>
        <!--  Inline error message  -->
        <TextBlock
            FontSize="10"
            Foreground="{StaticResource TextError}"
            IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
            Text="{Binding LastErrorMessage}"
            TextWrapping="Wrap"
            Margin="0,4,0,0" />

    </Grid>
</UserControl>
