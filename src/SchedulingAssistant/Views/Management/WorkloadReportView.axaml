<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.WorkloadReportView"
             x:DataType="vm:WorkloadReportViewModel"
             x:CompileBindings="False">

    <StackPanel Spacing="16" MaxWidth="420">

        <TextBlock Text="Workload Report" FontSize="13" FontWeight="SemiBold" />

        <Border Background="{StaticResource FilterBarBackground}"
                CornerRadius="4" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock FontSize="11" TextWrapping="Wrap"
                           Text="Exports a CSV summary of credited workload for all active instructors across semesters in the current academic year." />
                <Button Content="Choose file and export…"
                        Command="{Binding ExportWorkloadReportCommand}"
                        IsEnabled="{Binding !IsExporting}"
                        Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <TextBlock Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="11" TextWrapping="Wrap" />

    </StackPanel>

</UserControl>
