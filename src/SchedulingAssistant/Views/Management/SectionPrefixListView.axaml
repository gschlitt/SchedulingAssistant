<UserControl
    x:Class="SchedulingAssistant.Views.Management.SectionPrefixListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:SectionPrefixListViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <StackPanel
            Grid.Row="0"
            Margin="10,0"
            Spacing="8">
            <TextBlock
                MaxWidth="1000"
                HorizontalAlignment="Left"
                FontSize="{DynamicResource FontSizeNormal}"
                TextWrapping="Wrap">
                Institutions often place a prefix on their section designators, to indicate
                a campus, delivery mode, or other aspect of the section. Registering your institution's section prefixes and designators here can greatly speed
                up editing of sections. If you associate a campus with a section prefix, that campus is automatically selected for any section using that prefix.
            </TextBlock>

            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="The following examples of sections of the " />
                <Border Padding="2,0" Background="{StaticResource PrefixCampusABackground}">
                    <TextBlock Text="course" />
                </Border>
                <TextBlock Text=" PSYC 101 show various forms of " />
                <Border Padding="2,0" Background="{StaticResource PrefixCampusBBackground}">
                    <TextBlock Text="section prefix" />
                </Border>
                <TextBlock Text=" and " />
                <Border Padding="2,0" Background="LightSalmon">
                    <TextBlock Text="section designator" />
                </Border>
                <TextBlock Text="." />
            </WrapPanel>
        </StackPanel>

        <!--  Examples list  -->
        <Grid
            Grid.Row="1"
            Margin="10,10,0,0"
            ColumnDefinitions="150,500"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            ShowGridLines="False">

            <!--  First example of a section  -->
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="AB-" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LIghtSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="1" />
                </Border>
            </StackPanel>

            <!--  Second example of a section  -->
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="AB-" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LIghtSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="2" />
                </Border>
            </StackPanel>

            <!--  Comment on first pair  -->
            <WrapPanel
                Grid.RowSpan="2"
                Grid.Column="1"
                Width="400"
                Margin="20,0"
                VerticalAlignment="Top">
                <TextBlock Text="The" />
                <Border Padding="2,0" Background="{StaticResource PrefixCampusBBackground}">
                    <TextBlock Text="section prefix" />
                </Border>
                <TextBlock Text=" designates campus. The" />
                <Border Padding="2,0" Background="LightSalmon">
                    <TextBlock Text="section designator " />
                </Border>
                <TextBlock Text="is a number." />
            </WrapPanel>


            <!--  Third example of a section  -->
            <StackPanel
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,10,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="TUT" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LIghtSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="A" />
                </Border>
            </StackPanel>
            <!--  Fourth example of a section  -->
            <StackPanel
                Grid.Row="3"
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="TUT" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LightSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="B" />
                </Border>
            </StackPanel>

            <!--  Comment on second pair  -->
            <WrapPanel
                Grid.Row="2"
                Grid.RowSpan="2"
                Grid.Column="1"
                Width="400"
                Margin="0,10,0,0"
                VerticalAlignment="Top">
                <TextBlock Text="The" />
                <Border Padding="2,0" Background="{StaticResource PrefixCampusBBackground}">
                    <TextBlock Text="section prefix" />
                </Border>
                <TextBlock Text=" designates a tutorial. The" />
                <Border Padding="2,0" Background="LightSalmon">
                    <TextBlock Text="section designator " />
                </Border>
                <TextBlock Text="is a letter." />
            </WrapPanel>

            <!--  Fifth example of a section  -->
            <StackPanel
                Grid.Row="4"
                Grid.Column="0"
                Margin="0,10,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="A#" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LIghtSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="4" />
                </Border>
            </StackPanel>
            <!--  Sixth example of a section  -->
            <StackPanel
                Grid.Row="5"
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="0">
                <Border
                    Padding="5,2"
                    Background="{StaticResource PrefixCampusABackground}"
                    CornerRadius="2,0,0,2">
                    <TextBlock FontSize="{DynamicResource FontSizeNormal}" Text="PSYC 101 " />
                </Border>
                <Border
                    Padding="0"
                    Background="{StaticResource PrefixCampusBBackground}"
                    CornerRadius="0">
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="A#" />
                </Border>
                <Border
                    Padding="0,0,1,0"
                    Background="LIghtSalmon"
                    CornerRadius="0,2,2,0">
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{DynamicResource FontSizeNormal}"
                        Text="5" />
                </Border>
            </StackPanel>

            <!--  Comment on third pair  -->
            <WrapPanel
                Grid.Row="4"
                Grid.RowSpan="2"
                Grid.Column="1"
                Width="400"
                Margin="0,10,0,0"
                VerticalAlignment="Top">
                <TextBlock Text="The" />
                <Border Padding="2,0" Background="{StaticResource PrefixCampusBBackground}">
                    <TextBlock Text="section prefix " />
                </Border>
                <TextBlock Text="designates some other section aspect. The" />
                <Border Padding="2,0" Background="LightSalmon">
                    <TextBlock Text="section designator " />
                </Border>
                <TextBlock Text="is a number." />
            </WrapPanel>


            <TextBlock
                Grid.Row="6"
                Grid.ColumnSpan="2"
                MaxWidth="1200"
                HorizontalAlignment="Left"
                TextWrapping="Wrap">
                Supply your institution's section prefixes below. Indicate also whether your designators are numbers or letters. If your insitution does not use section prefixes or uses a format that does not fit these patterns, leave the list empty and just choose the designator. If your section prefix is linked to  a campus indicate that here.
            </TextBlock>
        </Grid>

        <!--  Edit form (shown when EditVm is not null)  -->
        <ContentControl
            Grid.Row="2"
            Grid.RowSpan="2"
            Margin="10,30"
            Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SectionPrefixEditViewModel}">
                    <StackPanel
                        MaxWidth="320"
                        HorizontalAlignment="Left"
                        Spacing="10">

                        <TextBlock
                            FontSize="{StaticResource FontSizeLarge}"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />

                        <TextBlock FontWeight="SemiBold" Text="Prefix" />
                        <TextBox Text="{Binding Prefix}" />

                        <TextBlock
                            FontSize="{StaticResource FontSizeNormal}"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding ValidationError}" />

                        <!--  Designator type  -->


                        <TextBlock FontWeight="SemiBold" Text="Section designator" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton
                                Content="Number (e.g. 1, 17)"
                                GroupName="DesignatorType"
                                IsChecked="{Binding IsNumberDesignator}" />
                            <RadioButton
                                Content="Letter (e.g. A, C)"
                                GroupName="DesignatorType"
                                IsChecked="{Binding IsLetterDesignator}" />
                        </StackPanel>

                        <TextBlock Text="Campus (optional)" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding CampusOptions}"
                            SelectedItem="{Binding SelectedCampus}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CampusOption}">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                        <StackPanel
                            Margin="0,4,0,0"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button Command="{Binding SaveCommand}" Content="Apply" />
                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        </StackPanel>

                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>




        <!--  List (shown when EditVm is null)  -->
        <DataGrid
            Grid.Row="2"
            Grid.RowSpan="2"
            Width="420"
            Margin="10,30"
            HorizontalAlignment="Left"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            IsReadOnly="True"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding Prefix.Prefix}"
                    Header="Prefix" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding DesignatorTypeDisplay}"
                    Header="Designator" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding CampusName}"
                    Header="Campus" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Toolbar  -->
        <StackPanel
            Grid.Row="4"
            Margin="10,0,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding AddCommand}" Content="Add" />
            <Button
                Command="{Binding EditCommand}"
                Content="Edit"
                IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button
                Command="{Binding DeleteCommand}"
                Content="Delete"
                IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>

    </Grid>

</UserControl>
