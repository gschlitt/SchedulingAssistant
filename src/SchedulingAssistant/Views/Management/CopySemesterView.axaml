<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.CopySemesterView"
             x:DataType="vm:CopySemesterViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,0">

        <TextBlock Grid.Row="0" Text="Copy Semester" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />

        <!-- Two-column layout: From and To -->
        <Grid Grid.Row="1" ColumnDefinitions="*,16,*" Margin="0,0,0,16"
              IsVisible="{Binding IsReady}"
              IsEnabled="{Binding IsWriteEnabled}">

            <!-- From column -->
            <DockPanel Grid.Column="0" Margin="0,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="From" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="Academic Year" FontSize="12" />
                    <ComboBox ItemsSource="{Binding AcademicYears}"
                              SelectedItem="{Binding FromAcademicYear}"
                              Margin="0,0,0,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Spacing="8">
                    <TextBlock Text="Semester" FontSize="12" />
                    <ComboBox ItemsSource="{Binding FromSemesters}"
                              SelectedItem="{Binding FromSemester}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DockPanel>

            <!-- To column -->
            <DockPanel Grid.Column="2" Margin="0,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="To" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
                    <TextBlock Text="Academic Year" FontSize="12" />
                    <ComboBox ItemsSource="{Binding AcademicYears}"
                              SelectedItem="{Binding ToAcademicYear}"
                              Margin="0,0,0,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Spacing="8">
                    <TextBlock Text="Semester" FontSize="12" />
                    <ComboBox ItemsSource="{Binding ToSemesters}"
                              SelectedItem="{Binding ToSemester}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </DockPanel>

        </Grid>

        <!-- Copy options -->
        <StackPanel Grid.Row="2" Spacing="3" Margin="0,0,0,12"
                    IsVisible="{Binding IsReady}"
                    IsEnabled="{Binding IsWriteEnabled}">
            <CheckBox Content="Copy section designations only"
                      IsChecked="{Binding CopyDesignationsOnly}" />
            <CheckBox Content="Copy section designations and:"
                      IsChecked="{Binding CopyAndMore}" />

            <!-- Sub-options (indented, enabled when CopyAndMore is checked) -->
            <StackPanel Margin="22,0,0,0" Spacing="3"
                        IsEnabled="{Binding AreSubOptionsEnabled}">
                <CheckBox Content="Include any section type assignments"
                          IsChecked="{Binding IncludeSectionType}" />
                <CheckBox Content="Include all assigned tags"
                          IsChecked="{Binding IncludeAllTags}" />
                <CheckBox Content="Include all staff members assigned to each section"
                          IsChecked="{Binding IncludeAllStaff}" />
                <CheckBox Content="Include all section meeting times and:"
                          IsChecked="{Binding IncludeAllMeetingTimes}" />

                <!-- Meeting sub-options (further indented, enabled when IncludeAllMeetingTimes is checked) -->
                <StackPanel Margin="22,0,0,0" Spacing="3"
                            IsEnabled="{Binding AreMeetingSubOptionsEnabled}">
                    <CheckBox Content="Include any room assignments"
                              IsChecked="{Binding IncludeRoomAssignments}" />
                    <CheckBox Content="Include any meeting type assignments"
                              IsChecked="{Binding IncludeMeetingTypeAssignments}" />
                </StackPanel>

                <CheckBox Content="Include all reserves"
                          IsChecked="{Binding IncludeAllReserves}" />
            </StackPanel>
        </StackPanel>

        <!-- Flagged sections warning panel -->
        <StackPanel Grid.Row="3" Spacing="8" Margin="0,0,0,12"
                    IsVisible="{Binding IsFlaggedWarning}">
            <TextBlock Text="The following sections have meeting times incompatible with the destination academic year's start time configuration. Their schedules will be removed during copy."
                       TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextValidationError}" />

            <ItemsControl ItemsSource="{Binding FlaggedDescriptions}" Margin="8,0,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="11" Margin="0,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <CheckBox Content="Write flagged sections report (.csv)"
                      IsChecked="{Binding WriteCsvReport}"
                      FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Status message -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   TextWrapping="Wrap" FontSize="12" Margin="0,0,0,8" />

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,0,0,0"
                    IsEnabled="{Binding IsWriteEnabled}">
            <!-- Ready state buttons -->
            <Button Content="Copy" Command="{Binding CopyCommand}"
                    IsEnabled="{Binding IsCopyEnabled}"
                    IsVisible="{Binding IsReady}" />
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsReady}" />

            <!-- Flagged warning state buttons -->
            <Button Content="Abort" Command="{Binding AbortCopyCommand}"
                    IsVisible="{Binding IsFlaggedWarning}" />
            <Button Content="Continue" Command="{Binding ContinueCopyCommand}"
                    IsVisible="{Binding IsFlaggedWarning}" />

            <!-- Complete state button -->
            <Button Content="Done" Command="{Binding DoneCommand}"
                    IsVisible="{Binding IsComplete}" />
        </StackPanel>

    </Grid>
</UserControl>
