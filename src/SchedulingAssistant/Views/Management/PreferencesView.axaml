<UserControl
    x:Class="SchedulingAssistant.Views.Management.PreferencesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:PreferencesViewModel">

   

    <StackPanel
        MaxWidth="500"
        Margin="10,0"
        HorizontalAlignment="Left"
        Spacing="24">

        <!--  Page title  -->
        <TextBlock
            FontSize="{StaticResource FontSizeXLarge}"
            FontWeight="SemiBold"
            Text="Preferences" />

        <!--  ═══ Section View ═══════════════════════════════════════  -->
        <StackPanel Spacing="12">

            <!--  Sub-heading + rule  -->
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Section View" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <!--  Open with all sections collapsed  -->
           
            <CheckBox 
                Content="Open with all sections collapsed"
                IsChecked="{Binding OpenWithAllSectionsCollapsed}">
                 <CheckBox.Styles>
             <Style Selector="CheckBox /template/ Border#NormalRectangle">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
              </Style>
           </CheckBox.Styles>                
                </CheckBox>
               

            <!--  Filter pass behavior  -->
           
            <StackPanel Spacing="6">
                <TextBlock Text="When a filter passes a section:" />
                <RadioButton 
                    
                    GroupName="FilterPassBehavior"
                    IsChecked="{Binding FilterHighlightsSection}">
                    <RadioButton.Content>
					Highlight the section
                    </RadioButton.Content>
                    </RadioButton>
                <RadioButton
                    Content="Expand the section (and collapse the others)"
                    GroupName="FilterPassBehavior"
                    IsChecked="{Binding FilterExpandsSection}" />
            </StackPanel>

   <StackPanel Spacing="4">
                <TextBlock
                    FontSize="{StaticResource FontSizeLarge}"
                    FontWeight="SemiBold"
                    Text="Schedule View" />
                <Border
                    Height="1"
                    Background="{StaticResource SeparatorLine}"
                    Opacity="0.2" />
            </StackPanel>

            <StackPanel >
                <StackPanel Orientation="Horizontal">
                <TextBlock Text="Start with FontSize set to "/>
                  <ComboBox
                    Background="Transparent"
					x:Name="TileFontSizeBox"
					Width="52"
					Height="18"
					Padding="4,0"
					VerticalAlignment="Center"
					FontSize="10"
					ItemsSource="{Binding FontSizeOptions}"
					SelectedItem="{Binding TileFontSize, Mode=TwoWay}" />  
                </StackPanel>
              </StackPanel>

               

        </StackPanel>

    </StackPanel>
</UserControl>
