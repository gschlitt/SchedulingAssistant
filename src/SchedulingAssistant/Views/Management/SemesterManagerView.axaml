<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.SemesterManagerView"
             x:DataType="vm:SemesterManagerViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Inline Add / Rename form (shown when EditVm is not null) -->
        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SemesterEditViewModel}">
                    <StackPanel Spacing="10" MaxWidth="320" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Name" />
                        <TextBox Text="{Binding Name}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save" Command="{Binding SaveCommand}" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- List + move buttons (shown when EditVm is null) -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto"
              IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Semesters}"
                      SelectedItem="{Binding SelectedSemester}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="False">
                <DataGrid.Styles>
                    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                        <Setter Property="Fill" Value="{StaticResource ButtonBackground}" />
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </DataGrid.Styles>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Semester" Binding="{Binding Name}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Up/Down ordering buttons -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4"
                        Margin="6,0,0,0" VerticalAlignment="Top">
                <Button Content="↑" Command="{Binding MoveUpCommand}" />
                <Button Content="↓" Command="{Binding MoveDownCommand}" />
            </StackPanel>

        </Grid>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    IsEnabled="{Binding IsWriteEnabled}">
            <Button Content="Add" Command="{Binding AddCommand}" />
            <Button Content="Rename" Command="{Binding RenameCommand}"
                    IsEnabled="{Binding SelectedSemester, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding SelectedSemester, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>

    </Grid>
</UserControl>
