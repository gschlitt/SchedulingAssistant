<UserControl
    x:Class="SchedulingAssistant.Views.Management.SemesterManagerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:SemesterManagerViewModel">

    <UserControl.Resources>
        <!--  Template for the color swatch cell: a bordered rectangle that opens a ColorView flyout when clicked  -->
        <DataTemplate x:Key="ColorSwatchTemplate" DataType="vm:SemesterRowViewModel">
            <Button
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                ToolTip.Tip="Click to change color">
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedLeft">
                        <ColorView
                            Margin="4"
                            HexInputAlphaPosition="Trailing"
                            IsAccentColorsVisible="False"
                            IsAlphaEnabled="False"
                            IsAlphaVisible="False"
                            IsColorComponentsVisible="False"
                            IsColorModelVisible="False"
                            IsColorPaletteVisible="True"
                            IsColorPreviewVisible="False"
                            IsColorSpectrumSliderVisible="True"
                            IsColorSpectrumVisible="True"                            
                            Color="{Binding HexColor, Mode=TwoWay, Converter={StaticResource HexToColorConverter}}" />
                    </Flyout>
                </Button.Flyout>
                <Border
                    Width="48"
                    Height="18"
                    BorderBrush="{StaticResource SeparatorLine}"
                    BorderThickness="1"
                    CornerRadius="3">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding HexColor, Converter={StaticResource HexToColorConverter}}" />
                    </Border.Background>
                </Border>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!--  Inline Add / Rename form (shown when EditVm is not null)  -->
        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SemesterEditViewModel}">
                    <StackPanel
                        MaxWidth="320"
                        HorizontalAlignment="Left"
                        Spacing="10">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />
                        <TextBlock Text="Name" />
                        <TextBox Text="{Binding Name}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding SaveCommand}" Content="Apply" />
                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!--  List + move buttons (shown when EditVm is null)  -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,Auto"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">

            <DataGrid
                Grid.Column="0"
                AutoGenerateColumns="False"
                CanUserSortColumns="False"
                IsReadOnly="True"
                ItemsSource="{Binding Semesters}"
                SelectedItem="{Binding SelectedSemester}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Name}"
                        Header="Semester" />
                    <DataGridTemplateColumn
                        Width="60"
                        CellTemplate="{StaticResource ColorSwatchTemplate}"
                        Header="Color" />
                </DataGrid.Columns>
            </DataGrid>

            <!--  Up/Down ordering buttons  -->
            <StackPanel
                Grid.Column="1"
                Margin="6,0,0,0"
                VerticalAlignment="Top"
                Orientation="Vertical"
                Spacing="4">
                <Button Command="{Binding MoveUpCommand}" Content="↑" />
                <Button Command="{Binding MoveDownCommand}" Content="↓" />
            </StackPanel>

        </Grid>

        <!--  Toolbar  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding AddCommand}" Content="Add" />
            <Button
                Command="{Binding RenameCommand}"
                Content="Rename"
                IsEnabled="{Binding SelectedSemester, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button
                Command="{Binding DeleteCommand}"
                Content="Delete"
                IsEnabled="{Binding SelectedSemester, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>
        <!--  Inline error message  -->
        <TextBlock
            FontSize="10"
            Foreground="{StaticResource TextError}"
            IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
            Text="{Binding LastErrorMessage}"
            TextWrapping="Wrap"
            Margin="0,4,0,0" />

    </Grid>
</UserControl>
