<UserControl
    x:Class="SchedulingAssistant.Views.Management.BlockPatternListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:BlockPatternListViewModel">

    <StackPanel MaxWidth="500" Spacing="16">

        <TextBlock
            FontSize="{StaticResource FontSizeXLarge}"
            FontWeight="SemiBold"
            Text="Block Patterns" />

        <TextBlock
            FontSize="{StaticResource FontSizeNormal}"
            Foreground="{StaticResource TextLabel}"
            TextWrapping="Wrap">
            Save up to five favourite day patterns (e.g. "MW" for Monday/Wednesday) and apply them with one click when building a section schedule.
        </TextBlock>

        <ItemsControl ItemsSource="{Binding Slots}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="16" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:BlockPatternSlotViewModel}">
                    <Border
                        Padding="12"
                        BorderBrush="{StaticResource SubduedBorder}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Spacing="8">

                            <DockPanel>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    FontWeight="SemiBold"
                                    Text="{Binding Label}" />
                                <StackPanel
                                    DockPanel.Dock="Right"
                                    IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <Button
                                        Padding="8,3"
                                        Command="{Binding EditCommand}"
                                        Content="Edit"
                                        FontSize="{StaticResource FontSizeNormal}"
                                        IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                                    <Button
                                        Padding="8,3"
                                        Command="{Binding ClearCommand}"
                                        Content="Clear"
                                        FontSize="{StaticResource FontSizeNormal}"
                                        IsEnabled="{Binding Pattern, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </StackPanel>
                                <TextBlock
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSubtle}"
                                    Text="{Binding DisplayName}" />
                            </DockPanel>

                            <!--  Inline edit form  -->
                            <ContentControl Content="{Binding EditVm}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate DataType="{x:Type vm:BlockPatternEditViewModel}">
                                        <StackPanel Spacing="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="{StaticResource FontSizeSmall}"
                                                    Foreground="{StaticResource TextLabel}"
                                                    Text="Name" />
                                                <TextBox
                                                    Width="200"
                                                    HorizontalAlignment="Left"
                                                    FontSize="{StaticResource FontSizeNormal}"
                                                    Text="{Binding Name}" />
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="{StaticResource FontSizeSmall}"
                                                    Foreground="{StaticResource TextLabel}"
                                                    Text="Days" />
                                                <ItemsControl ItemsSource="{Binding Days}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="10" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:DayCheckViewModel}">
                                                            <CheckBox
                                                                Content="{Binding DayName}"
                                                                FontSize="{StaticResource FontSizeNormal}"
                                                                IsChecked="{Binding IsChecked}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <TextBlock
                                                FontSize="{StaticResource FontSizeSmall}"
                                                Foreground="{StaticResource TextValidationError}"
                                                IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Text="{Binding ValidationError}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button
                                                    Padding="10,4"
                                                    Command="{Binding SaveCommand}"
                                                    Content="Done" />
                                                <Button
                                                    Padding="10,4"
                                                    Command="{Binding CancelCommand}"
                                                    Content="Cancel" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
