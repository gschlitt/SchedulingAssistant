<UserControl
    x:Class="SchedulingAssistant.Views.Management.BlockPatternListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:BlockPatternListViewModel">

    <StackPanel MaxWidth="500" Spacing="16">

        <TextBlock
            FontSize="{DynamicResource FontSizeXLarge}"
            FontWeight="SemiBold"
            Text="Block Patterns" />

        <TextBlock
            FontSize="{DynamicResource FontSizeNormal}"
            Foreground="{StaticResource TextLabel}"
            TextWrapping="Wrap">
            Save up to five favourite day patterns (e.g. "MW" for Monday/Wednesday) and apply them with one click when building a section schedule.
        </TextBlock>

        <!--  Slot 1  -->
        <Border
            Padding="12"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel DataContext="{Binding Slot1}" Spacing="8">

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontWeight="SemiBold"
                        Text="Pattern 1" />
                    <StackPanel
                        DockPanel.Dock="Right"
                        IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="8,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                        <Button
                            Padding="8,3"
                            Command="{Binding ClearCommand}"
                            Content="Clear"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding Pattern, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSubtle}"
                        Text="{Binding DisplayName}" />
                </DockPanel>

                <!--  Inline edit form for Slot 1  -->
                <ContentControl Content="{Binding EditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:BlockPatternEditViewModel}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Name" />
                                    <TextBox
                                        Width="200"
                                        HorizontalAlignment="Left"
                                        FontSize="{DynamicResource FontSizeNormal}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Days" />
                                    <ItemsControl ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayCheckViewModel}">
                                                <CheckBox
                                                    Content="{Binding DayName}"
                                                    FontSize="{DynamicResource FontSizeNormal}"
                                                    IsChecked="{Binding IsChecked}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource TextValidationError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding ValidationError}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding SaveCommand}"
                                        Content="Save" />
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding CancelCommand}"
                                        Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </StackPanel>
        </Border>

        <!--  Slot 2  -->
        <Border
            Padding="12"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel DataContext="{Binding Slot2}" Spacing="8">

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontWeight="SemiBold"
                        Text="Pattern 2" />
                    <StackPanel
                        DockPanel.Dock="Right"
                        IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="8,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                        <Button
                            Padding="8,3"
                            Command="{Binding ClearCommand}"
                            Content="Clear"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding Pattern, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSubtle}"
                        Text="{Binding DisplayName}" />
                </DockPanel>

                <!--  Inline edit form for Slot 2  -->
                <ContentControl Content="{Binding EditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:BlockPatternEditViewModel}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Name" />
                                    <TextBox
                                        Width="200"
                                        HorizontalAlignment="Left"
                                        FontSize="{DynamicResource FontSizeNormal}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Days" />
                                    <ItemsControl ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayCheckViewModel}">
                                                <CheckBox
                                                    Content="{Binding DayName}"
                                                    FontSize="{DynamicResource FontSizeNormal}"
                                                    IsChecked="{Binding IsChecked}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource TextValidationError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding ValidationError}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding SaveCommand}"
                                        Content="Save" />
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding CancelCommand}"
                                        Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </StackPanel>
        </Border>

        <!--  Slot 3  -->
        <Border
            Padding="12"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel DataContext="{Binding Slot3}" Spacing="8">

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontWeight="SemiBold"
                        Text="Pattern 3" />
                    <StackPanel
                        DockPanel.Dock="Right"
                        IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="8,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                        <Button
                            Padding="8,3"
                            Command="{Binding ClearCommand}"
                            Content="Clear"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding Pattern, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <TextBlock
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSubtle}"
                        Text="{Binding DisplayName}" />
                </DockPanel>

                <!--  Inline edit form for Slot 3  -->
                <ContentControl Content="{Binding EditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:BlockPatternEditViewModel}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Name" />
                                    <TextBox
                                        Width="200"
                                        HorizontalAlignment="Left"
                                        FontSize="{DynamicResource FontSizeNormal}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Days" />
                                    <ItemsControl ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayCheckViewModel}">
                                                <CheckBox
                                                    Content="{Binding DayName}"
                                                    FontSize="{DynamicResource FontSizeNormal}"
                                                    IsChecked="{Binding IsChecked}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource TextValidationError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding ValidationError}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding SaveCommand}"
                                        Content="Save" />
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding CancelCommand}"
                                        Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </StackPanel>
        </Border>

        <!--  Slot 4  -->
        <Border
            Padding="12"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel DataContext="{Binding Slot4}" Spacing="8">

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontWeight="SemiBold"
                        Text="Pattern 4" />
                    <StackPanel
                        DockPanel.Dock="Right"
                        IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="8,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                        <Button
                            Padding="8,3"
