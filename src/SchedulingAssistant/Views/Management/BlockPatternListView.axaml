                                        Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
