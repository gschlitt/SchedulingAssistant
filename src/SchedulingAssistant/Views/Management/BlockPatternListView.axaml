                </DockPanel>

                <!--  Inline edit form for Slot 4  -->
                <ContentControl Content="{Binding EditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:BlockPatternEditViewModel}">
                            <StackPanel Spacing="8">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Name" />
                                    <TextBox
                                        Width="200"
                                        HorizontalAlignment="Left"
                                        FontSize="{DynamicResource FontSizeNormal}"
                                        Text="{Binding Name}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        Foreground="{StaticResource TextLabel}"
                                        Text="Days" />
                                    <ItemsControl ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayCheckViewModel}">
                                                <CheckBox
                                                    Content="{Binding DayName}"
                                                    FontSize="{DynamicResource FontSizeNormal}"
                                                    IsChecked="{Binding IsChecked}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock
                                    FontSize="{DynamicResource FontSizeSmall}"
                                    Foreground="{StaticResource TextValidationError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding ValidationError}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding SaveCommand}"
                                        Content="Save" />
                                    <Button
                                        Padding="10,4"
                                        Command="{Binding CancelCommand}"
                                        Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

            </StackPanel>
        </Border>

        <!--  Slot 5  -->
        <Border
            Padding="12"
            BorderBrush="{StaticResource SubduedBorder}"
            BorderThickness="1"
            CornerRadius="4">
            <StackPanel DataContext="{Binding Slot5}" Spacing="8">

                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Left"
                        FontWeight="SemiBold"
                        Text="Pattern 5" />
                    <StackPanel
                        DockPanel.Dock="Right"
                        IsEnabled="{Binding $parent[UserControl].DataContext.IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="6">
                        <Button
                            Padding="8,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            FontSize="{DynamicResource FontSizeNormal}"
                            IsEnabled="{Binding $parent[UserControl].DataContext.IsEditingAny, Converter={x:Static BoolConverters.Not}}" />
                        <Button
                            Padding="8,3"
                            Command="{Binding ClearCommand}"
                            Content="Clear"
