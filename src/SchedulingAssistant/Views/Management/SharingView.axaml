<UserControl
	x:Class="SchedulingAssistant.Views.Management.SharingView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
	x:CompileBindings="False"
	x:DataType="vm:SharingViewModel">

	<StackPanel Margin="16" Spacing="12">

		<TextBlock FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold" Text="Shared Schedules" />
		<TextBlock
			FontSize="{StaticResource FontSizeNormal}"
			
			Text="Import a colleague's shared schedule to overlay their sections on your grid. Export your current sections for others to import."
			TextWrapping="Wrap" />

		<Separator Margin="0,4" />
		<GroupBox MinWidth="300" HorizontalAlignment="Left" Header="Import">
		<!-- Import / Export buttons -->
		<StackPanel Orientation="Vertical" Spacing="8" IsVisible="{Binding SupportsFileDialogs}">
			<Button
				Padding="10,5"
				Command="{Binding ImportSharedScheduleCommand}"
				Content="Import Shared Schedule..."
				FontSize="{StaticResource FontSizeNormal}" />
			<!-- Loaded status -->
		<TextBlock
			FontSize="11"			
			Text="{Binding LoadedSummary}" />
			<!-- Dismiss All -->
		<Button
			Padding="10,5"
			Command="{Binding DismissAllCommand}"
			Content="Dismiss All Shared Schedules"
			FontSize="11"
			IsVisible="{Binding HasLoadedSchedules}" />			
		</StackPanel>
			</GroupBox>
	
          <GroupBox Header="Export" MinWidth="300" HorizontalAlignment="Left"
					ToolTip.Tip="Export your current view">
          <StackPanel>
		<!-- Export source label -->
		<StackPanel Spacing="2" IsVisible="{Binding SupportsFileDialogs}">
			<TextBlock
				FontSize="{StaticResource FontSizeSmall}"				
				Text="Description (required), will be used as a label for your share" />
			<TextBox
				HorizontalAlignment="Stretch"
				FontSize="11"
				FontWeight="SemiBold"
				PlaceholderText="e.g. Chemistry Department 2nd yr courses"
				PlaceholderForeground="Black"
				Text="{Binding ExportSourceLabel}"
				CornerRadius="4">				
				</TextBox>
				
				
		   </StackPanel>			   
	           <Button	HorizontalAlignment="Stretch"	
						  Margin="0,5,0,0"
				Command="{Binding ExportSharedScheduleCommand}"
				Content="Export Shared Schedule..."
				FontSize="{StaticResource FontSizeNormal}"
				/>		
	        </StackPanel>	
				
	</GroupBox>
	
      

		<Separator Margin="0,4" />

		<!-- Shared folder -->
		<StackPanel Spacing="4" IsVisible="{Binding SupportsFileDialogs}">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<Button
					Padding="10,5"
					Command="{Binding SetSharedFolderCommand}"
					Content="Set Shared Folder..."
					FontSize="11" 
					ToolTip.Tip="Set a default folder for imports and exports."
					/>
				<TextBlock
					VerticalAlignment="Center"
					FontSize="10"					
					Text="{Binding SharedFolderDisplay}" />
			</StackPanel>
			</StackPanel>

		

		<!-- Status message -->
		<TextBlock
			FontSize="10"
			Foreground="{StaticResource TextError}"
			IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
			Text="{Binding StatusMessage}"
			TextWrapping="Wrap" />
	</StackPanel>
</UserControl>
