<UserControl
    x:Class="SchedulingAssistant.Views.Management.LegalStartTimeListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:LegalStartTimeListViewModel">

    <Grid Margin="10,0" RowDefinitions="Auto,*,Auto,Auto,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="20"
            FontWeight="SemiBold"
            Text="Scheduling" />

        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:LegalStartTimeEditViewModel}">
                    <Grid
                        MaxWidth="700"
                        HorizontalAlignment="Left"
                        ColumnDefinitions="*,300"
                        RowDefinitions="Auto,Auto,*,Auto">

                        <TextBlock
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Margin="0,0,0,12"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />

                        <!--  Block length (only editable when new)  -->
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,16,12"
                            Spacing="4">
                            <TextBlock Text="Block Length (hours)" />
                            <NumericUpDown
                                FormatString="0.0"
                                Increment="0.5"
                                IsEnabled="{Binding IsNew}"
                                Maximum="8"
                                Minimum="0.5"
                                Value="{Binding BlockLength}" />
                        </StackPanel>

                        <!--  Start times list  -->
                        <StackPanel
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,16,0"
                            Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="Start Times" />
                            <ItemsControl ItemsSource="{Binding StartTimeRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:StartTimeRowViewModel}">
                                        <StackPanel
                                            Margin="0,2"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                Width="60"
                                                VerticalAlignment="Center"
                                                Text="{Binding Label}" />
                                            <Button
                                                Padding="6,2"
                                                Command="{Binding RemoveCommand}"
                                                Content="✕" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!--  Add start time  -->
                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,12,16,0"
                            Spacing="4">
                            <TextBlock Text="Add Start Time (e.g. 8:30 or 1430)" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Width="120" Text="{Binding NewStartTime}" />
                                <Button Command="{Binding AddStartTimeCommand}" Content="Add" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{StaticResource TextError}"
                                IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Text="{Binding ValidationError}" />
                        </StackPanel>

                        <!--  Save / Cancel  -->
                        <StackPanel
                            Grid.Row="3"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button Command="{Binding SaveCommand}" Content="Apply" />
                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                        </StackPanel>

                    </Grid>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            IsReadOnly="True"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            ItemsSource="{Binding Entries}"
            SelectedItem="{Binding SelectedEntry}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="160"
                    Binding="{Binding BlockLength}"
                    Header="Block Length (hrs)" />
                <DataGridTemplateColumn Width="*" Header="Start Times">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Margin="4,2"
                                Text="{Binding StartTimesDisplay}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <Button Command="{Binding AddCommand}" Content="Add" />
            <Button
                Command="{Binding EditCommand}"
                Content="Edit"
                IsEnabled="{Binding SelectedEntry, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button
                Command="{Binding DeleteCommand}"
                Content="Delete"
                IsEnabled="{Binding SelectedEntry, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>

        <!--  Preferred block length preference  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,16,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock VerticalAlignment="Center" Text="Preferred block length:" />
            <ComboBox
                Width="120"
                DisplayMemberBinding="{Binding Label}"
                ItemsSource="{Binding PreferredBlockLengthOptions}"
                SelectedItem="{Binding SelectedPreferredOption}" />
        </StackPanel>

        <!--  Weekend day inclusion settings  -->
        <StackPanel
            Grid.Row="4"
            Margin="0,24,0,0"
            IsEnabled="{Binding IsWriteEnabled}"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Spacing="6">
            <CheckBox Content="Include Saturday as an available scheduling day" IsChecked="{Binding IncludeSaturday}" />
            <CheckBox Content="Include Sunday as an available scheduling day" IsChecked="{Binding IncludeSunday}" />
        </StackPanel>

    </Grid>
</UserControl>
