<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.SectionCodePatternListView"
             x:DataType="vm:SectionCodePatternListViewModel"
             xmlns:local="clr-namespace:SchedulingAssistant.Helpers"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto,Auto" >

        <!--  Edit form (shown when EditVm is not null)  -->
        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:SectionCodePatternEditViewModel}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="8" MaxWidth="480" HorizontalAlignment="Left">

                            <TextBlock Text="{Binding Title}"
                                       FontSize="{StaticResource FontSizeLarge}"
                                       FontWeight="SemiBold" />

                            <!--  Explanatory text  -->
                            <TextBlock Text="Define the patterns your institution uses for its section codes."
                                       
                                       TextWrapping="Wrap" />

                            <!--  Name  -->
                            <TextBlock   >
                                <Run Text="Name" FontWeight="SemiBold"/>
                                <Run Text="(This will appear as a menu choice when you are editing a section)"/>
                                </TextBlock>
                            <TextBox Text="{Binding Name}" 
                                     PlaceholderText="e.g. Lecture, Lab, Tutorial" />
                            <TextBlock Text="{Binding ValidationError}"
                                       Foreground="{StaticResource TextError}"
                                       FontSize="{StaticResource FontSizeNormal}"
                                       IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!--  Linear code structure: [Prefix] [Incrementor] [Suffix]  -->
                            <Grid ColumnDefinitions="*,12,*,12,*">

                                <!--  Prefix  -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Prefix (optional)" />
                                    <TextBox Text="{Binding Prefix}"
                                             PlaceholderText="e.g. L, AB, D" />
                                </StackPanel>

                                <!--  Incrementor: live display + all governing controls  -->
                                <Border Grid.Column="2"
                                        BorderBrush="{StaticResource TextLabel}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Designator" Margin="0,-5,0,5"/>
                                        <TextBox Text="{Binding IncrementorPreview}"
                                                 IsReadOnly="True"
                                                 FontFamily="Consolas, Menlo, monospace" Margin="0,-8,0,0" />
                                        <StackPanel Spacing="4" Margin="0,4,0,0">
                                            <RadioButton Content="Numbers"
                                                         IsChecked="{Binding ShowNumberFields}" />
                                            <RadioButton Content="Letters"
                                                         IsChecked="{Binding UseLetters}" />
                                        </StackPanel>
                                        <!--  Number sub-fields  -->
                                        <Grid ColumnDefinitions="*,6,*"
                                              IsVisible="{Binding ShowNumberFields}">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="First"
                                                           FontSize="{StaticResource FontSizeSmall}" />
                                                <TextBox Text="{Binding FirstNumberText}"
                                                         PlaceholderText="e.g. 1" />
                                                <TextBlock Text="{Binding FirstNumberError}"
                                                           Foreground="{StaticResource TextError}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           IsVisible="{Binding FirstNumberError, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Step"
                                                           FontSize="{StaticResource FontSizeSmall}" />
                                                <TextBox Text="{Binding IncrementText}"
                                                         PlaceholderText="e.g. 1" />
                                                <TextBlock Text="{Binding IncrementError}"
                                                           Foreground="{StaticResource TextError}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           IsVisible="{Binding IncrementError, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            </StackPanel>
                                        </Grid>
                                        <!--  Letter sub-field  -->
                                        <StackPanel IsVisible="{Binding ShowLetterFields}">
                                            <TextBlock Text="First letter"
                                                       FontSize="{StaticResource FontSizeSmall}" />
                                            <TextBox Text="{Binding FirstLetterText}"
                                                     PlaceholderText="e.g. A" />
                                            <TextBlock Text="{Binding FirstLetterError}"
                                                       Foreground="{StaticResource TextError}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       IsVisible="{Binding FirstLetterError, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!--  Suffix  -->
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Suffix (optional)" />
                                    <TextBox Text="{Binding Suffix}"
                                             PlaceholderText="e.g. -LAB" />
                                </StackPanel>

                            </Grid>

                            <!--  Preview  -->
                            <Border Padding="8,6"
                                    Background="{StaticResource SectionScheduleArea}"
                                    CornerRadius="4"
                                    IsVisible="{Binding Preview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Preview"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{StaticResource TextLabel}" />
                                    <TextBlock Text="{Binding Preview}"
                                               FontFamily="Consolas, Menlo, monospace"
                                               FontSize="{StaticResource FontSizeNormal}" />
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,4" />

                            <!--  Pre-fill: Campus and Section Type  -->
                            <TextBlock Text="Associate the code pattern with a campus or section type (optional)"
                                        />

                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Campus" />
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding CampusOptions}"
                                              SelectedItem="{Binding SelectedCampus}"
                                              DisplayMemberBinding="{Binding Name}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Section type" />
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding SectionTypeOptions}"
                                              SelectedItem="{Binding SelectedSectionType}"
                                              DisplayMemberBinding="{Binding Name}" />
                                </StackPanel>
                            </Grid>

                            <!--  Apply / Cancel  -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button Content="Apply" Command="{Binding SaveCommand}" />
                                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!--  Introductory text (shown when list is visible)  -->
        <StackPanel Grid.Row="0" Orientation="Vertical"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">
        <TextBlock Text="Section Codes" FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold"/>

        <TextBlock Margin="0,10,0,0" MaxWidth="700" HorizontalAlignment="Left"
                   Text="Section codes distinguish multiple offerings of the same course, or label different components of the same course (e.g. a lecture and a lab, or tutorial). Some examples are below.&#10;&#10;Set the section coding schemes your institution uses here and avoid having to enter them manually as you create or edit sections. Once configured, TermPoint will supply the section codes for new sections automatically. You can always over-ride if you wish."
                   TextWrapping="Wrap"
                    />

            <Expander Header="Examples" IsExpanded="False" Margin="0,4,0,20" MaxWidth="900" HorizontalAlignment="Left">
                <StackPanel Spacing="8" Margin="0,6,0,0">
                    <TextBlock TextWrapping="Wrap" local:InlineFormatter.Text="The following are examples of {red}section codes{/} in use at various universities." />

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,5,Auto,5,Auto,5">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sections" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Role" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Comments" FontWeight="SemiBold"/>
                        

                        <TextBlock Grid.Row="1" Grid.Column="0" local:InlineFormatter.Text="CHEM 111 {red}AB1{/}, CHEM 111 {red}AB2{/} " />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Two lecture sections of CHEM 111" />
                        <TextBlock Grid.Row="1" Grid.Column="4" Width="320" Text="Prefix AB denotes campus. Sections increment numerically by 1" TextWrapping="Wrap"/>
                        

                        <TextBlock Grid.Row="2" Grid.Column="0" local:InlineFormatter.Text="CHEM 111 {red}A#A{/}, CHEM 111 {red}A#B{/} " />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Two lab sections of CHEM 111" />
                        <TextBlock Grid.Row="2" Grid.Column="4" Width="320" Text="Sections increment alphabetically" TextWrapping="Wrap"/>
                        

                        <TextBlock Grid.Row="3" Grid.Column="0" local:InlineFormatter.Text="HIST 106 {red}D100{/}, HIST 106 {red}D200{/} " />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Two lecture sections of HIST 106" />
                        <TextBlock Grid.Row="3" Grid.Column="4" Width="320" Text="Prefix D denotes daytime. Number increments by 100" TextWrapping="Wrap"/>
                        

                        <TextBlock Grid.Row="4" Grid.Column="0" local:InlineFormatter.Text="HIST 106 {red}D101{/}, HIST 106 {red}D102{/} " />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="Two tutorial sections of HIST 106 D100" />
                        <TextBlock Grid.Row="4" Grid.Column="4" Width="320" Text="" />
                        

                        <TextBlock Grid.Row="5" Grid.Column="0" local:InlineFormatter.Text="BIO 219 {red}010{/}, BIO 219 {red}011{/} " />
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="Two lecture sections of BIO 219" />
                        <TextBlock Grid.Row="5" Grid.Column="4" Width="320" Text="No prefix." TextWrapping="Wrap" />
                        

                        <TextBlock Grid.Row="6" Grid.Column="0" local:InlineFormatter.Text="BIO 219 {red}020L{/}, BIO {red}021L{/} " />
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="Two labs of BIO 219 010" />
                        <TextBlock Grid.Row="6" Grid.Column="4" Width="320" Text="Suffix L denotes lab" TextWrapping="Wrap" />
                        

                    </Grid>

                    <TextBlock Text="Any section code that follows the format below can be configured in TermPoint:" TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="A Prefix (possibly empty) (e.g. 'A#' or 'D') + number or alphabetical incrementor (e.g. '100' or '011' or 'A' ) + Suffix (possibly empty)" TextWrapping="Wrap" />
                </StackPanel>
            </Expander>
            </StackPanel>

        <StackPanel Grid.Row="1" Width="400" HorizontalAlignment="Left"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">
        <TextBlock Text="Section Codes in use" FontSize="{StaticResource FontSizeLarge}" Margin="0,10"/>
        <!--  List (shown when EditVm is null)  -->
        <DataGrid x:Name="PatternsDataGrid"
                  
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"         Binding="{Binding Name}"            Width="*" />
                <DataGridTextColumn Header="Examples"     Binding="{Binding Examples}"        Width="Auto" />
                <DataGridTextColumn Header="Campus"       Binding="{Binding CampusName}"      Width="Auto" />
                <DataGridTextColumn Header="Section Type" Binding="{Binding SectionTypeName}" Width="Auto" />
            </DataGrid.Columns>
        </DataGrid>

        <!--  Toolbar  -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,12,0,0"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    IsEnabled="{Binding IsWriteEnabled}">
            <Button Content="Add"    Command="{Binding AddCommand}" />
            <Button Content="Edit"   Command="{Binding EditCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>
            </StackPanel>
    </Grid>
</UserControl>
