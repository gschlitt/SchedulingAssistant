<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.CampusListView"
             x:DataType="vm:CampusListViewModel"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto" MaxWidth="420">

        <!-- Edit form (shown when EditVm is not null) -->
        <ContentControl Grid.Row="1" Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:CampusEditViewModel}">
                    <StackPanel Spacing="10" MaxWidth="320" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeLarge}" FontWeight="SemiBold" />

                        <TextBlock Text="Name" />
                        <TextBox Text="{Binding Name}" />
                        <TextBlock Text="{Binding ValidationError}"
                                   Foreground="{StaticResource TextError}" FontSize="{StaticResource FontSizeNormal}"
                                   IsVisible="{Binding ValidationError,
                                       Converter={x:Static ObjectConverters.IsNotNull}}" />

                        <TextBlock Text="Abbreviation" />
                        <TextBox Text="{Binding Abbreviation}"
                                 Watermark="e.g. MC (optional)" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Apply" Command="{Binding SaveCommand}" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- List (shown when EditVm is null) -->
        <DataGrid x:Name="CampusesDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"         Binding="{Binding Name}"         Width="*" />
                <DataGridTextColumn Header="Abbreviation" Binding="{Binding Abbreviation}"  Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    IsEnabled="{Binding IsWriteEnabled}">
            <Button Content="Add" Command="{Binding AddCommand}" />
            <Button Content="Edit" Command="{Binding EditCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>

    </Grid>
</UserControl>
