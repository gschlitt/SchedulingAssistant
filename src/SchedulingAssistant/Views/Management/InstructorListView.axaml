<UserControl
    x:Class="SchedulingAssistant.Views.Management.InstructorListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:v="using:SchedulingAssistant.Views.Management"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:InstructorListViewModel"
    Background="{StaticResource AppBackground}">

    <!--  Two-column layout: Col 0 main content | Col 1 workload mailer  -->
    <Grid 
        Margin="10,0,0,0" 
        Background="{StaticResource AppBackground}"
        ColumnDefinitions="Auto,Auto"
        RowDefinitions="Auto,*">

        <!--  Row 0: Header  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Padding="0,12"
            Background="{StaticResource AppBackground}">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Select Instructor to access workload and workload history"
                           FontSize="{StaticResource FontSizeNormal}" FontStyle="Italic"
                           IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNull}}"/>
                <StackPanel
                    IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        Foreground="{StaticResource TextMuted}"
                        Text="Selected:" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        Text="{Binding SelectedFirstName}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        Text="{Binding SelectedLastName}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--  Row 1, Col 0: All instructor content stacked vertically  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="0">

            <!--  Edit form (shown when editing, hides the list+history)  -->
            <ContentControl Content="{Binding EditVm}">
                <ContentControl.ContentTemplate>
                    <DataTemplate DataType="{x:Type vm:InstructorEditViewModel}">
                        <StackPanel Spacing="10">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{Binding Title}" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,4,2"
                                    Text="First Name" />
                                <TextBox
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,4,6"
                                    Text="{Binding FirstName}" />

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,0,2"
                                    Text="Last Name" />
                                <TextBox
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,0,6"
                                    Text="{Binding LastName}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,0,4,2"
                                    Text="Initials" />
                                <TextBox
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,0,4,6"
                                    Text="{Binding Initials}" />

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,0,0,2"
                                    Text="Staff Type" />
                                <ComboBox
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="0,0,0,6"
                                    HorizontalAlignment="Stretch"
                                    DisplayMemberBinding="{Binding Name}"
                                    ItemsSource="{Binding StaffTypes}"
                                    SelectedValue="{Binding SelectedStaffTypeId}"
                                    SelectedValueBinding="{Binding Id}" />
                            </Grid>

                            <TextBlock
                                FontSize="9"
                                Foreground="{StaticResource TextError}"
                                IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Text="{Binding ValidationError}" />

                            <TextBlock Text="Email" />
                            <TextBox Text="{Binding Email}" />

                            <TextBlock Text="Notes" />
                            <TextBox
                                Height="40"
                                AcceptsReturn="True"
                                Text="{Binding Notes}" />

                            <CheckBox Content="Active" IsChecked="{Binding IsActive}" />

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button
                                    Padding="6,3"
                                    Command="{Binding SaveCommand}"
                                    Content="Apply" />
                                <Button
                                    Padding="6,3"
                                    Command="{Binding CancelCommand}"
                                    Content="Cancel" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!--  List view + Workload History (hidden when editing)  -->
            <StackPanel
                IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                Orientation="Horizontal"
                Spacing="16">

                <!--  Instructor list  -->
                <StackPanel x:Name="InstructorListPanel" Spacing="6">
                    <CheckBox Content="Show only active instructors" IsChecked="{Binding ShowOnlyActive}" />

                    <DataGrid
                        MinWidth="200"
                        x:Name="InstructorDataGrid"
                        HorizontalAlignment="Left"
                        b:DoubleTapCommandBehavior.Command="{Binding EditCommand}"
                        MaxHeight="250"
                        AutoGenerateColumns="False"
                        Background="{StaticResource AppBackground}"
                        BorderBrush="{StaticResource InlineListBorder}"
                        BorderThickness="1"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        ItemsSource="{Binding Instructors}"
                        SelectedItem="{Binding SelectedInstructor}"
                        Sorting="DataGrid_Sorting">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding FirstName}"
                                FontSize="12"
                                Header="First"
                                Tag="FirstName" />
                            <DataGridTextColumn
                                Width="Auto"
                                MinWidth="20"
                                Binding="{Binding LastName}"
                                FontSize="12"
                                Header="Last"
                                Tag="LastName" />
                            <DataGridTextColumn
                                MinWidth="40"
                                Binding="{Binding Initials}"
                                FontSize="12"
                                Header="Init"
                                Tag="Initials" />
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding StaffTypeName}"
                                FontSize="12"
                                Header="Type"
                                Tag="StaffType" />
                            <DataGridTextColumn
                                Width="Auto"
                                MinWidth="150"
                                Binding="{Binding Email}"
                                FontSize="12"
                                Header="Email" />
                            <DataGridCheckBoxColumn
                                Width="50"
                                Binding="{Binding IsActive}"
                                Header="Active"
                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--  Buttons  -->
                    <StackPanel
                        IsEnabled="{Binding IsWriteEnabled}"
                        Orientation="Horizontal"
                        Spacing="3">
                        <Button
                            Width="45"
                            Padding="5,3"
                            Command="{Binding AddCommand}"
                            Content="Add" />
                        <Button
                            Width="45"
                            Padding="5,3"
                            Command="{Binding EditCommand}"
                            Content="Edit"
                            IsEnabled="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button
                            Width="55"
                            Padding="5,3"
                            Command="{Binding DeleteCommand}"
                            Content="Delete"
                            IsEnabled="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                    <!--  Inline error message  -->
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextError}"
                        IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Text="{Binding LastErrorMessage}"
                        TextWrapping="Wrap"
                        Margin="0,4,0,0" />
                </StackPanel>

                <!--  Workload History (right of instructor list)  -->
                <DockPanel
                    Width="180"
                    MaxHeight="250"
                    VerticalAlignment="Top"
                    IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Border
                        Padding="8,12"
                        Background="{StaticResource AppBackground}"
                        DockPanel.Dock="Top">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextMuted}"
                            Text="Workload History" />
                    </Border>
                    <Border Background="{StaticResource AppBackground}">
                        <v:WorkloadHistoryView DataContext="{Binding WorkloadHistoryVm}" />
                    </Border>
                </DockPanel>

            </StackPanel>

            <!--  Semester picker  -->
            <StackPanel
                Margin="0,8,0,4"
                VerticalAlignment="Center"
                IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Spacing="10">
                <ComboBox
                    Padding="6,2"
                    VerticalAlignment="Center"
                    DisplayMemberBinding="{Binding Semester.Name}"
                    FontSize="11"
                    ItemsSource="{Binding FlyoutSemesters}"
                    SelectedItem="{Binding FlyoutSelectedSemester}" />
                <Border
                    Width="1"
                    Margin="4,2"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource InlineListBorder}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding SemesterActivityLabel}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="{Binding WorkloadUnitsDisplay}" />
            </StackPanel>

            <!--  Three workload panels side by side  -->
            <Grid
            ColumnDefinitions="Auto,1,Auto,1,Auto"
            IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}">

            <!--  Instructional Workload Panel  -->
            <Border
                Grid.Column="0"
                Padding="8"
                Background="{StaticResource AppBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <ScrollViewer>
                    <StackPanel DataContext="{Binding WorkloadVm}" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Instructional Workload"
                            b:HelpTip.Text="Section assigned and corresponding workload for the selected semester "/>

                        <TextBlock
                            Margin="0,4,0,0"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextFaint}"
                            Text="Sections" />

                        <ItemsControl ItemsSource="{Binding AssignedSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1" ColumnDefinitions="*,50">
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="{Binding Display}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Text="{Binding WorkloadValue, StringFormat=0.##}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="8"
                            FontStyle="Italic"
                            Foreground="{StaticResource TextMuted}"
                            Text="&#x26a0; Instructional workload is edited in Section Editor"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  Splitter  -->
            <Border Grid.Column="1" Background="{StaticResource InlineListBorder}" />

            <!--  Non-instructional Workload Panel  -->
            <Border
                x:Name="NonInstructionalPanel"
                Grid.Column="2"
                Padding="8"
                Background="{StaticResource AppBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <StackPanel DataContext="{Binding ReleaseVm}" Spacing="8">
                    <TextBlock
                        b:HelpTip.Text="Keep track of semester non-instructional workload (such as releases) here. Workload recorded here is visible in Workload View in the main window."
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Non-instructional Workload" />

                    <ContentControl Content="{Binding EditVm}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:ReleaseEditViewModel}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="New Release" />

                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Title" />
                                        <TextBox Text="{Binding Title}" />
                                    </StackPanel>

                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Workload" />
                                        <TextBox Text="{Binding WorkloadText}" />
                                    </StackPanel>

                                    <TextBlock
                                        FontSize="9"
                                        Foreground="{StaticResource TextError}"
                                        IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Text="{Binding ValidationError}" />

                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button
                                            Padding="6,3"
                                            Command="{Binding SaveCommand}"
                                            Content="Apply" />
                                        <Button
                                            Padding="6,3"
                                            Command="{Binding CancelCommand}"
                                            Content="Cancel" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <StackPanel IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}" Spacing="4">
                        <DataGrid
                            MaxHeight="280"
                            AutoGenerateColumns="False"
                            BorderBrush="{StaticResource InlineListBorder}"
                            BorderThickness="1"
                            CanUserSortColumns="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding Releases}"
                            SelectedItem="{Binding SelectedRelease}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding Title}"
                                    Header="Title" />
                                <DataGridTextColumn
                                    Width="70"
                                    Binding="{Binding WorkloadValue, StringFormat=0.##}"
                                    Header="Workload" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel
                            IsEnabled="{Binding IsWriteEnabled}"
                            Orientation="Horizontal"
                            Spacing="3">
                            <Button
                                Width="45"
                                Padding="5,3"
                                Command="{Binding AddCommand}"
                                Content="Add" />
                            <Button
                                Width="45"
                                Padding="5,3"
                                Command="{Binding EditCommand}"
                                Content="Edit"
                                IsEnabled="{Binding SelectedRelease, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <Button
                                Width="55"
                                Padding="5,3"
                                Command="{Binding DeleteCommand}"
                                Content="Delete"
                                IsEnabled="{Binding SelectedRelease, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>

                        <TextBlock
                            FontSize="8"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding LastErrorMessage}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Splitter  -->
            <Border Grid.Column="3" Background="{StaticResource InlineListBorder}" />

            <!--  Commitments Panel  -->
            <Border
                x:Name="CommitmentsPanel"
                Grid.Column="4"
                Padding="8"
                Background="{StaticResource AppBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <ScrollViewer>
                    <StackPanel DataContext="{Binding CommitmentsVm}" Spacing="8">
                        <TextBlock
                            b:HelpTip.Text="Keep track of time committments an instructor may have, other than scheduled teaching. Anything recorded here will show when an instructor is overlaid on Schedule Grid."
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Scheduled Commitments" />

                        <ContentControl Content="{Binding EditVm}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:CommitmentEditViewModel}">
                                    <StackPanel Margin="0,4,0,0" Spacing="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Name" />
                                            <TextBox Text="{Binding Name}" PlaceholderText="Commitment name" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Day" />
                                            <ComboBox
                                                DisplayMemberBinding="{Binding Display}"
                                                ItemsSource="{Binding DayOptions}"
                                                SelectedItem="{Binding SelectedDayOption}" />
                                        </StackPanel>

                                        <TextBlock Text="Time" />
                                        <Grid Margin="0,0,0,6" ColumnDefinitions="*,4,*">
                                            <ComboBox
                                                Grid.Column="0"
                                                DisplayMemberBinding="{Binding Display}"
                                                ItemsSource="{Binding StartTimeOptions}"
                                                SelectedValue="{Binding SelectedStartMinutes}"
                                                SelectedValueBinding="{Binding Minutes}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Text="&#x2013;" />
                                            <ComboBox
                                                Grid.Column="2"
                                                DisplayMemberBinding="{Binding Display}"
                                                ItemsSource="{Binding EndTimeOptions}"
                                                SelectedValue="{Binding SelectedEndMinutes}"
                                                SelectedValueBinding="{Binding Minutes}" />
                                        </Grid>

                                        <TextBlock
                                            FontSize="9"
                                            Foreground="{StaticResource TextError}"
                                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Text="{Binding ValidationError}" />

                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button
                                                Padding="6,3"
                                                Command="{Binding SaveCommand}"
                                                Content="Apply" />
                                            <Button
                                                Padding="6,3"
                                                Command="{Binding CancelCommand}"
                                                Content="Cancel" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                        <StackPanel IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}" Spacing="4">
                            <DataGrid
                                MaxHeight="280"
                                AutoGenerateColumns="False"
                                BorderBrush="{StaticResource InlineListBorder}"
                                BorderThickness="1"
                                CanUserSortColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding Commitments}"
                                SelectedItem="{Binding SelectedCommitment}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Name}"
                                        Header="Name" />
                                    <DataGridTextColumn
                                        Width="40"
                                        Binding="{Binding DayDisplay}"
                                        Header="Day" />
                                    <DataGridTextColumn
                                        Width="90"
                                        Binding="{Binding TimeDisplay}"
                                        Header="Time" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel
                                IsEnabled="{Binding IsWriteEnabled}"
                                Orientation="Horizontal"
                                Spacing="3">
                                <Button
                                    Width="45"
                                    Padding="5,3"
                                    Command="{Binding AddCommand}"
                                    Content="Add" />
                                <Button
                                    Width="45"
                                    Padding="5,3"
                                    Command="{Binding EditCommand}"
                                    Content="Edit"
                                    IsEnabled="{Binding SelectedCommitment, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <Button
                                    Width="55"
                                    Padding="5,3"
                                    Command="{Binding DeleteCommand}"
                                    Content="Delete"
                                    IsEnabled="{Binding SelectedCommitment, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </StackPanel>

                            <TextBlock
                                FontSize="8"
                                Foreground="{StaticResource TextError}"
                                IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Text="{Binding LastErrorMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        </StackPanel>

        <!--  Col 1, Row 1: Workload Mailer toggle + panel  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Margin="10,0,0,0">
            <CheckBox
                Content="Workload Mailer"
                FontSize="{StaticResource FontSizeNormal}"                
                IsChecked="{Binding ShowWorkloadMailer}" />
            <Border
                x:Name="WorkloadMailerPanel"
                Padding="10"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1,0,0,0"
                IsVisible="{Binding ShowWorkloadMailer}">
                <v:WorkloadMailerView DataContext="{Binding WorkloadMailerVm}" />
            </Border>
        </StackPanel>

    </Grid>
</UserControl>
