<UserControl
    x:Class="SchedulingAssistant.Views.Management.InstructorListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:v="using:SchedulingAssistant.Views.Management"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:InstructorListViewModel">

    <UserControl.Styles>
        <Style Selector="DataGrid DataGridRow:selected">
            <Setter Property="Background" Value="#FFE0E0E0" />
            <!--  shaded gray  -->
        </Style>
    </UserControl.Styles>

    <!--  Two-column layout: Column 0 has instructor list + workload panels | Column 1 reserved  -->
    <Grid
        Margin="10,0,0,0"
        ColumnDefinitions="*,*"
        RowDefinitions="Auto,Auto,Auto,*">
        <!--  LEFT COLUMN: Instructor list and edit  -->

        <!--  HEADER: Instructor name  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Padding="8,12"
            Background="{StaticResource SurfaceBackground}"
            BorderThickness="0,0,0,0">
            <StackPanel
                IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    Foreground="{StaticResource TextMuted}"
                    Text="Selected:" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding SelectedFirstName}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding SelectedLastName}" />
            </StackPanel>
        </Border>



        <!--  Edit form  -->
        <ContentControl
            Grid.Row="1"
            Grid.Column="0"
            Content="{Binding EditVm}">
            <ContentControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:InstructorEditViewModel}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{Binding Title}" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,4,2"
                                FontSize="10"
                                Text="First Name" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,4,6"
                                FontSize="10"
                                Text="{Binding FirstName}" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,2"
                                FontSize="10"
                                Text="Last Name" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                FontSize="10"
                                Text="{Binding LastName}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,4,2"
                                FontSize="10"
                                Text="Initials" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="0"
                                Margin="0,0,4,6"
                                FontSize="10"
                                Text="{Binding Initials}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,0,0,2"
                                FontSize="10"
                                Text="Staff Type" />
                            <ComboBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,0,0,6"
                                HorizontalAlignment="Stretch"
                                DisplayMemberBinding="{Binding Name}"
                                FontSize="10"
                                ItemsSource="{Binding StaffTypes}"
                                SelectedValue="{Binding SelectedStaffTypeId}"
                                SelectedValueBinding="{Binding Id}" />
                        </Grid>

                        <TextBlock
                            FontSize="9"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding ValidationError}" />

                        <TextBlock FontSize="10" Text="Email" />
                        <TextBox FontSize="10" Text="{Binding Email}" />

                        <TextBlock FontSize="10" Text="Notes" />
                        <TextBox
                            Height="40"
                            AcceptsReturn="True"
                            FontSize="10"
                            Text="{Binding Notes}" />

                        <CheckBox
                            Content="Active"
                            FontSize="10"
                            IsChecked="{Binding IsActive}" />

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button
                                Padding="6,3"
                                Command="{Binding SaveCommand}"
                                Content="Done"
                                FontSize="10" />
                            <Button
                                Padding="6,3"
                                Command="{Binding CancelCommand}"
                                Content="Cancel"
                                FontSize="10" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!--  List view: checkbox + grid (hidden when editing)  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
            Spacing="6">
            <CheckBox
                Content="Show only active instructors"
                FontSize="10"
                IsChecked="{Binding ShowOnlyActive}" />

            <!--  CanUserSortColumns enables click-to-sort on column headers.
                  The Sorting event is handled in code-behind, which delegates to
                  InstructorListViewModel.SetSortMode() and sets e.Handled=true to
                  suppress the DataGrid's built-in client-side sort (we sort at the DB level).
                  Tag values on each column identify which InstructorSortMode to apply.  -->
            <DataGrid
                MaxHeight="250"
                AutoGenerateColumns="False"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1"
                CanUserSortColumns="True"
                IsReadOnly="True"
                ItemsSource="{Binding Instructors}"
                SelectedItem="{Binding SelectedInstructor}"
                Sorting="DataGrid_Sorting">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding FirstName}"
                        FontSize="12"
                        Header="First"
                        Tag="FirstName" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding LastName}"
                        FontSize="12"
                        Header="Last"
                        Tag="LastName" />
                    <DataGridTextColumn
                        Width="40"
                        Binding="{Binding Initials}"
                        FontSize="12"
                        Header="Init"
                        Tag="Initials" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding StaffTypeName}"
                        FontSize="12"
                        Header="Type"
                        Tag="StaffType" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Email}"
                        FontSize="12"
                        Header="Email" />
                    <DataGridCheckBoxColumn
                        Width="46"
                        Binding="{Binding IsActive}"
                        Header="Active"
                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <!--  Buttons — IsEnabled gates the entire group in read-only mode  -->
            <StackPanel Orientation="Horizontal" Spacing="3"
                        IsEnabled="{Binding IsWriteEnabled}">
                <Button
                    Width="45"
                    Padding="5,3"
                    Command="{Binding AddCommand}"
                    Content="Add"
                    FontSize="10" />
                <Button
                    Width="45"
                    Padding="5,3"
                    Command="{Binding EditCommand}"
                    Content="Edit"
                    FontSize="10"
                    IsEnabled="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button
                    Width="55"
                    Padding="5,3"
                    Command="{Binding DeleteCommand}"
                    Content="Delete"
                    FontSize="10"
                    IsEnabled="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>
        </StackPanel>

        <!--  Semester picker + Semester Activity label with workload units  -->
        <!--  The semester ComboBox is local to this flyout and operates independently  -->
        <!--  of the global semester selection, allowing per-instructor semester browsing  -->
        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,8,0,4"
            VerticalAlignment="Center"
            IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}"
            Orientation="Horizontal"
            Spacing="10">
            <!--  Local semester chooser: all semesters in the current academic year  -->
            <ComboBox
                Padding="6,2"
                VerticalAlignment="Center"
                DisplayMemberBinding="{Binding Semester.Name}"
                FontSize="11"
                ItemsSource="{Binding FlyoutSemesters}"
                SelectedItem="{Binding FlyoutSelectedSemester}" />
            <!--  Vertical divider  -->
            <Border
                Width="1"
                Margin="4,2"
                VerticalAlignment="Stretch"
                Background="{StaticResource InlineListBorder}" />
            <!--  Activity summary for the selected semester  -->
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding SemesterActivityLabel}" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding WorkloadUnitsDisplay}" />
        </StackPanel>

        <!--  Three workload panels side by side (below instructor list)  -->
        <Grid
            Grid.Row="3"
            Grid.Column="0"
            ColumnDefinitions="*,1,*,1,*"
            IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}">
            <!--  Instructional Workload Panel  -->
            <Border
                Grid.Column="0"
                Padding="8"
                Background="{StaticResource SurfaceBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <ScrollViewer>
                    <StackPanel DataContext="{Binding WorkloadVm}" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Instructional Workload" />

                        <!--  Sections heading  -->
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextFaint}"
                            Text="Sections" />

                        <!--  Assigned sections list  -->
                        <ItemsControl ItemsSource="{Binding AssignedSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1" ColumnDefinitions="*,50">
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="9"
                                            Text="{Binding Display}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="9"
                                            Text="{Binding WorkloadValue, StringFormat=0.##}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Info about editing sections  -->
                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="8"
                            FontStyle="Italic"
                            Foreground="{StaticResource TextMuted}"
                            Text="⚠ Instructional workload is edited in Section Editor"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  Splitter  -->
            <Border Grid.Column="1" Background="{StaticResource InlineListBorder}" />

            <!--  Non-instructional Workload Panel  -->
            <Border
                Grid.Column="2"
                Padding="8"
                Background="{StaticResource SurfaceBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <StackPanel DataContext="{Binding ReleaseVm}" Spacing="8">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Non-instructional Workload" />

                    <!--  Release edit form  -->
                    <ContentControl Content="{Binding EditVm}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:ReleaseEditViewModel}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Text="New Release" />

                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="10" Text="Title" />
                                        <TextBox FontSize="10" Text="{Binding Title}" />
                                    </StackPanel>

                                    <StackPanel Spacing="2">
                                        <TextBlock FontSize="10" Text="Workload" />
                                        <TextBox FontSize="10" Text="{Binding WorkloadText}" />
                                    </StackPanel>

                                    <TextBlock
                                        FontSize="9"
                                        Foreground="{StaticResource TextError}"
                                        IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Text="{Binding ValidationError}" />

                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button
                                            Padding="6,3"
                                            Command="{Binding SaveCommand}"
                                            Content="Done"
                                            FontSize="10" />
                                        <Button
                                            Padding="6,3"
                                            Command="{Binding CancelCommand}"
                                            Content="Cancel"
                                            FontSize="10" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!--  Releases list (hidden when editing)  -->
                    <StackPanel IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}" Spacing="4">
                        <DataGrid
                            MaxHeight="280"
                            AutoGenerateColumns="False"
                            BorderBrush="{StaticResource InlineListBorder}"
                            BorderThickness="1"
                            CanUserSortColumns="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding Releases}"
                            SelectedItem="{Binding SelectedRelease}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Title}"
                                    FontSize="10"
                                    Header="Title" />
                                <DataGridTextColumn
                                    Width="70"
                                    Binding="{Binding WorkloadValue, StringFormat=0.##}"
                                    FontSize="10"
                                    Header="Workload" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!--  CRUD buttons  -->
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <Button
                                Width="45"
                                Padding="5,3"
                                Command="{Binding AddCommand}"
                                Content="Add"
                                FontSize="10" />
                            <Button
                                Width="45"
                                Padding="5,3"
                                Command="{Binding EditCommand}"
                                Content="Edit"
                                FontSize="10"
                                IsEnabled="{Binding SelectedRelease, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <Button
                                Width="55"
                                Padding="5,3"
                                Command="{Binding DeleteCommand}"
                                Content="Delete"
                                FontSize="10"
                                IsEnabled="{Binding SelectedRelease, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>

                        <!--  Error message  -->
                        <TextBlock
                            FontSize="8"
                            Foreground="{StaticResource TextError}"
                            IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Text="{Binding LastErrorMessage}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Splitter  -->
            <Border Grid.Column="3" Background="{StaticResource InlineListBorder}" />

            <!--  Commitments Panel  -->
            <Border
                Grid.Column="4"
                Padding="8"
                Background="{StaticResource SurfaceBackground}"
                BorderBrush="{StaticResource InlineListBorder}"
                BorderThickness="1">
                <ScrollViewer>
                    <StackPanel DataContext="{Binding CommitmentsVm}" Spacing="8">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Scheduled Commitments" />

                        <!--  Commitment edit form  -->
                        <ContentControl Content="{Binding EditVm}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:CommitmentEditViewModel}">
                                    <StackPanel Margin="0,4,0,0" Spacing="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="10" Text="Name" />
                                            <TextBox
                                                FontSize="10"
                                                Text="{Binding Name}"
                                                Watermark="Commitment name" />
                                        </StackPanel>

                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="10" Text="Day" />
                                            <ComboBox
                                                DisplayMemberBinding="{Binding Display}"
                                                FontSize="10"
                                                ItemsSource="{Binding DayOptions}"
                                                SelectedItem="{Binding SelectedDayOption}" />
                                        </StackPanel>

                                        <TextBlock FontSize="10" Text="Time" />
                                        <Grid Margin="0,0,0,6" ColumnDefinitions="*,4,*">
                                            <ComboBox
                                                Grid.Column="0"
                                                DisplayMemberBinding="{Binding Display}"
                                                FontSize="10"
                                                ItemsSource="{Binding StartTimeOptions}"
                                                SelectedValue="{Binding SelectedStartMinutes}"
                                                SelectedValueBinding="{Binding Minutes}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Text="–" />
                                            <ComboBox
                                                Grid.Column="2"
                                                DisplayMemberBinding="{Binding Display}"
                                                FontSize="10"
                                                ItemsSource="{Binding EndTimeOptions}"
                                                SelectedValue="{Binding SelectedEndMinutes}"
                                                SelectedValueBinding="{Binding Minutes}" />
                                        </Grid>

                                        <TextBlock
                                            FontSize="9"
                                            Foreground="{StaticResource TextError}"
                                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Text="{Binding ValidationError}" />

                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button
                                                Padding="6,3"
                                                Command="{Binding SaveCommand}"
                                                Content="Done"
                                                FontSize="10" />
                                            <Button
                                                Padding="6,3"
                                                Command="{Binding CancelCommand}"
                                                Content="Cancel"
                                                FontSize="10" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                        <!--  Commitments list (hidden when editing)  -->
                        <StackPanel IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}" Spacing="4">
                            <DataGrid
                                MaxHeight="280"
                                AutoGenerateColumns="False"
                                BorderBrush="{StaticResource InlineListBorder}"
                                BorderThickness="1"
                                CanUserSortColumns="False"
                                IsReadOnly="True"
                                ItemsSource="{Binding Commitments}"
                                SelectedItem="{Binding SelectedCommitment}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Name}"
                                        FontSize="10"
                                        Header="Name" />
                                    <DataGridTextColumn
                                        Width="40"
                                        Binding="{Binding DayDisplay}"
                                        FontSize="10"
                                        Header="Day" />
                                    <DataGridTextColumn
                                        Width="90"
                                        Binding="{Binding TimeDisplay}"
                                        FontSize="10"
                                        Header="Time" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!--  CRUD buttons  -->
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <Button
                                    Width="45"
                                    Padding="5,3"
                                    Command="{Binding AddCommand}"
                                    Content="Add"
                                    FontSize="10" />
                                <Button
                                    Width="45"
                                    Padding="5,3"
                                    Command="{Binding EditCommand}"
                                    Content="Edit"
                                    FontSize="10"
                                    IsEnabled="{Binding SelectedCommitment, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <Button
                                    Width="55"
                                    Padding="5,3"
                                    Command="{Binding DeleteCommand}"
                                    Content="Delete"
                                    FontSize="10"
                                    IsEnabled="{Binding SelectedCommitment, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            </StackPanel>

                            <!--  Error message  -->
                            <TextBlock
                                FontSize="8"
                                Foreground="{StaticResource TextError}"
                                IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Text="{Binding LastErrorMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!--  RIGHT COLUMN: Workload History header  -->
        <Border
            Grid.Row="0"
            Grid.Column="1"
            Padding="8,12"
            Background="{StaticResource SurfaceBackground}"
            IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="18"
                FontWeight="Bold"
                Foreground="{StaticResource TextMuted}"
                Text="Workload History" />
        </Border>

        <!--  RIGHT COLUMN: Workload History content  -->
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Background="{StaticResource SurfaceBackground}"
            IsVisible="{Binding SelectedInstructor, Converter={x:Static ObjectConverters.IsNotNull}}">
            <v:WorkloadHistoryView DataContext="{Binding WorkloadHistoryVm}" />
        </Border>

    </Grid>
</UserControl>
