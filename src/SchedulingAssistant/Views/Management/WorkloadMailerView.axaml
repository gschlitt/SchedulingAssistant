<UserControl
	x:Class="SchedulingAssistant.Views.Management.WorkloadMailerView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
	x:CompileBindings="False"
	x:DataType="vm:WorkloadMailerViewModel">

	<!--
		The flyout contains two panels driven by a MailerStep state machine:
		IsSetup   = true  →  Setup panel  (choose AY, semesters, instructors, edit template)
		IsSending = true  →  Sending panel (preview and open each email one at a time)
		IsDone    = true  →  Done message
	-->

	<Grid Width="760" Margin="16,0">

		<!--
			═══════════════════════════════════════════════════════════════════
			STEP 1 — Setup
			════════════════════════════════════════════════════════════════
		-->
		<Grid
			ColumnDefinitions="260,16,*"
			IsVisible="{Binding IsSetup}"
			RowDefinitions="Auto,6,Auto,12,Auto,8,*">

			<!--  ── Title row (spans all columns) ───────────────────────────  -->
			<TextBlock
				Grid.Row="0"
				Grid.Column="0"
				Grid.ColumnSpan="3"
				FontSize="{StaticResource FontSizeLarge}"
				FontWeight="SemiBold"
				Text="Workload Mailer" />

			<!--  ── Description banner (spans all columns) ───────────────────  -->
			<Border
				Grid.Row="2"
				Grid.Column="0"
				Grid.ColumnSpan="3"
				Padding="0,8"
				Background="{StaticResource FilterBarBackground}"
				CornerRadius="3">
				<TextBlock
					FontSize="{StaticResource FontSizeNormal}"
					Text="Automatically create emails detailing an instructor's workload for an academic year. You can edit the email as you wish using the placeholders, and save it as a template for future use. The resource uses the default email client you have set on your computer."
					TextWrapping="Wrap" />
			</Border>

			<!--  ── Left column: Semester + Instructor selectors ────────────  -->
			<StackPanel
				Grid.Row="4"
				Grid.RowSpan="3"
				Grid.Column="0"
				Spacing="10">

				<!--  Academic Year  -->
				<TextBlock
					FontSize="{StaticResource FontSizeNormal}"
					FontWeight="SemiBold"
					Text="Academic Year" />
				<ComboBox
					HorizontalAlignment="Stretch"
					DisplayMemberBinding="{Binding Name}"
					FontSize="11"
					ItemsSource="{Binding AcademicYears}"
					SelectedItem="{Binding SelectedAcademicYear, Mode=TwoWay}" />

				<!--  Semesters  -->
				<TextBlock
					Margin="0,4,0,0"
					FontSize="{StaticResource FontSizeNormal}"
					FontWeight="SemiBold"
					Text="Semesters" />
				<Border
					Padding="6"
					Background="{StaticResource FilterBarBackground}"
					CornerRadius="3">
					<ItemsControl ItemsSource="{Binding SemesterItems}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<CheckBox
									Padding="2,2"
									Content="{Binding DisplayName}"
									FontSize="11"
									IsChecked="{Binding IsSelected, Mode=TwoWay}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Border>

				<!--  Instructors  -->
				<DockPanel Margin="0,4,0,0">
					<TextBlock
						VerticalAlignment="Center"
						DockPanel.Dock="Left"
						FontSize="{StaticResource FontSizeNormal}"
						FontWeight="SemiBold"
						Text="Instructors" />
					<StackPanel
						HorizontalAlignment="Right"
						DockPanel.Dock="Right"
						Orientation="Horizontal"
						Spacing="4">
						<Button
							Padding="5,1"
							Command="{Binding SelectAllInstructorsCommand}"
							Content="All"
							FontSize="{StaticResource FontSizeNormal}" />
						<Button
							Padding="5,1"
							Command="{Binding DeselectAllInstructorsCommand}"
							Content="None"
							FontSize="{StaticResource FontSizeNormal}" />
					</StackPanel>
				</DockPanel>
				<Border
					MaxHeight="240"
					Padding="6"
					Background="{StaticResource FilterBarBackground}"
					CornerRadius="3">
					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding InstructorItems}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<CheckBox
										Padding="2,1"
										FontSize="{StaticResource FontSizeSmall}"
										IsChecked="{Binding IsSelected, Mode=TwoWay}"
										IsEnabled="{Binding HasEmail}">
										<CheckBox.Content>
											<StackPanel Orientation="Horizontal" Spacing="6">
												<TextBlock FontSize="{StaticResource FontSizeSmall}" Text="{Binding DisplayName}" />
												<TextBlock
													FontSize="{StaticResource FontSizeSmall}"
													Foreground="{StaticResource TextPrimary}"
													Text="{Binding EmailDisplay}" />
											</StackPanel>
										</CheckBox.Content>
									</CheckBox>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Border>

			</StackPanel>

			<!--  ── Right column: Template editor ──────────────────────────  -->
			<StackPanel
				Grid.Row="4"
				Grid.RowSpan="3"
				Grid.Column="2"
				Spacing="8">

				<!--  Placeholder legend  -->
				<Border
					Padding="8,6"
					Background="{StaticResource FilterBarBackground}"
					CornerRadius="3">
					<StackPanel Spacing="3">
						<TextBlock
							FontSize="{StaticResource FontSizeNormal}"
							FontWeight="SemiBold"
							Text="Available placeholders:" />
						<TextBlock
							FontSize="{StaticResource FontSizeNormal}"
							Foreground="{StaticResource TextSecondary}"
							Text="{}{FirstName}  {LastName}  {AcademicYear}  {Semester}  {Workload}" />
					</StackPanel>
				</Border>

				<!--  Subject  -->
				<TextBlock
					FontSize="11"
					FontWeight="SemiBold"
					Text="Email Subject" />
				<TextBox
					FontSize="11"
					Text="{Binding SubjectTemplate, Mode=TwoWay}"
					PlaceholderText="e.g. Your Workload — {AcademicYear} {Semester}" />

				<!--  Body  -->
				<TextBlock
					FontSize="11"
					FontWeight="SemiBold"
					Text="Email Body" />
				<TextBox
					Height="320"
					VerticalContentAlignment="Top"
					AcceptsReturn="True"
					FontFamily="Courier New, Consolas, monospace"
					FontSize="11"
					Text="{Binding BodyTemplate, Mode=TwoWay}"
					TextWrapping="Wrap" />

				<!--  Save template + Begin  -->
				<DockPanel Margin="0,4,0,0">
					<Button
						Padding="10,5"
						Command="{Binding SaveTemplateCommand}"
						Content="Save Template"
						DockPanel.Dock="Left"
						FontSize="11" />
					<Button
						Padding="12,5"
						HorizontalAlignment="Right"
						Command="{Binding BeginSendingCommand}"
						Content="Begin Sending →"
						DockPanel.Dock="Right"
						FontSize="11"
						FontWeight="SemiBold" />
				</DockPanel>

			</StackPanel>

		</Grid>

		<!--
			═══════════════════════════════════════════════════════════════════
			STEP 2 — Sending
			════════════════════════════════════════════════════════════════
		-->
		<Grid IsVisible="{Binding IsSending}" RowDefinitions="Auto,12,Auto,8,Auto,8,*,12,Auto">

			<!--  Progress  -->
			<TextBlock
				Grid.Row="0"
				FontSize="12"
				FontWeight="SemiBold"
				Text="{Binding ProgressText}" />

			<!--  Instructor name + email  -->
			<StackPanel
				Grid.Row="2"
				Orientation="Horizontal"
				Spacing="12">
				<TextBlock
					FontSize="12"
					FontWeight="SemiBold"
					Text="{Binding CurrentInstructorName}" />
				<TextBlock
					FontSize="12"
					Foreground="{StaticResource TextSecondary}"
					Text="{Binding CurrentEmail}" />
			</StackPanel>

			<!--  Subject (editable)  -->
			<TextBox
				Grid.Row="4"
				FontSize="11"
				Text="{Binding RenderedSubject, Mode=TwoWay}"
				PlaceholderText="Subject" />

			<!--  Body (editable)  -->
			<TextBox
				Grid.Row="6"
				Height="320"
				VerticalContentAlignment="Top"
				AcceptsReturn="True"
				FontFamily="Courier New, Consolas, monospace"
				FontSize="11"
				Text="{Binding RenderedBody, Mode=TwoWay}"
				TextWrapping="Wrap" />

			<!--  Action buttons  -->
			<StackPanel
				Grid.Row="8"
				HorizontalAlignment="Right"
				Orientation="Horizontal"
				Spacing="8">
				<Button
					Padding="10,5"
					Background="Transparent"
					Command="{Binding BackToSetupCommand}"
					Content="← Back to Setup"
					FontSize="11" />
				<Button
					Padding="10,5"
					Command="{Binding SkipCommand}"
					Content="Skip"
					FontSize="11" />
				<Button
					Padding="12,5"
					Command="{Binding OpenInMailCommand}"
					Content="Open in Mail →"
					FontSize="11"
					FontWeight="SemiBold" />
			</StackPanel>

		</Grid>

		<!--
			═══════════════════════════════════════════════════════════════════
			STEP 3 — Done
			════════════════════════════════════════════════════════════════
		-->
		<StackPanel
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			IsVisible="{Binding IsDone}"
			Spacing="12">
			<TextBlock
				HorizontalAlignment="Center"
				FontSize="16"
				FontWeight="SemiBold"
				Text="All done!" />
			<TextBlock
				HorizontalAlignment="Center"
				FontSize="12"
				Foreground="{StaticResource TextSecondary}"
				Text="All emails have been opened in your mail client." />
			<Button
				Padding="12,5"
				HorizontalAlignment="Center"
				Command="{Binding BackToSetupCommand}"
				Content="Back to Setup"
				FontSize="11" />
		</StackPanel>

	</Grid>

</UserControl>
