<UserControl
    x:Class="SchedulingAssistant.Views.Management.SectionListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:models="using:SchedulingAssistant.Models"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    b:LostFocusForwardBehavior.Command="{Binding CommitEditSectionCodeCommand}"
    b:LostFocusForwardBehavior.TargetName="SectionCodeBox"
    x:CompileBindings="False"
    x:DataType="vm:SectionListViewModel">

    <UserControl.Styles>
        <!--  Section list: selected item uses the shared SelectedSectionColor so it matches the grid tile  -->
        <Style Selector="ListBox.SectionList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TileFillSelected}" />
        </Style>
        <Style Selector="ListBox.SectionList ListBoxItem:pointerover:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource TileFillSelected}" />
        </Style>

        <!--  Compact popup trigger button: looks like a bordered label, toggles popup open/closed  -->
        <Style Selector="ToggleButton.EditorPopupTrigger">
            <Setter Property="Background" Value="{StaticResource FilterExpanderContent}" />
            <Setter Property="BorderBrush" Value="{StaticResource SubduedBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
            <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:pointerover">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:checked">
            <Setter Property="Background" Value="{StaticResource FilterExpanderBorder}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!--  Shared template for the inline edit form, used for both Add and Edit  -->
        <DataTemplate x:Key="InlineEditFormTemplate" DataType="{x:Type vm:SectionEditViewModel}">
            <StackPanel Spacing="4">

                <!--  Save / Cancel (top)  -->
                <StackPanel
                    Margin="0,0,0,2"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Button
                        Padding="6,2"
                        Command="{Binding SaveCommand}"
                        Content="Save"
                        FontSize="10" />
                    <Button
                        Padding="6,2"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        FontSize="10" />
                </StackPanel>

                <!--  Subject + Course Number + Campus + Section Code + Section Type side by side  -->
                <Grid Margin="0,0,0,0" ColumnDefinitions="100,80,Auto,80,90">
                    <!--  Subject dropdown  -->
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Subject" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            DisplayMemberBinding="{Binding CalendarAbbreviation}"
                            FontSize="11"
                            ItemsSource="{Binding Subjects}"
                            SelectedItem="{Binding SelectedSubject}" />
                    </StackPanel>

                    <!--  Course Number dropdown (filtered by subject)  -->
                    <StackPanel Grid.Column="1" Margin="0,0,4,0">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Course #" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            FontSize="11"
                            IsEnabled="{Binding HasAvailableCourseNumbers}"
                            ItemsSource="{Binding CourseNumbers}"
                            SelectedItem="{Binding SelectedCourseNumber}" />
                    </StackPanel>

                    <!--
                        Section Prefix shortcut (optional; auto-fills the Section Code with the
                        next available integer slot for the chosen prefix, and sets the campus)
                    -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,4,0"
                        IsEnabled="{Binding IsSectionCodeEnabled}">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Prefix" />
                        <ComboBox
                            MinWidth="80"
                            HorizontalAlignment="Stretch"
                            DisplayMemberBinding="{Binding Label}"
                            FontSize="11"
                            ItemsSource="{Binding PrefixOptions}"
                            SelectedItem="{Binding SelectedPrefixOption}" />
                    </StackPanel>

                    <!--  Section Code  -->
                    <StackPanel Grid.Column="3" Margin="0,0,4,0">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Section Code" />
                        <TextBox
                            x:Name="SectionCodeBox"
                            Height="24"
                            FontSize="11"
                            IsEnabled="{Binding IsSectionCodeEnabled}"
                            Text="{Binding SectionCode}" />
                        <TextBlock
                            Margin="0,1,0,0"
                            FontSize="9"
                            Foreground="{StaticResource TextValidationError}"
                            IsVisible="{Binding SectionCodeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Text="{Binding SectionCodeError}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <!--  Section Type  -->
                    <StackPanel Grid.Column="4" IsEnabled="{Binding AreOtherFieldsEnabled}">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Section Type" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            DisplayMemberBinding="{Binding Name}"
                            FontSize="11"
                            ItemsSource="{Binding SectionTypes}"
                            SelectedValue="{Binding SelectedSectionTypeId}"
                            SelectedValueBinding="{Binding Id}" />
                    </StackPanel>
                </Grid>

                <!--  Fields below Course+Code are disabled until course and unique code are committed  -->
                <StackPanel IsEnabled="{Binding AreOtherFieldsEnabled}" Spacing="0">

                    <!--  Schedule  -->
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextLabel}"
                        Text="Schedule" />
                    <ItemsControl ItemsSource="{Binding Meetings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SectionMeetingViewModel}">
                                <Border
                                    Margin="0,0,0,4"
                                    Padding="5,4"
                                    BorderBrush="{StaticResource SubduedBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">

                                    <!--
                                        Columns: Day=80, Length=80, Start=80, Freq=90, MtgType=70, Room=80, ✕=24
                                        Row 0: column headers. Row 1: controls. Row 2: custom-weeks input,
                                        shown only when Frequency="Custom". Row 2 occupies only col 3 so the
                                        Freq ComboBox (row 1, col 3) and the Weeks TextBox (row 2, col 3)
                                        share the same column width automatically.
                                    -->
                                    <Grid ColumnDefinitions="80,80,80,90,70,80,24" RowDefinitions="Auto,Auto,Auto">

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,2,1"
                                            FontSize="9"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="Day" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="2,0,2,1"
                                            FontSize="9"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="Length" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="2"
                                            Margin="2,0,2,1"
                                            FontSize="9"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="Start" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="3"
                                            Margin="2,0,2,1"
                                            FontSize="9"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="Freq" />
                                        <!--  "Mtg Type" stacked  -->
                                        <StackPanel
                                            Grid.Row="0"
                                            Grid.Column="4"
                                            Margin="2,0,2,1"
                                            Orientation="Vertical"
                                            Spacing="0">
                                            <TextBlock
                                                FontSize="9"
                                                Foreground="{StaticResource TextMuted}"
                                                LineHeight="10"
                                                Text="Mtg" />
                                            <TextBlock
                                                FontSize="9"
                                                Foreground="{StaticResource TextMuted}"
                                                LineHeight="10"
                                                Text="Type" />
                                        </StackPanel>
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="5"
                                            Margin="2,0,2,1"
                                            FontSize="9"
                                            Foreground="{StaticResource TextMuted}"
                                            Text="Room" />

                                        <!--  Day  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            ItemsSource="{Binding AvailableDays}"
                                            SelectedValue="{Binding SelectedDay}"
                                            SelectedValueBinding="{Binding Day}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:DayOption}">
                                                    <TextBlock FontSize="11" Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!--  Length  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="2,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            ItemsSource="{Binding AvailableBlockLengths}"
                                            PlaceholderText="—"
                                            SelectedItem="{Binding SelectedBlockLength}" />

                                        <!--  Start  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            Margin="2,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            ItemsSource="{Binding AvailableStartTimes}"
                                            PlaceholderText="—"
                                            SelectedItem="{Binding SelectedStartTime}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11" Text="{Binding Converter={StaticResource MinutesToTimeConverter}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!--  Frequency  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="3"
                                            Margin="2,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            ItemsSource="{Binding FrequencyOptions}"
                                            PlaceholderText="—"
                                            SelectedItem="{Binding SelectedFrequencyOption}" />

                                        <!--
                                            Custom weeks input — sits directly below the Frequency ComboBox in the
                                            same column (col 3), so both controls share the same width. Only
                                            visible when Frequency="Custom".
                                        -->
                                        <StackPanel
                                            Grid.Row="2"
                                            Grid.Column="3"
                                            Margin="2,2,2,0"
                                            IsVisible="{Binding IsCustomFrequency}">
                                            <TextBox
                                                Padding="3,1"
                                                HorizontalAlignment="Stretch"
                                                FontSize="11"
                                                Text="{Binding CustomWeeksText}"
                                                ToolTip.Tip="{Binding CustomWeeksError}"
                                                Watermark="e.g. 1,3,5" />
                                            <TextBlock
                                                FontSize="9"
                                                Foreground="{StaticResource ErrorText}"
                                                IsVisible="{Binding CustomWeeksError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Text="{Binding CustomWeeksError}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!--  Meeting Type  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="4"
                                            Margin="2,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            DisplayMemberBinding="{Binding Name}"
                                            FontSize="11"
                                            ItemsSource="{Binding MeetingTypes}"
                                            SelectedValue="{Binding SelectedMeetingTypeId}"
                                            SelectedValueBinding="{Binding Id}" />

                                        <!--  Room  -->
                                        <ComboBox
                                            Grid.Row="1"
                                            Grid.Column="5"
                                            Margin="2,0,2,0"
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            ItemsSource="{Binding Rooms}"
                                            SelectedValue="{Binding SelectedRoomId}"
                                            SelectedValueBinding="{Binding Id}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:Room}">
                                                    <TextBlock FontSize="11">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} {1}">
                                                                <Binding Path="Building" />
                                                                <Binding Path="RoomNumber" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <!--  Remove button  -->
                                        <Button
                                            Grid.Row="1"
                                            Grid.Column="6"
                                            Margin="2,0,0,0"
                                            Padding="3,2"
                                            Command="{Binding $parent[ItemsControl].DataContext.RemoveMeetingCommand}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            FontSize="10"
                                            ToolTip.Tip="Remove" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel
                        Margin="0,2,0,0"
                        IsEnabled="{Binding AreOtherFieldsEnabled}"
                        Orientation="Horizontal"
                        Spacing="4">
                        <Button
                            Padding="4,2"
                            Command="{Binding AddMeetingCommand}"
                            Content="+ meeting"
                            FontSize="10" />
                        <Button
                            Padding="4,2"
                            Command="{Binding ApplyPattern1Command}"
                            Content="{Binding Pattern1Label}"
                            FontSize="10"
                            IsVisible="{Binding HasPattern1}"
                            ToolTip.Tip="Apply Pattern 1" />
                        <Button
                            Padding="4,2"
                            Command="{Binding ApplyPattern2Command}"
                            Content="{Binding Pattern2Label}"
                            FontSize="10"
                            IsVisible="{Binding HasPattern2}"
                            ToolTip.Tip="Apply Pattern 2" />
                        <Button
                            Padding="4,2"
                            Command="{Binding ApplyPattern3Command}"
                            Content="{Binding Pattern3Label}"
                            FontSize="10"
                            IsVisible="{Binding HasPattern3}"
                            ToolTip.Tip="Apply Pattern 3" />
                        <Button
                            Padding="4,2"
                            Command="{Binding ApplyPattern4Command}"
                            Content="{Binding Pattern4Label}"
                            FontSize="10"
                            IsVisible="{Binding HasPattern4}"
                            ToolTip.Tip="Apply Pattern 4" />
                        <Button
                            Padding="4,2"
                            Command="{Binding ApplyPattern5Command}"
                            Content="{Binding Pattern5Label}"
                            FontSize="10"
                            IsVisible="{Binding HasPattern5}"
                            ToolTip.Tip="Apply Pattern 5" />
                    </StackPanel>

                    <!--  Instructor + Tags side by side  -->
                    <Grid
                        MaxWidth="400"
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        ColumnDefinitions="*,4,*">

                        <!--  Left: Instructor multi-select popup  -->
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Margin="0,0,0,1"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextLabel}"
                                Text="Instructor(s)" />
                            <Panel>
                                <ToggleButton
                                    x:Name="InstructorToggle"
                                    Classes="EditorPopupTrigger"
                                    Content="{Binding InstructorSummary}" />
                                <Popup
                                    IsLightDismissEnabled="True"
                                    IsOpen="{Binding #InstructorToggle.IsChecked, Mode=TwoWay}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding #InstructorToggle}">
                                    <Border
                                        MinWidth="160"
                                        MaxHeight="160"
                                        Padding="2"
                                        Background="{StaticResource FilterExpanderContent}"
                                        BorderBrush="{StaticResource SubduedBorder}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl Margin="2" ItemsSource="{Binding InstructorSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:InstructorSelectionViewModel}">
                                                        <Grid Margin="2,1,2,1" ColumnDefinitions="Auto,*,Auto">
                                                            <CheckBox
                                                                Grid.Column="0"
                                                                Padding="2,1"
                                                                VerticalAlignment="Center"
                                                                Content="{Binding DisplayName}"
                                                                FontSize="11"
                                                                IsChecked="{Binding IsSelected}" />
                                                            <TextBox
                                                                Grid.Column="2"
                                                                Width="36"
                                                                Height="22"
                                                                Margin="3,0,0,0"
                                                                Padding="3,1"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                IsVisible="{Binding IsSelected}"
                                                                Text="{Binding WorkloadText}"
                                                                TextAlignment="Center"
                                                                Watermark="1" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Panel>
                        </StackPanel>

                        <!--  Right: Tags popup  -->
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Margin="0,0,0,1"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextLabel}"
                                Text="Tags" />
                            <Panel>
                                <ToggleButton
                                    x:Name="TagsToggle"
                                    Classes="EditorPopupTrigger"
                                    Content="{Binding TagSummary}" />
                                <Popup
                                    IsLightDismissEnabled="True"
                                    IsOpen="{Binding #TagsToggle.IsChecked, Mode=TwoWay}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding #TagsToggle}">
                                    <Border
                                        MinWidth="140"
                                        MaxHeight="160"
                                        Padding="2"
                                        Background="{StaticResource FilterExpanderContent}"
                                        BorderBrush="{StaticResource SubduedBorder}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl Margin="2" ItemsSource="{Binding TagSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:TagSelectionViewModel}">
                                                        <CheckBox
                                                            Margin="2,0,0,1"
                                                            Padding="2,1"
                                                            Content="{Binding Value.Name}"
                                                            FontSize="11"
                                                            IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Panel>
                        </StackPanel>

                    </Grid>

                    <!--  Reserve Codes + Resources side by side  -->
                    <Grid
                        MaxWidth="400"
                        Margin="0,4,0,0"
                        HorizontalAlignment="Left"
                        ColumnDefinitions="*,4,*">

                        <!--  Left: Reserve Codes popup  -->
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Margin="0,0,0,1"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextLabel}"
                                Text="Reserve Codes" />
                            <Panel>
                                <ToggleButton
                                    x:Name="ReservesToggle"
                                    Classes="EditorPopupTrigger"
                                    Content="{Binding ReserveSummary}" />
                                <Popup
                                    IsLightDismissEnabled="True"
                                    IsOpen="{Binding #ReservesToggle.IsChecked, Mode=TwoWay}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding #ReservesToggle}">
                                    <Border
                                        MinWidth="160"
                                        MaxHeight="180"
                                        Padding="2"
                                        Background="{StaticResource FilterExpanderContent}"
                                        BorderBrush="{StaticResource SubduedBorder}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl Margin="2" ItemsSource="{Binding ReserveSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ReserveSelectionViewModel}">
                                                        <Grid Margin="2,1,2,1" ColumnDefinitions="Auto,*,Auto">
                                                            <CheckBox
                                                                Grid.Column="0"
                                                                Padding="2,1"
                                                                VerticalAlignment="Center"
                                                                Content="{Binding Value.Name}"
                                                                FontSize="11"
                                                                IsChecked="{Binding IsSelected}" />
                                                            <TextBox
                                                                Grid.Column="2"
                                                                Width="44"
                                                                Height="22"
                                                                Margin="6,0,0,0"
                                                                Padding="3,1"
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                IsVisible="{Binding IsSelected}"
                                                                Text="{Binding CodeText}"
                                                                TextAlignment="Center"
                                                                Watermark="#" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Panel>
                        </StackPanel>

                        <!--  Right: Resources popup  -->
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Margin="0,0,0,1"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextLabel}"
                                Text="Resources" />
                            <Panel>
                                <ToggleButton
                                    x:Name="ResourcesToggle"
                                    Classes="EditorPopupTrigger"
                                    Content="{Binding ResourceSummary}" />
                                <Popup
                                    IsLightDismissEnabled="True"
                                    IsOpen="{Binding #ResourcesToggle.IsChecked, Mode=TwoWay}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding #ResourcesToggle}">
                                    <Border
                                        MinWidth="140"
                                        MaxHeight="160"
                                        Padding="2"
                                        Background="{StaticResource FilterExpanderContent}"
                                        BorderBrush="{StaticResource SubduedBorder}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl Margin="2" ItemsSource="{Binding ResourceSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ResourceSelectionViewModel}">
                                                        <CheckBox
                                                            Margin="2,0,0,1"
                                                            Padding="2,1"
                                                            Content="{Binding Value.Name}"
                                                            FontSize="11"
                                                            IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Panel>
                        </StackPanel>

                    </Grid>

                    <!--  Notes (at bottom)  -->
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="10"
                        Foreground="{StaticResource TextLabel}"
                        Text="Notes" />
                    <TextBox
                        Height="44"
                        Padding="4,2"
                        AcceptsReturn="True"
                        FontSize="11"
                        Text="{Binding Notes}" />

                </StackPanel>
                <!--  End AreOtherFieldsEnabled gate  -->

                <!--  Save / Cancel (bottom)  -->
                <StackPanel
                    Margin="0,6,0,0"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Button
                        Padding="8,3"
                        Command="{Binding SaveCommand}"
                        Content="Save"
                        FontSize="11" />
                    <Button
                        Padding="8,3"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        FontSize="11" />
                </StackPanel>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Error banner (only visible when LastErrorMessage is set)  -->
        <Border
            Grid.Row="0"
            Padding="6,3"
            Background="{StaticResource ErrorBannerBackground}"
            BorderBrush="{StaticResource ErrorBannerBorder}"
            BorderThickness="0,0,0,1"
            IsVisible="{Binding LastErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <DockPanel>
                <Button
                    Padding="3,1"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding DismissErrorCommand}"
                    Content="✕"
                    DockPanel.Dock="Right"
                    FontSize="10"
                    ToolTip.Tip="Dismiss" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="10"
                    Foreground="{StaticResource ErrorBannerText}"
                    Text="{Binding LastErrorMessage}"
                    TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!--  Add-to-semester prompt — shown in multi-semester mode when Add is clicked  -->
        <Border
            Grid.Row="1"
            Padding="8,6"
            Background="{StaticResource EditorBackground}"
            BorderBrush="{StaticResource EditorBorder}"
            BorderThickness="0,0,0,1"
            IsVisible="{Binding IsAddSemesterPromptVisible}">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimary}"
                    Text="Add section to which semester?" />
                <ItemsControl ItemsSource="{Binding AddSemesterOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Margin="0,2,0,0"
                                Padding="8,4"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="{Binding BannerBackground}"
                                Command="{Binding $parent[UserControl].DataContext.AddToSemesterCommand}"
                                CommandParameter="{Binding SemesterId}"
                                Content="{Binding SemesterName}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    Margin="0,2,0,0"
                    Padding="8,3"
                    HorizontalAlignment="Left"
                    Command="{Binding CancelAddPromptCommand}"
                    Content="Cancel" />
            </StackPanel>
        </Border>

        <ScrollViewer
            x:Name="ListScrollViewer"
            Grid.Row="2"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Stretch">

                <!--
                    DoubleTapCommandBehavior replaces the OnListBoxDoubleTapped code-behind handler.
                    Double-tapping an item sets it as SelectedItem (Avalonia's single-select model
                    does this on pointer-down) and then invokes EditCommand, which opens the inline
                    editor for the currently selected item.
                -->
                <ListBox
                    x:Name="SectionListBox"
                    Classes="SectionList"
                    b:DoubleTapCommandBehavior.Command="{Binding EditCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding SectionItems}"
                    SelectedItem="{Binding SelectedItem}"
                    SelectionMode="Single">
                    <ListBox.ItemContainerTheme>
                        <ControlTheme BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </ControlTheme>
                    </ListBox.ItemContainerTheme>
                    <ListBox.DataTemplates>

                        <!--
                            Semester group banner — shown at the top of each semester's section group.
                            IsHitTestVisible="False" on the content prevents the click from registering
                            as a meaningful "item selection", though the ListBoxItem container itself
                            may still become highlighted; the ViewModel ignores banner selections.
                        -->
                        <DataTemplate DataType="{x:Type vm:SemesterBannerViewModel}">
                            <Border
                                Padding="10,5,10,5"
                                Background="{Binding BannerBackground}"
                                BorderBrush="{Binding BannerBorder}"
                                BorderThickness="0,0,0,2"
                                IsHitTestVisible="False">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="{Binding SemesterName}" />
                            </Border>
                        </DataTemplate>

                        <!--  Section card with multi-semester left border indicator  -->
                        <DataTemplate DataType="{x:Type vm:SectionListItemViewModel}">
                            <!--  Filter highlight: 3 pt FilterColor border when section matches active grid filter  -->
                            <Border
                                BorderBrush="{StaticResource FilterColorBrush}"
                                BorderThickness="{Binding IsFilterHighlighted, Converter={StaticResource FilterBorderThicknessConverter}}">
                                <Border BorderBrush="{StaticResource ItemSeparator}" BorderThickness="0,0,0,2">
                                <!--  Multi-semester indicator: narrow left border in semester color  -->
                                <Border
                                    Padding="0"
                                    BorderBrush="{Binding SemesterLeftBorderBrush}"
                                    BorderThickness="{Binding $parent[UserControl].DataContext.IsMultiSemesterMode, Converter={StaticResource MultiSemesterLeftBorderThicknessConverter}}">
                                    <StackPanel>

                                        <!--  Summary row (hidden while section is being created)  -->
                                        <StackPanel IsVisible="{Binding !IsBeingCreated}" Spacing="1">
                                            <!--  Row 1: Toggle + Heading + Instructor + Section Type + Property indicators  -->
                                            <Grid
                                                Margin="2,3,6,2"
                                                VerticalAlignment="Center"
                                                ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                                <!--  Collapse/expand toggle  -->
                                                <Button
                                                    Grid.Column="0"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    Padding="2,0"
                                                    VerticalAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding ToggleCollapsedCommand}"
                                                    Cursor="Hand">
                                                    <Panel>
                                                        <TextBlock
                                                            FontSize="8"
                                                            Foreground="{StaticResource TextLabel}"
                                                            IsVisible="{Binding IsCollapsed}"
                                                            Text="▶" />
                                                        <TextBlock
                                                            FontSize="8"
                                                            Foreground="{StaticResource TextLabel}"
                                                            IsVisible="{Binding !IsCollapsed}"
                                                            Text="▼" />
                                                    </Panel>
                                                </Button>
                                                <!--  Heading  -->
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="2,0,8,0"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Heading}" />
                                                <!--  Instructor  -->
                                                <TextBlock
                                                    Grid.Column="2"
                                                    FontSize="12"
                                                    IsVisible="{Binding InstructorHeaderLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Text="{Binding InstructorHeaderLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <!--  Section Type  -->
                                                <TextBlock
                                                    Grid.Column="3"
                                                    Margin="8,0,8,0"
                                                    FontSize="12"
                                                    IsVisible="{Binding SectionTypeName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Text="{Binding SectionTypeName}" />
                                                <!--  Right: property indicators (when collapsed)  -->
                                                <StackPanel
                                                    Grid.Column="4"
                                                    IsVisible="{Binding IsCollapsed}"
                                                    Orientation="Horizontal"
                                                    Spacing="3">
                                                    <TextBlock
                                                        FontSize="9"
                                                        IsVisible="{Binding TagLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        Text="🏷️" />
                                                    <TextBlock
                                                        FontSize="9"
                                                        IsVisible="{Binding ReserveLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        Text="📋" />
                                                    <TextBlock
                                                        FontSize="9"
                                                        IsVisible="{Binding ResourceLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        Text="📦" />
                                                </StackPanel>
                                            </Grid>

                                            <!--  Row 2: Meetings (when not collapsed)  -->
                                            <StackPanel
                                                Margin="2,2,6,4"
                                                Grid.IsSharedSizeScope="True"
                                                IsVisible="{Binding !IsCollapsed}"
                                                Spacing="0">
                                                <!--
                                                    Headers: Day, Start, End, Freq (col 3, hidden when all meetings are weekly), Room, Type.
                                                    Col 3 uses SharedSizeGroup="FreqCol" so it grows to match the widest frequency
                                                    value across all data rows; when the header is hidden (all-weekly sections),
                                                    there is no content in the group and the column collapses to zero.
                                                -->
                                                <Grid Margin="0,0,0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="45" />
                                                        <ColumnDefinition Width="45" />
                                                        <ColumnDefinition Width="45" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="FreqCol" />
                                                        <ColumnDefinition Width="45" />
                                                        <ColumnDefinition Width="45" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Margin="2,0,2,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        Text="Day" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Margin="2,0,2,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        Text="Start" />
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="2,0,2,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        Text="End" />
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        Margin="2,0,2,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        IsVisible="{Binding HasNonDefaultFrequency}"
                                                        Text="Freq" />
                                                    <TextBlock
                                                        Grid.Column="4"
                                                        Margin="2,0,2,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        Text="Room" />
                                                    <TextBlock
                                                        Grid.Column="5"
                                                        Margin="2,0,0,0"
                                                        FontSize="9"
                                                        Foreground="{StaticResource TextMuted}"
                                                        Text="Type" />
                                                </Grid>

                                                <!--  Meetings  -->
                                                <ItemsControl ItemsSource="{Binding MeetingDetails}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:MeetingDisplayInfo}">
                                                            <Grid Margin="0,1,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="45" />
                                                                    <ColumnDefinition Width="45" />
                                                                    <ColumnDefinition Width="45" />
                                                                    <!--  Col 3: same SharedSizeGroup as the header — auto-sizes to the widest frequency value across all rows  -->
                                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FreqCol" />
                                                                    <ColumnDefinition Width="45" />
                                                                    <ColumnDefinition Width="45" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock
                                                                    Grid.Column="0"
                                                                    Margin="2,1,2,1"
                                                                    FontSize="11"
                                                                    Text="{Binding Day}" />
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Margin="2,1,2,1"
                                                                    FontSize="11"
                                                                    Text="{Binding StartTime}" />
                                                                <TextBlock
                                                                    Grid.Column="2"
                                                                    Margin="2,1,2,1"
                                                                    FontSize="11"
                                                                    Text="{Binding EndTime}" />
                                                                <TextBlock
                                                                    Grid.Column="3"
                                                                    Margin="2,1,2,1"
                                                                    FontSize="11"
                                                                    Text="{Binding Frequency}" />
                                                                <TextBlock
                                                                    Grid.Column="4"
                                                                    Margin="2,1,2,1"
                                                                    FontSize="11"
                                                                    Text="{Binding Room}" />
                                                                <TextBlock
                                                                    Grid.Column="5"
                                                                    Margin="2,1,0,1"
                                                                    FontSize="11"
                                                                    Text="{Binding MeetingType}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!--  Row 3: Properties (tags, reserves, resources) when not collapsed  -->
                                            <StackPanel
                                                Margin="2,0,6,4"
                                                IsVisible="{Binding !IsCollapsed}"
                                                Spacing="2">
                                                <!--  Tags  -->
                                                <StackPanel
                                                    IsVisible="{Binding TagLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="🏷️" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Text="{Binding TagLine}" />
                                                </StackPanel>
                                                <!--  Reserves  -->
                                                <StackPanel
                                                    IsVisible="{Binding ReserveLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="📋" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Text="{Binding ReserveLine}" />
                                                </StackPanel>
                                                <!--  Resources  -->
                                                <StackPanel
                                                    IsVisible="{Binding ResourceLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        Text="📦" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Text="{Binding ResourceLine}" />
                                                </StackPanel>
                                                <!--  Notes  -->
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="11"
                                                    IsVisible="{Binding NoteLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    MaxLines="1"
                                                    Text="{Binding NoteLine}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!--  Inline edit form — shown when this item IsExpanded  -->
                                        <Border
                                            Padding="8,6,6,8"
                                            Background="{StaticResource EditorBackground}"
                                            BorderBrush="{StaticResource EditorBorder}"
                                            BorderThickness="3,0,0,0"
                                            IsVisible="{Binding IsExpanded}">
                                            <ContentControl Content="{Binding $parent[UserControl].DataContext.EditVm}" ContentTemplate="{StaticResource InlineEditFormTemplate}" />
                                        </Border>

                                    </StackPanel>
                                </Border>
                            </Border>
                            </Border>
                        </DataTemplate>

                    </ListBox.DataTemplates>
                </ListBox>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
