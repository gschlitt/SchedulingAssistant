<UserControl
    x:Class="SchedulingAssistant.Views.Management.CourseListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:v="using:SchedulingAssistant.Views.Management"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:CourseListViewModel">

    <UserControl.Styles>
        <Style Selector="DataGrid DataGridRow:selected">
            <Setter Property="Background" Value="#FFE0E0E0" />
            <!--  shaded gray  -->
        </Style>
    </UserControl.Styles>

    <Border Padding="0,0,12,12">
        <Grid Margin="10,0" ColumnDefinitions="Auto,1,*">

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  LEFT COLUMN: COURSES AND SUBJECTS (SCROLLABLE)  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,12,0" Spacing="12">


                    <!--  Advisory message when no subjects exist  -->
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource TextMuted}"
                        IsVisible="{Binding HasSubjects, Converter={x:Static BoolConverters.Not}}"
                        Text="Create at least one subject first" />

                    <!--  Course edit form  -->
                    <ContentControl Content="{Binding EditVm}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:CourseEditViewModel}">
                                <StackPanel HorizontalAlignment="Left" Spacing="12">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="{Binding FormTitle}" />

                                    <TextBlock Text="Subject" />
                                    <ComboBox
                                        DisplayMemberBinding="{Binding Name}"
                                        ItemsSource="{Binding Subjects}"
                                        SelectedItem="{Binding SelectedSubject}" />

                                    <!--  Course number + auto-suggested level side by side  -->
                                    <TextBlock Text="Course number (e.g. 101 or 111LAB, max 8 characters)" />
                                    <Grid ColumnDefinitions="*,12,Auto,8,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding CourseNumber}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Text="Level" />
                                        <ComboBox
                                            Grid.Column="4"
                                            MinWidth="72"
                                            ItemsSource="{Binding LevelOptions}"
                                            PlaceholderText="—"
                                            SelectedItem="{Binding SelectedLevel}" />
                                    </Grid>

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Calendar Code (computed)" />
                                    <TextBlock
                                        Padding="8,4"
                                        Background="{StaticResource SubtleBackground}"
                                        Text="{Binding ComputedCalendarCode}" />

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{StaticResource TextError}"
                                        IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                        Text="{Binding ValidationError}" />

                                    <TextBlock Text="Title" />
                                    <TextBox Text="{Binding CourseTitle}" />

                                    <!--  Tag multi-select  -->
                                    <Expander
                                        Padding="0"
                                        Header="{Binding TagSummary, StringFormat='Tags: {0}'}"
                                        IsVisible="{Binding TagSelections.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <ItemsControl Margin="4,4,0,0" ItemsSource="{Binding TagSelections}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TagSelectionViewModel}">
                                                    <CheckBox
                                                        Margin="0,2"
                                                        Content="{Binding Value.Name}"
                                                        IsChecked="{Binding IsSelected}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>

                                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Command="{Binding SaveCommand}" Content="Done" />
                                        <Button Command="{Binding CancelCommand}" Content="Cancel" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!--  Show only active courses toggle  -->
                    <CheckBox
                        Content="Show only active courses"
                        FontSize="10"
                        IsChecked="{Binding ShowOnlyActive}"
                        IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}" />

                    <!--  Course list — columns auto-size to content  -->

                    <!--
                        HorizontalAlignment="Left" prevents the DataGrid from stretching beyond
                        its content width, which would create a phantom filler column. All columns
                        use Width="Auto" so they size to their actual content. The outer grid column
                        is Width="Auto" and naturally sizes to whatever the DataGrid needs.
                    -->
                    <DataGrid
                        MaxHeight="300"
                        HorizontalAlignment="Left"
                        AutoGenerateColumns="False"
                        CanUserSortColumns="False"
                        IsReadOnly="True"
                        IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                        ItemsSource="{Binding Courses}"
                        ScrollViewer.AllowAutoHide="False"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        SelectedItem="{Binding SelectedCourse}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="Auto"
                                MinWidth="90"
                                Binding="{Binding CalendarCode}"
                                Header="Calendar Code" />
                            <DataGridTextColumn
                                Width="Auto"
                                MinWidth="130"
                                Binding="{Binding Title}"
                                Header="Title" />
                            <DataGridTextColumn
                                Width="Auto"
                                MinWidth="80"
                                Binding="{Binding TagSummary}"
                                Header="Tags" />
                            <DataGridCheckBoxColumn
                                Width="Auto"
                                MinWidth="55"
                                Binding="{Binding IsActive}"
                                Header="Active" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--  Course toolbar — IsEnabled gates the entire group in read-only mode  -->
                    <StackPanel
                        IsEnabled="{Binding IsWriteEnabled}"
                        IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Command="{Binding AddCommand}"
                            Content="Add Course"
                            IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button
                            Command="{Binding EditCommand}"
                            Content="Edit Course"
                            IsEnabled="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button
                            Command="{Binding DeleteCommand}"
                            Content="Delete Course"
                            IsEnabled="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>

                    <!--  ═══════════════════════════════════════════════════════════  -->
                    <!--  SUBJECTS SECTION  -->
                    <!--  ═══════════════════════════════════════════════════════════  -->

                    <StackPanel Margin="0,20,0,0" Spacing="12">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Subjects" />

                        <!--  Subject edit form  -->
                        <ContentControl Content="{Binding SubjectEditVm}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:SubjectEditViewModel}">
                                    <StackPanel
                                        MaxWidth="400"
                                        HorizontalAlignment="Left"
                                        Spacing="12">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Title}" />

                                        <TextBlock Text="Name (e.g. Mathematics)" />
                                        <TextBox Text="{Binding Name}" />

                                        <TextBlock Text="Calendar Abbreviation (e.g. MATH)" />
                                        <TextBox Text="{Binding CalendarAbbreviation}" />

                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextError}"
                                            IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                            Text="{Binding ValidationError}" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Command="{Binding SaveCommand}" Content="Done" />
                                            <Button Command="{Binding CancelCommand}" Content="Cancel" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                        <!--  Subject list  -->
                        <DataGrid
                            MaxHeight="200"
                            HorizontalAlignment="Left"
                            AutoGenerateColumns="False"
                            CanUserSortColumns="True"
                            IsReadOnly="True"
                            IsVisible="{Binding SubjectEditVm, Converter={x:Static ObjectConverters.IsNull}}"
                            ItemsSource="{Binding Subjects}"
                            SelectedItem="{Binding SelectedSubject}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="Auto"
                                    MinWidth="160"
                                    Binding="{Binding Name}"
                                    Header="Name" />
                                <DataGridTextColumn
                                    Width="Auto"
                                    MinWidth="160"
                                    Binding="{Binding CalendarAbbreviation}"
                                    Header="Calendar Abbreviation" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!--  Subject toolbar  -->
                        <StackPanel
                            IsVisible="{Binding SubjectEditVm, Converter={x:Static ObjectConverters.IsNull}}"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button Command="{Binding AddSubjectCommand}" Content="Add Subject" />
                            <Button
                                Command="{Binding EditSubjectCommand}"
                                Content="Edit Subject"
                                IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <Button
                                Command="{Binding DeleteSubjectCommand}"
                                Content="Delete Subject"
                                IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  VERTICAL SEPARATOR  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <Border Grid.Column="1" Background="{StaticResource InlineListBorder}" />

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  RIGHT COLUMN: COURSE HISTORY  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <StackPanel
                Grid.Column="2"
                Margin="12,0,0,0"
                Spacing="8">
                <TextBlock
                    Margin="0,0,0,4"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Course History" />

                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource TextMuted}"
                    IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNull}}"
                    Text="Select a course to view its history" />

                <ContentControl Content="{Binding CourseHistoryVm}" IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:CourseHistoryViewModel}">
                            <v:CourseHistoryView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </StackPanel>

        </Grid>
    </Border>

</UserControl>
