<UserControl
    x:Class="SchedulingAssistant.Views.Management.CourseListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:v="using:SchedulingAssistant.Views.Management"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:CourseListViewModel">

    <UserControl.Styles>
        <Style Selector="DataGrid DataGridRow:selected">
            <Setter Property="Background" Value="#FFE0E0E0" />
            <!--  shaded gray  -->
        </Style>
    </UserControl.Styles>

    <Border Padding="0,0,12,12">
        <Grid
            ColumnDefinitions="Auto,1,*"
            Margin="10,0"
            HorizontalAlignment="Stretch">

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  LEFT COLUMN: COURSES AND SUBJECTS (SCROLLABLE)  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel
                    Margin="0,0,12,0"
                    Spacing="12">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Courses" />

                <!--  Advisory message when no subjects exist  -->
                <TextBlock
                    FontSize="13"
                    Foreground="#888888"
                    IsVisible="{Binding HasSubjects, Converter={x:Static BoolConverters.Not}}"
                    Text="Create at least one subject first" />

                <!--  Course edit form  -->
                <ContentControl Content="{Binding EditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:CourseEditViewModel}">
                            <StackPanel
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                Spacing="12">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{Binding FormTitle}" />

                                <TextBlock Text="Subject" />
                                <ComboBox
                                    DisplayMemberBinding="{Binding Name}"
                                    ItemsSource="{Binding Subjects}"
                                    SelectedItem="{Binding SelectedSubject}" />

                                <TextBlock Text="Course Number (3 digits, e.g. 101)" />
                                <TextBox Text="{Binding CourseNumber}" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="#666"
                                    Text="Calendar Code (computed)" />
                                <TextBlock
                                    Padding="8,4"
                                    Background="#F5F5F5"
                                    Text="{Binding ComputedCalendarCode}" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Text="{Binding ValidationError}" />

                                <TextBlock Text="Title" />
                                <TextBox Text="{Binding CourseTitle}" />

                                <CheckBox Content="Active" IsChecked="{Binding IsActive}" />

                                <!--  Tags multi-select (popup trigger pattern)  -->
                                <TextBlock Text="Tags" />
                                <Panel>
                                    <ToggleButton
                                        x:Name="CourseTagsToggle"
                                        Classes="EditorPopupTrigger"
                                        Content="{Binding TagSummary}" />
                                    <Popup
                                        IsLightDismissEnabled="True"
                                        IsOpen="{Binding #CourseTagsToggle.IsChecked, Mode=TwoWay}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding #CourseTagsToggle}">
                                        <Border
                                            MinWidth="160"
                                            MaxHeight="200"
                                            Padding="2"
                                            Background="{StaticResource FilterExpanderContent}"
                                            BorderBrush="{StaticResource SubduedBorder}"
                                            BorderThickness="1"
                                            CornerRadius="3">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl Margin="2" ItemsSource="{Binding TagSelections}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:TagSelectionViewModel}">
                                                            <CheckBox
                                                                Margin="2,0,0,1"
                                                                Padding="2,1"
                                                                Content="{Binding Value.Name}"
                                                                FontSize="12"
                                                                IsChecked="{Binding IsSelected}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Panel>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding SaveCommand}" Content="Save" />
                                    <Button Command="{Binding CancelCommand}" Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!--  Course list  -->

                <DataGrid
                    Height="250"
                    MaxHeight="250"
                    AutoGenerateColumns="False"
                    CanUserSortColumns="True"
                    IsReadOnly="True"
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    ItemsSource="{Binding Courses}"
                    ScrollViewer.AllowAutoHide="False"
                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                    SelectedItem="{Binding SelectedCourse}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="Auto"
                            MinWidth="130"
                            Binding="{Binding CalendarCode}"
                            Header="Code" />
                        <DataGridTextColumn
                            Width="Auto"
                            MinWidth="160"
                            Binding="{Binding Title}"
                            Header="Title" />
                        <DataGridCheckBoxColumn
                            Width="Auto"
                            MinWidth="55"
                            Binding="{Binding IsActive}"
                            Header="Active" />
                        <DataGridTextColumn
                            Width="Auto"
                            MinWidth="80"
                            Binding="{Binding TagSummary}"
                            Header="Tags" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Course toolbar  -->
                <StackPanel
                    IsVisible="{Binding EditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{Binding AddCommand}"
                        Content="Add Course"
                        IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <Button
                        Command="{Binding EditCommand}"
                        Content="Edit Course"
                        IsEnabled="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <Button
                        Command="{Binding DeleteCommand}"
                        Content="Delete Course"
                        IsEnabled="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}" />
                </StackPanel>

                <!--  ═══════════════════════════════════════════════════════════  -->
                <!--  SUBJECTS SECTION  -->
                <!--  ═══════════════════════════════════════════════════════════  -->

                <StackPanel Margin="0,20,0,0" Spacing="12">
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Subjects" />

                <!--  Subject edit form  -->
                <ContentControl Content="{Binding SubjectEditVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:SubjectEditViewModel}">
                            <StackPanel
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                Spacing="12">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{Binding Title}" />

                                <TextBlock Text="Name (e.g. Mathematics)" />
                                <TextBox Text="{Binding Name}" />

                                <TextBlock Text="Calendar Abbreviation (e.g. MATH)" />
                                <TextBox Text="{Binding CalendarAbbreviation}" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextError}"
                                    IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    Text="{Binding ValidationError}" />

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding SaveCommand}" Content="Save" />
                                    <Button Command="{Binding CancelCommand}" Content="Cancel" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!--  Subject list  -->
                <DataGrid
                    MaxHeight="200"
                    AutoGenerateColumns="False"
                    CanUserSortColumns="True"
                    IsReadOnly="True"
                    IsVisible="{Binding SubjectEditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    ItemsSource="{Binding Subjects}"
                    SelectedItem="{Binding SelectedSubject}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding Name}"
                            Header="Name" />
                        <DataGridTextColumn
                            Width="150"
                            Binding="{Binding CalendarAbbreviation}"
                            Header="Calendar Abbreviation" />
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Subject toolbar  -->
                <StackPanel
                    IsVisible="{Binding SubjectEditVm, Converter={x:Static ObjectConverters.IsNull}}"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button Command="{Binding AddSubjectCommand}" Content="Add Subject" />
                    <Button
                        Command="{Binding EditSubjectCommand}"
                        Content="Edit Subject"
                        IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    <Button
                        Command="{Binding DeleteSubjectCommand}"
                        Content="Delete Subject"
                        IsEnabled="{Binding SelectedSubject, Converter={x:Static ObjectConverters.IsNotNull}}" />
                </StackPanel>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  VERTICAL SEPARATOR  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <Border
                Grid.Column="1"
                Background="#CCCCCC" />

            <!--  ═══════════════════════════════════════════════════════════  -->
            <!--  RIGHT COLUMN: COURSE HISTORY  -->
            <!--  ═══════════════════════════════════════════════════════════  -->

            <StackPanel
                Grid.Column="2"
                Margin="12,0,0,0"
                Spacing="8">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Margin="0,0,0,4"
                    Text="Course History" />

                <TextBlock
                    FontSize="12"
                    Foreground="#888888"
                    IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNull}}"
                    Text="Select a course to view its history" />

                <ContentControl
                    Content="{Binding CourseHistoryVm}"
                    IsVisible="{Binding SelectedCourse, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:CourseHistoryViewModel}">
                            <v:CourseHistoryView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </StackPanel>

        </Grid>
    </Border>

</UserControl>
