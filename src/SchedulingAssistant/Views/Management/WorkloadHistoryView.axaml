<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
             x:Class="SchedulingAssistant.Views.Management.WorkloadHistoryView"
             x:DataType="vm:WorkloadHistoryViewModel"
             x:CompileBindings="False"
             Background="{StaticResource AppBackground}">

    <ScrollViewer>
        <Border Padding="8,4">
            <StackPanel Spacing="4">
                <!-- Expand / Collapse all -->
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button MinWidth="0" MinHeight="0" Padding="4,1"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding ExpandAllCommand}"
                            Content="▼" FontSize="9" ToolTip.Tip="Expand all" />
                    <Button MinWidth="0" MinHeight="0" Padding="4,1"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding CollapseAllCommand}"
                            Content="▶" FontSize="9" ToolTip.Tip="Collapse all" />
                </StackPanel>
                <!-- Academic Years as Expanders -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkloadHistoryItemViewModel}">
                            <Expander Header="{Binding Display}" FontSize="11" FontWeight="SemiBold"
                                      IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Padding="0,2">
                                <!-- Semesters -->
                                <ItemsControl ItemsSource="{Binding Children}" Margin="12,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:WorkloadHistoryItemViewModel}">
                                            <StackPanel Spacing="2">
                                                <!-- Semester -->
                                                <TextBlock Text="{Binding Display}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0" />

                                                <!-- Sections and Releases -->
                                                <ItemsControl ItemsSource="{Binding Children}" Margin="12,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:WorkloadHistoryItemViewModel}">
                                                            <TextBlock Text="{Binding Display}" FontSize="9"
                                                                       Foreground="{StaticResource TextMuted}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>

</UserControl>
