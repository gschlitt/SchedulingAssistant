<UserControl
    x:Class="SchedulingAssistant.Views.Management.MeetingListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:models="using:SchedulingAssistant.Models"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:MeetingListViewModel">

    <UserControl.Styles>
        <!--  Remove the default ListBox border and background  -->
        <Style Selector="ListBox.MeetingList">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!--  Card hover / selected styles  -->
        <Style Selector="ListBox.MeetingList ListBoxItem:selected Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource MeetingTile}" />
        </Style>
        <Style Selector="ListBox.MeetingList ListBoxItem:pointerover:selected Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource MeetingTile}" />
        </Style>
        <Style Selector="ListBox.MeetingList ListBoxItem:pointerover:not(:selected) Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource SubtleBackground}" />
        </Style>

        <!--  Compact editor popup trigger (reused from SectionListView style)  -->
        <Style Selector="ToggleButton.EditorPopupTrigger">
            <Setter Property="Background" Value="{StaticResource FilterExpanderContent}" />
            <Setter Property="BorderBrush" Value="{StaticResource SubduedBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:pointerover">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:checked">
            <Setter Property="Background" Value="{StaticResource FilterExpanderBorder}" />
        </Style>
        <!--  Prevent string content from wrapping inside narrow popup-trigger columns  -->
        <Style Selector="ToggleButton.EditorPopupTrigger TextBlock">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!--  Inline edit form template (shown when IsExpanded=true and EditVm matches)  -->
        <DataTemplate x:Key="InlineMeetingEditTemplate" DataType="{x:Type vm:MeetingEditViewModel}">
            <StackPanel Margin="0,4,0,0" Spacing="4">

                <!--  Save / Cancel  -->
                <StackPanel
                    Margin="0,0,0,2"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Button
                        Padding="6,2"
                        Command="{Binding SaveCommand}"
                        Content="Apply"
                        FontSize="11" />
                    <Button
                        Padding="6,2"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        FontSize="11" />
                </StackPanel>

                <!--  Title  -->
                <StackPanel Spacing="1">
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource TextLabel}"
                        Text="Title" />
                    <TextBox
                        Height="24"
                        FontSize="12"
                        Text="{Binding Title}"
                        Watermark="Meeting title…" />
                </StackPanel>

                <!--  Schedule slots  -->
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextLabel}"
                    Text="Schedule" />
                <ItemsControl ItemsSource="{Binding Slots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SectionMeetingViewModel}">
                            <Border
                                Margin="0,0,0,4"
                                Padding="5,4"
                                Background="{StaticResource SubtleBackground}"
                                CornerRadius="3">
                                <!--
                                    Col 3 hosts both the Frequency ComboBox (row 1) and the Custom
                                    weeks TextBox (row 2, shown only when Frequency="Custom"). Row 2
                                    occupies only col 3 so both controls share the same column width.
                                -->
                                <Grid ColumnDefinitions="80,80,80,90,70,80,24" RowDefinitions="Auto,Auto,Auto">

                                    <!--  Column headers  -->
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Day" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="2,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Start" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="2,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Length" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="3"
                                        Margin="2,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Freq" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="4"
                                        Margin="2,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Mtg Type" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="5"
                                        Margin="2,0,2,1"
                                        FontSize="9"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="Room" />

                                    <!--  Day  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        FontSize="11"
                                        ItemsSource="{Binding AvailableDays}"
                                        SelectedValue="{Binding SelectedDay}"
                                        SelectedValueBinding="{Binding Day}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayOption}">
                                                <TextBlock FontSize="11" Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!--  Start  -->
                                    <AutoCompleteBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        b:LostFocusCommandBehavior.Command="{Binding CommitStartTimeCommand}"
                                        b:OpenDropDownOnFocusBehavior.IsEnabled="True"
                                        CornerRadius="4"
                                        FilterMode="None"
                                        FontSize="11"
                                        ItemsSource="{Binding AllStartTimeStrings}"
                                        MinimumPrefixLength="0"
                                        Text="{Binding StartTimeText, Mode=TwoWay}"
                                        Watermark="HHMM" />

                                    <!--  Length  -->
                                    <AutoCompleteBox
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        b:LostFocusCommandBehavior.Command="{Binding CommitBlockLengthCommand}"
                                        b:OpenDropDownOnFocusBehavior.IsEnabled="True"
                                        CornerRadius="4"
                                        FilterMode="None"
                                        FontSize="11"
                                        ItemsSource="{Binding AvailableBlockLengthStrings}"
                                        MinimumPrefixLength="0"
                                        Text="{Binding BlockLengthText, Mode=TwoWay}"
                                        Watermark="{Binding BlockLengthWatermark}" />

                                    <!--  Frequency  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        FontSize="11"
                                        ItemsSource="{Binding FrequencyOptions}"
                                        PlaceholderText="—"
                                        SelectedItem="{Binding SelectedFrequencyOption}" />

                                    <!--
                                        Custom weeks input — sits directly below the Frequency ComboBox
                                        in the same column (col 3). Only visible when Frequency="Custom".
                                    -->
                                    <StackPanel
                                        Grid.Row="2"
                                        Grid.Column="3"
                                        Margin="2,2,2,0"
                                        IsVisible="{Binding IsCustomFrequency}">
                                        <TextBox
                                            Padding="3,1"
                                            HorizontalAlignment="Stretch"
                                            FontSize="11"
                                            Text="{Binding CustomWeeksText}"
                                            ToolTip.Tip="{Binding CustomWeeksError}"
                                            Watermark="e.g. 1,3,5" />
                                        <TextBlock
                                            FontSize="9"
                                            Foreground="{StaticResource ErrorText}"
                                            IsVisible="{Binding CustomWeeksError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Text="{Binding CustomWeeksError}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!--  Meeting Type  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        DisplayMemberBinding="{Binding Name}"
                                        FontSize="11"
                                        ItemsSource="{Binding MeetingTypes}"
                                        SelectedValue="{Binding SelectedMeetingTypeId}"
                                        SelectedValueBinding="{Binding Id}" />

                                    <!--  Room  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="5"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        FontSize="11"
                                        ItemsSource="{Binding Rooms}"
                                        SelectedValue="{Binding SelectedRoomId}"
                                        SelectedValueBinding="{Binding Id}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:Room}">
                                                <TextBlock FontSize="11" Text="{Binding Building}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!--  Remove slot button  -->
                                    <Button
                                        Grid.Row="1"
                                        Grid.Column="6"
                                        Width="20"
                                        Padding="2,1"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DataContext.RemoveSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="✕"
                                        FontSize="9"
                                        ToolTip.Tip="Remove slot" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    Padding="4,1"
                    Command="{Binding AddSlotCommand}"
                    Content="+ Add Meeting Time"
                    FontSize="12" />

                <!--  Attendees / Tags / Resources popup pickers  -->
                <Grid Margin="0,6,0,0" ColumnDefinitions="*,4,*,4,*">

                    <!--  Attendees popup  -->
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextLabel}"
                            Text="Attendees" />
                        <Panel>
                            <ToggleButton
                                x:Name="AttendeesToggle"
                                Classes="EditorPopupTrigger"
                                Content="{Binding AttendeeSummary}">
                                <ToolTip.Tip>
                                    <TextBlock
                                        MaxWidth="300"
                                        Text="{Binding AttendeeSummaryTooltip}"
                                        TextWrapping="Wrap" />
                                </ToolTip.Tip>
                            </ToggleButton>
                            <Popup
                                IsLightDismissEnabled="True"
                                IsOpen="{Binding #AttendeesToggle.IsChecked, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding #AttendeesToggle}">
                                <Border
                                    MinWidth="160"
                                    MaxHeight="200"
                                    Padding="2"
                                    Background="{StaticResource FilterExpanderContent}"
                                    BorderBrush="{StaticResource SubduedBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <!--  Preset sentinels (Everyone / No one / per-staff-type)  -->
                                            <ItemsControl Margin="2,2,2,0" ItemsSource="{Binding SentinelPresets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:AttendeeSentinelViewModel}">
                                                        <CheckBox
                                                            Margin="2,0,0,1"
                                                            Padding="2,1"
                                                            Background="{StaticResource FilterSentinelBackground}"
                                                            Content="{Binding DisplayName}"
                                                            FontSize="11"
                                                            FontStyle="Italic"
                                                            IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!--  Divider between presets and individuals  -->
                                            <Border
                                                Height="1"
                                                Margin="4,3"
                                                Background="{StaticResource SubduedBorder}" />
                                            <!--  Individual instructors  -->
                                            <ItemsControl Margin="2" ItemsSource="{Binding AttendeeSelections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:InstructorSelectionViewModel}">
                                                        <CheckBox
                                                            Margin="2,0,0,1"
                                                            Padding="2,1"
                                                            Content="{Binding DisplayName}"
                                                            FontSize="11"
                                                            IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>

                    <!--  Tags popup  -->
                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextLabel}"
                            Text="Tags" />
                        <Panel>
                            <ToggleButton
                                x:Name="TagsToggle"
                                Classes="EditorPopupTrigger"
                                Content="{Binding TagSummary}" />
                            <Popup
                                IsLightDismissEnabled="True"
                                IsOpen="{Binding #TagsToggle.IsChecked, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding #TagsToggle}">
                                <Border
                                    MinWidth="140"
                                    MaxHeight="160"
                                    Padding="2"
                                    Background="{StaticResource FilterExpanderContent}"
                                    BorderBrush="{StaticResource SubduedBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl Margin="2" ItemsSource="{Binding TagSelections}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TagSelectionViewModel}">
                                                    <CheckBox
                                                        Margin="2,0,0,1"
                                                        Padding="2,1"
                                                        Content="{Binding Value.Name}"
                                                        FontSize="11"
                                                        IsChecked="{Binding IsSelected}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>

                    <!--  Resources popup  -->
                    <StackPanel Grid.Column="4">
                        <TextBlock
                            Margin="0,0,0,1"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextLabel}"
                            Text="Resources" />
                        <Panel>
                            <ToggleButton
                                x:Name="ResourcesToggle"
                                Classes="EditorPopupTrigger"
                                Content="{Binding ResourceSummary}" />
                            <Popup
                                IsLightDismissEnabled="True"
                                IsOpen="{Binding #ResourcesToggle.IsChecked, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding #ResourcesToggle}">
                                <Border
                                    MinWidth="140"
                                    MaxHeight="160"
                                    Padding="2"
                                    Background="{StaticResource FilterExpanderContent}"
                                    BorderBrush="{StaticResource SubduedBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl Margin="2" ItemsSource="{Binding ResourceSelections}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ResourceSelectionViewModel}">
                                                    <CheckBox
                                                        Margin="2,0,0,1"
                                                        Padding="2,1"
                                                        Content="{Binding Value.Name}"
                                                        FontSize="11"
                                                        IsChecked="{Binding IsSelected}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </StackPanel>
                </Grid>

                <!--  Campus  -->
                <StackPanel Margin="0,6,0,0">
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource TextLabel}"
                        Text="Campus" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        CornerRadius="4"
                        DisplayMemberBinding="{Binding Name}"
                        FontSize="11"
                        ItemsSource="{Binding Campuses}"
                        SelectedValue="{Binding SelectedCampusId}"
                        SelectedValueBinding="{Binding Id}" />
                </StackPanel>

                <!--  Notes  -->
                <StackPanel Margin="0,6,0,0" Spacing="1">
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource TextLabel}"
                        Text="Notes" />
                    <TextBox
                        Height="48"
                        AcceptsReturn="True"
                        FontSize="11"
                        Text="{Binding Notes}"
                        TextWrapping="Wrap" />
                </StackPanel>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Main content: list of event cards  -->
    <DockPanel>

        <!--  Add-to-semester prompt — shown in multi-semester mode when Add is clicked  -->
        <Border
            Padding="8,6"
            Background="{StaticResource EditorBackground}"
            BorderBrush="{StaticResource EditorBorder}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top"
            IsVisible="{Binding IsAddSemesterPromptVisible}">
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimary}"
                    Text="Add event to which semester?" />
                <ItemsControl ItemsSource="{Binding AddSemesterOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Margin="0,2,0,0"
                                Padding="8,4"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Command="{Binding $parent[UserControl].DataContext.AddToSemesterCommand}"
                                CommandParameter="{Binding SemesterId}"
                                Content="{Binding SemesterName}">
                                <Button.Background>
                                    <MultiBinding Converter="{StaticResource SemesterBackgroundBrushConverter}">
                                        <Binding Path="SemesterName" />
                                        <Binding Path="SemesterColor" />
                                    </MultiBinding>
                                </Button.Background>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    Margin="0,2,0,0"
                    Padding="8,3"
                    HorizontalAlignment="Left"
                    Command="{Binding CancelAddPromptCommand}"
                    Content="Cancel" />
            </StackPanel>
        </Border>

        <!--  Empty-state hint  -->
        <TextBlock
            Margin="8,4"
            DockPanel.Dock="Bottom"
            FontSize="11"
            Foreground="{StaticResource TextFaint}"
            IsVisible="{Binding Items.Count, Converter={x:Static ObjectConverters.IsNull}}"
            Text="No events for this semester." />

        <ListBox
            Margin="5,0"
            b:DoubleTapCommandBehavior.Command="{Binding EditCommand}"
            b:EnterKeyCommandBehavior.Command="{Binding EditCommand}"
            Classes="MeetingList"
            DockPanel.Dock="Top"
            ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionMode="Single">

            <!--
                Non-virtualizing panel so that inline editors can expand cards to
                arbitrary heights without layout being clamped by a recycling host.
                Matches the approach used in SectionListView.
            -->
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerTheme>
                <ControlTheme BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,0" />
                </ControlTheme>
            </ListBox.ItemContainerTheme>

            <ListBox.DataTemplates>

                <!--
                    Semester group banner — shown at the top of each semester's event group.
                    IsHitTestVisible="False" on the content prevents the click from registering
                    as a meaningful item selection; the ViewModel ignores banner selections.
                -->
                <DataTemplate DataType="{x:Type vm:SemesterBannerViewModel}">
                    <Border
                        Margin="0,10,0,4"
                        Padding="10,4"
                        BorderThickness="0"
                        CornerRadius="4"
                        IsHitTestVisible="False">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource SemesterBorderBrushConverter}">
                                <Binding Path="SemesterName" />
                                <Binding Path="SemesterColor" />
                            </MultiBinding>
                        </Border.Background>
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding SemesterName}" />
                    </Border>
                </DataTemplate>

                <!--  Event card with multi-semester left border indicator  -->
                <DataTemplate DataType="{x:Type vm:MeetingListItemViewModel}">
                    <Border
                        Margin="0,2,0,2"
                        Padding="0"
                        Background="{StaticResource MeetingTile}"
                        BorderThickness="{Binding $parent[UserControl].DataContext.IsMultiSemesterMode, Converter={StaticResource MultiSemesterLeftBorderThicknessConverter}}"
                        BoxShadow="{StaticResource PanelBoxShadow}"
                        Classes="MeetingCard"
                        CornerRadius="4">
                        <Border.BorderBrush>
                            <MultiBinding Converter="{StaticResource SemesterBorderBrushConverter}">
                                <Binding Path="SemesterName" />
                                <Binding Path="SemesterColor" />
                            </MultiBinding>
                        </Border.BorderBrush>
                        <StackPanel Margin="6,4,6,4" Spacing="0">

                            <!--
                                Card summary — hidden for placeholder cards (IsBeingCreated=true)
                                so the editor form fills the card without a blank heading above it.
                                Matches the pattern used in SectionListView.
                            -->
                            <StackPanel IsVisible="{Binding !IsBeingCreated}" Spacing="0">

                                <!--  Card heading: title  -->
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{Binding Title}"
                                    TextTrimming="CharacterEllipsis" />

                                <!--  Schedule lines  -->
                                <ItemsControl
                                    Margin="0,1,0,0"
                                    FontSize="10"
                                    Foreground="{StaticResource TextSubdued}"
                                    ItemsSource="{Binding ScheduleLines}" />

                                <!--  Attendees (capped at 5 names; hover tooltip shows all when truncated)  -->
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{StaticResource TextFaint}"
                                    IsVisible="{Binding AttendeeLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Text="{Binding AttendeeLineBrief}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTip.IsEnabled="{Binding AttendeeTooltip, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <ToolTip.Tip>
                                        <TextBlock
                                            MaxWidth="300"
                                            Text="{Binding AttendeeTooltip}"
                                            TextWrapping="Wrap" />
                                    </ToolTip.Tip>
                                </TextBlock>

                                <!--  Tags  -->
                                <StackPanel
                                    IsVisible="{Binding TagLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <svg:Svg
                                        Width="12"
                                        Height="12"
                                        VerticalAlignment="Center"
                                        Path="/Assets/tag.svg" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{StaticResource TextFaint}"
                                        Text="{Binding TagLine}" />
                                </StackPanel>

                                <!--  Resources  -->
                                <StackPanel
                                    IsVisible="{Binding ResourceLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Orientation="Horizontal"
                                    Spacing="4">
                                    <svg:Svg
                                        Width="12"
                                        Height="12"
                                        VerticalAlignment="Center"
                                        Path="/Assets/tools.svg" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Foreground="{StaticResource TextFaint}"
                                        Text="{Binding ResourceLine}" />
                                </StackPanel>

                            </StackPanel>

                            <!--  Inline editor (shown when this card is being edited)  -->
                            <ContentControl
                                Content="{Binding DataContext.EditVm, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                ContentTemplate="{StaticResource InlineMeetingEditTemplate}"
                                IsVisible="{Binding IsExpanded}" />

                        </StackPanel>
                    </Border>
                </DataTemplate>

            </ListBox.DataTemplates>
        </ListBox>

    </DockPanel>

</UserControl>
