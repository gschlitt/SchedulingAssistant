<UserControl
    x:Class="SchedulingAssistant.Views.Management.MeetingListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:models="using:SchedulingAssistant.Models"
    xmlns:vm="using:SchedulingAssistant.ViewModels.Management"
    x:CompileBindings="False"
    x:DataType="vm:MeetingListViewModel">

    <UserControl.Styles>
        <!--  Card hover / selected styles  -->
        <Style Selector="ListBox.MeetingList ListBoxItem:selected Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource TileFillSelected}" />
        </Style>
        <Style Selector="ListBox.MeetingList ListBoxItem:pointerover:selected Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource TileFillSelected}" />
        </Style>
        <Style Selector="ListBox.MeetingList ListBoxItem:pointerover:not(:selected) Border.MeetingCard">
            <Setter Property="Background" Value="{StaticResource SubtleBackground}" />
        </Style>

        <!--  Compact editor popup trigger (reused from SectionListView style)  -->
        <Style Selector="ToggleButton.EditorPopupTrigger">
            <Setter Property="Background" Value="{StaticResource FilterExpanderContent}" />
            <Setter Property="BorderBrush" Value="{StaticResource SubduedBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource TextFaint}" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:pointerover">
            <Setter Property="Background" Value="{StaticResource ButtonHover}" />
        </Style>
        <Style Selector="ToggleButton.EditorPopupTrigger:checked">
            <Setter Property="Background" Value="{StaticResource FilterExpanderBorder}" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!--  Inline edit form template (shown when IsExpanded=true and EditVm matches)  -->
        <DataTemplate x:Key="InlineMeetingEditTemplate" DataType="{x:Type vm:MeetingEditViewModel}">
            <StackPanel Margin="0,4,0,0" Spacing="4">

                <!--  Save / Cancel  -->
                <StackPanel
                    Margin="0,0,0,2"
                    Orientation="Horizontal"
                    Spacing="6">
                    <Button
                        Padding="6,2"
                        Command="{Binding SaveCommand}"
                        Content="Apply"
                        FontSize="10" />
                    <Button
                        Padding="6,2"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        FontSize="10" />
                </StackPanel>

                <!--  Title  -->
                <StackPanel Spacing="1">
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextLabel}"
                        Text="Title" />
                    <TextBox
                        Height="24"
                        FontSize="11"
                        Text="{Binding Title}"
                        Watermark="Meeting title…" />
                </StackPanel>

                <!--  Schedule slots  -->
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextLabel}"
                    Text="Schedule" />
                <ItemsControl ItemsSource="{Binding Slots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SectionMeetingViewModel}">
                            <Border
                                Margin="0,0,0,4"
                                Padding="5,4"
                                Background="{StaticResource SubtleBackground}"
                                CornerRadius="3">
                                <Grid ColumnDefinitions="80,80,80,70,80,24" RowDefinitions="Auto,Auto">

                                    <!--  Column headers  -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,2,1" FontSize="9" Foreground="{StaticResource TextMuted}" Text="Day" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="2,0,2,1" FontSize="9" Foreground="{StaticResource TextMuted}" Text="Start" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="2,0,2,1" FontSize="9" Foreground="{StaticResource TextMuted}" Text="Length" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Margin="2,0,2,1" FontSize="9" Foreground="{StaticResource TextMuted}" Text="Room" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Margin="2,0,2,1" FontSize="9" Foreground="{StaticResource TextMuted}" Text="Mtg Type" />

                                    <!--  Day  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        FontSize="11"
                                        ItemsSource="{Binding AvailableDays}"
                                        SelectedValue="{Binding SelectedDay}"
                                        SelectedValueBinding="{Binding Day}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DayOption}">
                                                <TextBlock FontSize="11" Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!--  Start  -->
                                    <AutoCompleteBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        b:LostFocusCommandBehavior.Command="{Binding CommitStartTimeCommand}"
                                        b:OpenDropDownOnFocusBehavior.IsEnabled="True"
                                        FilterMode="None"
                                        FontSize="11"
                                        ItemsSource="{Binding AllStartTimeStrings}"
                                        MinimumPrefixLength="0"
                                        Text="{Binding StartTimeText, Mode=TwoWay}"
                                        Watermark="HHMM" />

                                    <!--  Length  -->
                                    <AutoCompleteBox
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        b:LostFocusCommandBehavior.Command="{Binding CommitBlockLengthCommand}"
                                        b:OpenDropDownOnFocusBehavior.IsEnabled="True"
                                        FilterMode="None"
                                        FontSize="11"
                                        ItemsSource="{Binding AvailableBlockLengthStrings}"
                                        MinimumPrefixLength="0"
                                        Text="{Binding BlockLengthText, Mode=TwoWay}"
                                        Watermark="hrs" />

                                    <!--  Room  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        FontSize="11"
                                        ItemsSource="{Binding Rooms}"
                                        SelectedValue="{Binding SelectedRoomId}"
                                        SelectedValueBinding="{Binding Id}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:Room}">
                                                <TextBlock FontSize="11" Text="{Binding Building}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!--  Meeting Type  -->
                                    <ComboBox
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Margin="2,0,2,0"
                                        Padding="3,1"
                                        HorizontalAlignment="Stretch"
                                        CornerRadius="4"
                                        DisplayMemberBinding="{Binding Name}"
                                        FontSize="11"
                                        ItemsSource="{Binding MeetingTypes}"
                                        SelectedValue="{Binding SelectedMeetingTypeId}"
                                        SelectedValueBinding="{Binding Id}" />

                                    <!--  Remove slot button  -->
                                    <Button
                                        Grid.Row="1"
                                        Grid.Column="5"
                                        Width="20"
                                        Padding="2,1"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DataContext.RemoveSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="✕"
                                        FontSize="9"
                                        ToolTip.Tip="Remove slot" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button
                    Padding="4,1"
                    Command="{Binding AddSlotCommand}"
                    Content="+ Add slot"
                    FontSize="10" />

                <!--  Attendees  -->
                <TextBlock
                    Margin="0,6,0,0"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextLabel}"
                    Text="Attendees" />
                <ItemsControl ItemsSource="{Binding AttendeeSelections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InstructorSelectionViewModel}">
                            <CheckBox
                                Content="{Binding DisplayName}"
                                FontSize="11"
                                IsChecked="{Binding IsSelected}"
                                Padding="4,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Campus + Tags side by side  -->
                <Grid
                    Margin="0,6,0,0"
                    ColumnDefinitions="*,*">

                    <!--  Campus  -->
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Campus" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            CornerRadius="4"
                            DisplayMemberBinding="{Binding Name}"
                            FontSize="11"
                            ItemsSource="{Binding Campuses}"
                            SelectedValue="{Binding SelectedCampusId}"
                            SelectedValueBinding="{Binding Id}" />
                    </StackPanel>

                    <!--  Tags  -->
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock
                            FontSize="10"
                            Foreground="{StaticResource TextLabel}"
                            Text="Tags" />
                        <ItemsControl ItemsSource="{Binding TagSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TagSelectionViewModel}">
                                    <CheckBox
                                        Content="{Binding Value.Name}"
                                        FontSize="11"
                                        IsChecked="{Binding IsSelected}"
                                        Padding="4,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!--  Notes  -->
                <StackPanel Margin="0,6,0,0" Spacing="1">
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextLabel}"
                        Text="Notes" />
                    <TextBox
                        Height="48"
                        AcceptsReturn="True"
                        FontSize="11"
                        Text="{Binding Notes}"
                        TextWrapping="Wrap" />
                </StackPanel>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!--  Main content: list of meeting cards  -->
    <DockPanel>

        <!--  Empty-state hint  -->
        <TextBlock
            Margin="8,4"
            DockPanel.Dock="Bottom"
            FontSize="11"
            Foreground="{StaticResource TextFaint}"
            IsVisible="{Binding Items.Count, Converter={x:Static ObjectConverters.IsNull}}"
            Text="No meetings for this semester." />

        <ListBox
            Classes="MeetingList"
            DockPanel.Dock="Top"
            ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionMode="Single">

            <ListBox.ItemContainerTheme>
                <ControlTheme BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,0" />
                </ControlTheme>
            </ListBox.ItemContainerTheme>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MeetingListItemViewModel}">
                    <Border
                        Padding="6,4"
                        Background="{StaticResource SurfaceBackground}"
                        Classes="MeetingCard"
                        CornerRadius="2">
                        <StackPanel Spacing="0">

                            <!--  Card heading: title  -->
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  Schedule lines  -->
                            <ItemsControl
                                Margin="0,1,0,0"
                                FontSize="10"
                                Foreground="{StaticResource TextSubdued}"
                                ItemsSource="{Binding ScheduleLines}" />

                            <!--  Attendees  -->
                            <TextBlock
                                FontSize="10"
                                Foreground="{StaticResource TextFaint}"
                                IsVisible="{Binding AttendeeLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Text="{Binding AttendeeLine}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  Inline editor (shown when this card is being edited)  -->
                            <ContentControl
                                IsVisible="{Binding IsExpanded}"
                                Content="{Binding DataContext.EditVm, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                ContentTemplate="{StaticResource InlineMeetingEditTemplate}" />

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>

</UserControl>
