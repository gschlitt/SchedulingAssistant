<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SchedulingAssistant.ViewModels"
             x:Class="SchedulingAssistant.Views.DebugTestDataView"
             x:DataType="vm:DebugTestDataViewModel"
             x:CompileBindings="False">

    <StackPanel Spacing="16" Margin="20">

        <!-- Exception behaviour toggle -->
        <Border BorderBrush="{StaticResource MenuBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox Content="Raise exceptions immediately (don't just log)"
                              IsChecked="{Binding ThrowOnError}"
                              FontSize="12" />
                    <Button Content="Test"
                            Command="{Binding TestThrowCommand}"
                            Padding="8,2"
                            FontSize="11"
                            ToolTip.Tip="Fires a test exception through the logger to verify the setting" />
                </StackPanel>
                <TextBlock Text="When checked, any call to LogError re-throws after writing, so exceptions surface in the debugger instead of being silently swallowed."
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{StaticResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <StackPanel Spacing="8">
            <TextBlock Text="Number of sections to generate:" FontSize="13" FontWeight="SemiBold" />
            <TextBox Text="{Binding SectionCount}"
                     PlaceholderText="Enter count (1-1000)"
                     FontSize="12" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Button Content="Generate"
                    Command="{Binding GenerateCommand}"
                    IsEnabled="{Binding !IsGenerating}"
                    MinWidth="120"
                    Padding="16,8" />
            <Button Content="Export Start Times"
                    Command="{Binding ExportStartTimesCommand}"
                    IsEnabled="{Binding !IsGenerating}"
                    MinWidth="120"
                    Padding="16,8" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    MinWidth="120"
                    Padding="16,8" />
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="{StaticResource TextFaint}" />

        <TextBlock IsVisible="{Binding IsGenerating}"
                   Text="Processing..."
                   TextAlignment="Center"
                   FontSize="12"
                   Foreground="{StaticResource TextMuted}" />
    </StackPanel>

</UserControl>
