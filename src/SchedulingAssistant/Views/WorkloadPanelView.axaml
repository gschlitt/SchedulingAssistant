<UserControl
	x:Class="SchedulingAssistant.Views.WorkloadPanelView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:conv="using:SchedulingAssistant.Converters"
	xmlns:b="using:SchedulingAssistant.Behaviors"
	x:Name="Root"
	x:CompileBindings="False">

	<UserControl.Styles>
		<!--  Section chip: light blue with raised appearance  -->
		<Style Selector="Button.chip">
			<Setter Property="Background" Value="{StaticResource TileFill}" />
			<Setter Property="CornerRadius" Value="4" />
			<Setter Property="Padding" Value="4,1" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="MinWidth" Value="0" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						BoxShadow="{StaticResource PanelBoxShadow}"
						CornerRadius="{TemplateBinding CornerRadius}">
						<ContentPresenter
							x:Name="PART_ContentPresenter"
							Margin="{TemplateBinding Padding}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Content="{TemplateBinding Content}" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<!--  Release chip: light lavender with raised appearance  -->
		<Style Selector="Button.chip.release">
			<Setter Property="Background" Value="{StaticResource ReleaseTile}" />
		</Style>
		<!--
			Hover tint on instructor cards. Targets the transparent overlay Border inside the card
			when the outer WorkloadCard Border is in :pointerover — same pattern as section cards.
		-->
		<Style Selector="Border.WorkloadCard:pointerover Border.WorkloadCardHover">
			<Setter Property="Background" Value="{StaticResource CardHoverOverlay}" />
		</Style>
		<!--  Instructor name: looks like a label but is a clickable button. Hand cursor + hover tint.  -->
		<Style Selector="Button.instructor-name">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border
						Background="{TemplateBinding Background}"
						CornerRadius="3">
						<ContentPresenter
							x:Name="PART_ContentPresenter"
							Padding="{TemplateBinding Padding}"
							HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
							VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
							Content="{TemplateBinding Content}" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="Button.instructor-name:pointerover">
			<Setter Property="Background" Value="{StaticResource CardHoverOverlay}" />
		</Style>

		<!--  Selected chip: violet border matching UserSelectedSectionBorderColor in other views  -->
		<Style Selector="Button.chip.selected">
			<Setter Property="BorderBrush" Value="{StaticResource UserSelectedSectionBorderColor}" />
			<Setter Property="BorderThickness" Value="3" />
		</Style>
		<Style Selector="Button.chip.release.selected">
			<Setter Property="BorderBrush" Value="{StaticResource UserSelectedSectionBorderColor}" />
			<Setter Property="BorderThickness" Value="2" />
		</Style>

		<!--  Note toggle: a borderless icon button that shows/hides the read-only note area.  -->
		<Style Selector="ToggleButton.note-toggle">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="MinWidth" Value="0" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="VerticalAlignment" Value="Top" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border
						Background="{TemplateBinding Background}"
						CornerRadius="3">
						<ContentPresenter
							x:Name="PART_ContentPresenter"
							Margin="{TemplateBinding Padding}"
							Content="{TemplateBinding Content}" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="ToggleButton.note-toggle:pointerover">
			<Setter Property="Background" Value="{StaticResource CardHoverOverlay}" />
		</Style>
	</UserControl.Styles>

	<Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,*,Auto" MaxWidth="550" HorizontalAlignment="Left">

		<!--  Column headers  -->
		<Border
			Grid.Row="0"
			Padding="14,0,32,0"
			Background="{StaticResource ViewHeaderBackground}"
			BorderBrush="{StaticResource InlineListBorder}"
			BorderThickness="0,0,0,1">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="150" SharedSizeGroup="NameCol" />
					<ColumnDefinition Width="18" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="35" />
					<ColumnDefinition Width="20" />
				</Grid.ColumnDefinitions>
				<TextBlock
					Grid.Column="0"
					Margin="4,3"
					FontWeight="SemiBold"
					Text="Instructor" />
				<!--  Col 1: note-icon column (no header text)  -->
				<TextBlock
					Grid.Column="2"
					Margin="4,3"
					FontWeight="SemiBold"
					Text="Workload" />
				<TextBlock
					Grid.Column="3"
					Margin="0,3"
					HorizontalAlignment="Center"
					FontWeight="SemiBold"
					Text="Sem."
					b:HelpTip.Text="Total workload for semester"/>
				<TextBlock
					Grid.Column="4"
					Margin="0,3"
					HorizontalAlignment="Center"
					FontWeight="SemiBold"
					Text="AY"
					b:HelpTip.Text="Total workload for academic year"/>
			</Grid>
		</Border>

		<!--  Scrollable data area  -->
		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="8,4">

				<!--  Error banner  -->
				<Border
					Padding="6,3"
					Background="{StaticResource NotificationWarningBackground}"
					IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
					<TextBlock
						Foreground="{StaticResource NotificationWarningText}"
						Text="{Binding LastErrorMessage}"
						TextWrapping="Wrap" />
				</Border>

				<!--  Instructor cards — same raised appearance as section cards  -->
				<ItemsControl ItemsSource="{Binding Rows}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<!--  Card:  box shadow, and rounded corners matching section cards  -->
							<Border
								Margin="0,2,0,2"
								Background="{StaticResource WorkloadTileBackground}"
								BoxShadow="{StaticResource PanelBoxShadow}"
								Classes="WorkloadCard"
								CornerRadius="4">
								<Grid>
									<Grid Margin="6,4">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="150" SharedSizeGroup="NameCol" />
											<ColumnDefinition Width="18" />
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="35" />
											<ColumnDefinition Width="20" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto" />
											<RowDefinition Height="Auto" />
										</Grid.RowDefinitions>

										<!--  Name with initials. Clickable — selects all of this instructor's sections.  -->
										<Button
											Grid.Row="0"
											Grid.Column="0"
											VerticalAlignment="Top"
											Classes="instructor-name"
											Command="{Binding DataContext.SelectInstructorSectionsCommand, ElementName=Root}"
											CommandParameter="{Binding}"
											ToolTip.Tip="Click to select all sections for this instructor">
											<TextBlock
												Margin="4,2"
												Text="{Binding NameWithInitials}"
												TextTrimming="CharacterEllipsis"
												TextWrapping="Wrap" />
										</Button>

										<!--  Note icon (single-semester mode): shown only when a non-empty note exists.
										      Toggles the read-only note area below this row.  -->
										<ToggleButton
											Grid.Row="0"
											Grid.Column="1"
											Margin="1,2,0,0"
											Classes="note-toggle"
											IsChecked="{Binding IsNoteExpanded}"
											IsVisible="{Binding HasNote}"
											ToolTip.Tip="Show/hide scheduling note">
											<Viewbox Width="13" Height="13">
												<Path
													Data="{StaticResource NoteIcon}"
													Fill="Transparent"
													Stroke="{StaticResource TextFaint}"
													StrokeThickness="1.5" />
											</Viewbox>
										</ToggleButton>

										<!--  Single-semester mode: flat chips (horizontal, wrapping)  -->
										<ItemsControl
											Grid.Row="0"
											Grid.Column="2"
											Margin="2,0"
											HorizontalAlignment="Left"
											IsVisible="{Binding IsMultiSemesterMode, Converter={x:Static BoolConverters.Not}}"
											ItemsSource="{Binding Items}">
											<ItemsControl.ItemsPanel>
												<ItemsPanelTemplate>
													<WrapPanel HorizontalAlignment="Left" Orientation="Horizontal" MaxWidth="200" />
												</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Button
														Margin="2,1"
														Classes="chip"
														Classes.release="{Binding IsRelease}"
														Classes.selected="{Binding IsSelected}"
														Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
														CommandParameter="{Binding}"
														Content="{Binding Label}" />
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>

										<!--  Multi-semester mode: grouped by semester with colored frames  -->
										<ItemsControl
											Grid.Row="0"
											Grid.Column="2"
											Grid.ColumnSpan="2"
											Margin="2,0"
											IsVisible="{Binding IsMultiSemesterMode}"
											ItemsSource="{Binding SemesterGroups}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<!--  Colored frame around this semester's chips  -->
													<Border
														Margin="0,2"
														Padding="3,2"
														BorderThickness="2"
														CornerRadius="2">
														<Border.BorderBrush>
															<MultiBinding Converter="{StaticResource SemesterBackgroundBrushConverter}">
																<Binding Path="SemesterName" />
																<Binding Path="SemesterColor" />
															</MultiBinding>
														</Border.BorderBrush>
														<!--  Inner grid: chips fill *, semester total right-aligned 58px  -->
														<Grid ColumnDefinitions="Auto,*,58" RowDefinitions="Auto,Auto">
															<!--  Note icon (multi-semester): shown only when this semester has a non-empty note.  -->
															<ToggleButton
																Grid.Row="0"
																Grid.Column="0"
																Margin="0,1,2,0"
																Classes="note-toggle"
																IsChecked="{Binding IsNoteExpanded}"
																IsVisible="{Binding HasNote}"
																ToolTip.Tip="Show/hide scheduling note">
																<Viewbox Width="12" Height="12">
																	<Path
																		Data="{StaticResource NoteIcon}"
																		Fill="Transparent"
																		Stroke="{StaticResource TextFaint}"
																		StrokeThickness="1.5" />
																</Viewbox>
															</ToggleButton>
															<!--  Chips WrapPanel in col 1  -->
															<ItemsControl
																Grid.Row="0"
																Grid.Column="1"
																Margin="2,0"
																ItemsSource="{Binding Items}">
																<ItemsControl.ItemsPanel>
																	<ItemsPanelTemplate>
																		<WrapPanel Orientation="Horizontal" />
																	</ItemsPanelTemplate>
																</ItemsControl.ItemsPanel>
																<ItemsControl.ItemTemplate>
																	<DataTemplate>
																		<Button
																			Margin="2,1"
																			Classes="chip"
																			Classes.release="{Binding IsRelease}"
																			Classes.selected="{Binding IsSelected}"
																			Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
																			CommandParameter="{Binding}"
																			Content="{Binding Label}" />
																	</DataTemplate>
																</ItemsControl.ItemTemplate>
															</ItemsControl>
															<!--  Per-semester total in col 2 (aligns with outer "Sem." header)  -->
															<TextBlock
																Grid.Row="0"
																Grid.Column="2"
																Margin="4,2"
																HorizontalAlignment="Right"
																VerticalAlignment="Top"
																Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}" />
															<!--  Read-only note area inside this semester box (multi-semester mode)  -->
															<Border
																Grid.Row="1"
																Grid.Column="0"
																Grid.ColumnSpan="3"
																Margin="2,3,0,0"
																Padding="5,3"
																Background="{StaticResource ViewHeaderBackground}"
																BorderBrush="{StaticResource InlineListBorder}"
																BorderThickness="1"
																CornerRadius="3"
																IsVisible="{Binding IsNoteExpanded}">
																<TextBlock
																	FontSize="11"
																	Foreground="{StaticResource TextPrimary}"
																	Text="{Binding NoteText}"
																	TextWrapping="Wrap" />
															</Border>
														</Grid>
													</Border>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>

										<!--  Semester total (single-semester mode only)  -->
										<TextBlock
											Grid.Row="0"
											Grid.Column="3"
											HorizontalAlignment="Center"
											VerticalAlignment="Top"
											IsVisible="{Binding IsMultiSemesterMode, Converter={x:Static BoolConverters.Not}}"
											Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}" />

										<!--  Academic year total  -->
										<TextBlock
											Grid.Row="0"
											Grid.Column="4"
											HorizontalAlignment="Center"
											VerticalAlignment="Top"
											Text="{Binding AcademicYearTotal, StringFormat={}{0:0.##}}" />

										<!--  Read-only note area (single-semester mode); spans full width below the row.  -->
										<Border
											Grid.Row="1"
											Grid.Column="0"
											Grid.ColumnSpan="5"
											Margin="4,4,4,2"
											Padding="6,4"
											Background="{StaticResource ViewHeaderBackground}"
											BorderBrush="{StaticResource InlineListBorder}"
											BorderThickness="1"
											CornerRadius="3"
											IsVisible="{Binding IsNoteExpanded}">
											<TextBlock
												FontSize="11"
												Foreground="{StaticResource TextPrimary}"
												Text="{Binding NoteText}"
												TextWrapping="Wrap" />
										</Border>

									</Grid>
									<!--
										Hover overlay: transparent by default; tinted by WorkloadCardHover style
										when Border.WorkloadCard is in :pointerover. IsHitTestVisible="False" lets
										pointer events pass through to chips and other interactive content below.
									-->
									<Border
										Classes="WorkloadCardHover"
										CornerRadius="4"
										IsHitTestVisible="False" />
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</StackPanel>
		</ScrollViewer>

		<!--  Row 2: Footer border — fixed height matches Schedule View zoom footer  -->
		<Border
			Grid.Row="2"
			Height="26"
			Background="{StaticResource ChromeBackground}"
			BorderBrush="{StaticResource ChromeBorder}"
			BorderThickness="0,1,0,0" />

	</Grid>

</UserControl>
