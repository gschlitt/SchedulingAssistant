<UserControl
    x:Class="SchedulingAssistant.Views.WorkloadPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:SchedulingAssistant.Converters"
    x:Name="Root"
    x:CompileBindings="False">

    <UserControl.Styles>
        <!--  Section chip: light blue  -->
        <Style Selector="Button.chip">
            <Setter Property="Background" Value="#D8E8F8" />
            <Setter Property="BorderBrush" Value="#7AAAD4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <!--  Release chip: light lavender  -->
        <Style Selector="Button.chip.release">
            <Setter Property="Background" Value="#EDE8F5" />
            <Setter Property="BorderBrush" Value="#B0A0C8" />
        </Style>
        <!--  Selected chip: violet border matching UserSelectedSectionBorderColor in other views  -->
        <Style Selector="Button.chip.selected">
            <Setter Property="BorderBrush" Value="{StaticResource UserSelectedSectionBorderColor}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Button.chip.release.selected">
            <Setter Property="BorderBrush" Value="{StaticResource UserSelectedSectionBorderColor}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!--  Column headers  -->
        <Border
            Grid.Row="0"
            Padding="10,0"
            Background="{StaticResource ChromeBackground}"
            BorderBrush="{StaticResource InlineListBorder}"
            BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="130,32,*,35,20">
                <TextBlock
                    Grid.Column="0"
                    Margin="4,3"
                    FontWeight="SemiBold"
                    Text="Instructor" />
                <TextBlock
                    Grid.Column="1"
                    Margin="2,3"
                    FontWeight="SemiBold"
                    Text="Init." />
                <TextBlock
                    Grid.Column="2"
                    Margin="4,3"
                    FontWeight="SemiBold"
                    Text="Sections &amp; Releases" />
                <TextBlock
                    Grid.Column="3"
                    Margin="4,3"
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Sem." />
                <TextBlock
                    Grid.Column="4"
                    Margin="4,3"
                    HorizontalAlignment="Right"
                    FontWeight="SemiBold"
                    Text="AY" />
            </Grid>
        </Border>

        <!--  Scrollable data area  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="10,0"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!--  Error banner  -->
                <Border
                    Padding="6,3"
                    Background="{StaticResource NotificationWarningBackground}"
                    IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock
                        Foreground="{StaticResource NotificationWarningText}"
                        Text="{Binding LastErrorMessage}"
                        TextWrapping="Wrap" />
                </Border>

                <!--  Instructor rows  -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource ItemSeparator}" BorderThickness="0,0,0,1">
                                <Grid Margin="0,3" ColumnDefinitions="130,32,*,35,20">

                                    <!--  Name  -->
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="4,2"
                                        VerticalAlignment="Top"
                                        Text="{Binding FullName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />

                                    <!--  Initials  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="2,2"
                                        VerticalAlignment="Top"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="{Binding Initials}" />

                                    <!--  Single-semester mode: flat chips (horizontal, wrapping)  -->
                                    <ItemsControl
                                        Grid.Column="2"
                                        Margin="2,0"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsMultiSemesterMode, Converter={x:Static BoolConverters.Not}}"
                                        ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Left" Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="2,1"
                                                    Classes="chip"
                                                    Classes.release="{Binding IsRelease}"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding Label}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Multi-semester mode: grouped by semester with colored frames  -->
                                    <ItemsControl
                                        Grid.Column="2"
                                        Grid.ColumnSpan="2"
                                        Margin="2,0"
                                        IsVisible="{Binding IsMultiSemesterMode}"
                                        ItemsSource="{Binding SemesterGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!--  Colored frame around this semester's chips  -->
                                                <Border
                                                    Margin="0,2"
                                                    Padding="3,2"
                                                    BorderBrush="{Binding SemesterColorBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="2">
                                                    <!--  Inner grid: chips fill *, semester total right-aligned 58px  -->
                                                    <Grid ColumnDefinitions="*,58">
                                                        <!--  Chips WrapPanel in col 0  -->
                                                        <ItemsControl
                                                            Grid.Column="0"
                                                            Margin="2,0"
                                                            ItemsSource="{Binding Items}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Button
                                                                        Margin="2,1"
                                                                        Classes="chip"
                                                                        Classes.release="{Binding IsRelease}"
                                                                        Classes.selected="{Binding IsSelected}"
                                                                        Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{Binding Label}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <!--  Per-semester total in col 1 (aligns with outer "Sem." header)  -->
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Margin="4,2"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Semester total (single-semester mode only)  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="4,2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        IsVisible="{Binding IsMultiSemesterMode, Converter={x:Static BoolConverters.Not}}"
                                        Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}" />

                                    <!--  Academic year total  -->
                                    <TextBlock
                                        Grid.Column="4"
                                        Margin="4,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Text="{Binding AcademicYearTotal, StringFormat={}{0:0.##}}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
