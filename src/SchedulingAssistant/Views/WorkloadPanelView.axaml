<UserControl
    x:Class="SchedulingAssistant.Views.WorkloadPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:SchedulingAssistant.Converters"
    x:Name="Root"
    x:CompileBindings="False">

    <UserControl.Styles>
        <!--  Section chip: light blue  -->
        <Style Selector="Button.chip">
            <Setter Property="Background" Value="#D8E8F8" />
            <Setter Property="BorderBrush" Value="#7AAAD4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <!--  Release chip: light lavender  -->
        <Style Selector="Button.chip.release">
            <Setter Property="Background" Value="#EDE8F5" />
            <Setter Property="BorderBrush" Value="#B0A0C8" />
        </Style>
        <!--  Selected chip: darker highlight  -->
        <Style Selector="Button.chip.selected">
            <Setter Property="Background" Value="#5BA3D0" />
            <Setter Property="BorderBrush" Value="#2E5C7A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.chip.release.selected">
            <Setter Property="Background" Value="#9D7EB8" />
            <Setter Property="BorderBrush" Value="#5D3E7F" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!--  Column headers  -->
        <Border
            Grid.Row="0"
            Background="#E8EEF5"
            BorderBrush="#CCCCCC"
            BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="100,32,*,58,58">
                <TextBlock
                    Grid.Column="0"
                    Margin="4,3"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Text="Instructor" />
                <TextBlock
                    Grid.Column="1"
                    Margin="2,3"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Text="Init." />
                <TextBlock
                    Grid.Column="2"
                    Margin="4,3"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Text="Sections &amp; Releases" />
                <TextBlock
                    Grid.Column="3"
                    Margin="4,3"
                    HorizontalAlignment="Right"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Text="Sem." />
                <TextBlock
                    Grid.Column="4"
                    Margin="4,3"
                    HorizontalAlignment="Right"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Text="AY" />
            </Grid>
        </Border>

        <!--  Scrollable data area  -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!--  Error banner  -->
                <Border
                    Padding="6,3"
                    Background="#FFF3CD"
                    IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock
                        FontSize="10"
                        Foreground="#856404"
                        Text="{Binding LastErrorMessage}"
                        TextWrapping="Wrap" />
                </Border>

                <!--  Instructor rows  -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                <Grid Margin="0,3" ColumnDefinitions="100,32,*,58,58">

                                    <!--  Name  -->
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="4,2"
                                        VerticalAlignment="Top"
                                        FontSize="10"
                                        Text="{Binding FullName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />

                                    <!--  Initials  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="2,2"
                                        VerticalAlignment="Top"
                                        FontSize="10"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="{Binding Initials}" />

                                    <!--  Work item chips (horizontal, wrapping)  -->
                                    <ItemsControl
                                        Grid.Column="2"
                                        Margin="2,0"
                                        ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button
                                                    Margin="2,1"
                                                    Classes="chip"
                                                    Classes.release="{Binding IsRelease}"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Content="{Binding Label}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Semester total  -->
                                    <TextBlock
                                        Grid.Column="3"
                                        Margin="4,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        FontSize="10"
                                        Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}" />

                                    <!--  Academic year total  -->
                                    <TextBlock
                                        Grid.Column="4"
                                        Margin="4,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        FontSize="10"
                                        Text="{Binding AcademicYearTotal, StringFormat={}{0:0.##}}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
