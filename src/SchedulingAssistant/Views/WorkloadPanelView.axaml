<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:SchedulingAssistant.Converters"
             x:Class="SchedulingAssistant.Views.WorkloadPanelView"
             x:Name="Root"
             x:CompileBindings="False">

    <UserControl.Styles>
        <!-- Section chip: light blue -->
        <Style Selector="Button.chip">
            <Setter Property="Background" Value="#D8E8F8" />
            <Setter Property="BorderBrush" Value="#7AAAD4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <!-- Release chip: light lavender -->
        <Style Selector="Button.chip.release">
            <Setter Property="Background" Value="#EDE8F5" />
            <Setter Property="BorderBrush" Value="#B0A0C8" />
        </Style>
        <!-- Selected chip: darker highlight -->
        <Style Selector="Button.chip.selected">
            <Setter Property="Background" Value="#5BA3D0" />
            <Setter Property="BorderBrush" Value="#2E5C7A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.chip.release.selected">
            <Setter Property="Background" Value="#9D7EB8" />
            <Setter Property="BorderBrush" Value="#5D3E7F" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Column headers -->
        <Border Grid.Row="0" Background="#E8EEF5"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="130,42,*,58,58">
                <TextBlock Grid.Column="0" Text="Instructor"
                           FontSize="10" FontWeight="SemiBold" Margin="4,3" />
                <TextBlock Grid.Column="1" Text="Init."
                           FontSize="10" FontWeight="SemiBold" Margin="2,3" />
                <TextBlock Grid.Column="2" Text="Sections &amp; Releases"
                           FontSize="10" FontWeight="SemiBold" Margin="4,3" />
                <TextBlock Grid.Column="3" Text="Sem."
                           FontSize="10" FontWeight="SemiBold"
                           HorizontalAlignment="Right" Margin="4,3" />
                <TextBlock Grid.Column="4" Text="AY"
                           FontSize="10" FontWeight="SemiBold"
                           HorizontalAlignment="Right" Margin="4,3" />
            </Grid>
        </Border>

        <!-- Scrollable data area -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Error banner -->
                <Border IsVisible="{Binding LastErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Background="#FFF3CD" Padding="6,3">
                    <TextBlock Text="{Binding LastErrorMessage}"
                               FontSize="10" Foreground="#856404" TextWrapping="Wrap" />
                </Border>

                <!-- Instructor rows -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="130,42,*,58,58" Margin="0,3">

                                    <!-- Name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FullName}"
                                               FontSize="10" VerticalAlignment="Top"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,2" />

                                    <!-- Initials -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Initials}"
                                               FontSize="10" VerticalAlignment="Top"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="2,2" />

                                    <!-- Work item chips (horizontal, wrapping) -->
                                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Items}" Margin="2,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}"
                                                        Classes="chip"
                                                        Classes.release="{Binding IsRelease}"
                                                        Classes.selected="{Binding DataContext.SelectedSectionId, ElementName=Root, Converter={StaticResource IsSelectedConverter}, ConverterParameter={Binding Id}}"
                                                        Command="{Binding DataContext.HandleItemClickCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"
                                                        Margin="2,1" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Semester total -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SemesterTotal, StringFormat={}{0:0.##}}"
                                               FontSize="10" VerticalAlignment="Top"
                                               HorizontalAlignment="Right"
                                               Margin="4,2" />

                                    <!-- Academic year total -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding AcademicYearTotal, StringFormat={}{0:0.##}}"
                                               FontSize="10" VerticalAlignment="Top"
                                               HorizontalAlignment="Right"
                                               Margin="4,2" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
