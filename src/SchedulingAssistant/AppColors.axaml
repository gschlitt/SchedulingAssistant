<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Design.PreviewWith>
		<Border Padding="20" Background="{StaticResource ChromeBackground}" />
	</Design.PreviewWith>

	<!--  ── App-wide surface  ────────────────────────────────  -->
	<Color x:Key="AppBackgroundColor">#f3f4f7</Color>
	<SolidColorBrush x:Key="AppBackground" Color="{StaticResource AppBackgroundColor}" />

	<!--  ── Primary chrome (top menu bar)  -->
	<SolidColorBrush x:Key="ChromeBackground" Color="white" />

	<!--  panel surfaces this is poorly defined  —  -->
	<SolidColorBrush x:Key="SurfaceBackground" Color="{StaticResource AppBackgroundColor}" />

	<!--  Very light 1 px separator  -->
	<SolidColorBrush x:Key="ChromeBorder" Color="#A0707070" />

	<!--  Section View, Schedule View, and Workload View panel header bars  -->
	<SolidColorBrush x:Key="ViewHeaderBackground" Color="{StaticResource AppBackgroundColor}" />

	<!--  ────────────Information Panels   ────────────  -->

	<!--
		Section and Schedule View Tile fill, section workload pills
		This forms the background of the entire time block a section meeting occupies, as well as the background for the text itself
	-->
	<SolidColorBrush x:Key="TileFill" Color="#cfecf8" />
	<!--  Release workload pill  -->
	<SolidColorBrush x:Key="ReleaseTile" Color="#EDE8F5" />

	<!--  Chosen to contrast with the section workload pill color  -->
	<SolidColorBrush x:Key="WorkloadTileBackground" Color="#8fd2ef" />

	<!--  Events/Meetings tile fill Should contrast with section color  -->
	<SolidColorBrush x:Key="MeetingTile" Color="#bbaada" />

	<!--  External border: the outline around the entire tile card  -->
	<SolidColorBrush x:Key="TileExternalBorder" Color="#acb4bd" />
	<!--  Internal border: horizontal separator lines between co-scheduled sections within a card  -->
	<SolidColorBrush x:Key="TileInternalBorder" Color="#dce0e3" />

	<!--  Selection and Interaction with Tiles  -->

	<!--  Hover on Section Cards and Section Meetings: Semi-transparent dark tint overlaid on Section View tiles  on hover  -->
	<SolidColorBrush x:Key="CardHoverOverlay" Color="#14000000" />

	<!--  Border when user selects a section or section meeting in Section View, Schedule View or Workload View  -->
	<SolidColorBrush x:Key="UserSelectedSectionBorderColor" Color="#3c647f" />

	<SolidColorBrush x:Key="SectionMeetingTextSelected" Color="Black" />

	<!--  Section card background when section matches the active Schedule Grid filter  -->
	<SolidColorBrush x:Key="FilterSelectedSectionBackgroundColor" Color="#9ecbf7" />

	<!--  De-emphasis: staffed tiles under "Emphasize Unstaffed" mode  -->
	<Color x:Key="TileDeemphasizedTextColor">#555f6d</Color>
	<SolidColorBrush x:Key="TileDeemphasizedText" Color="{StaticResource TileDeemphasizedTextColor}" />

	<!--
		When a section meeting is emphasized via overlay Also colors the border of the entire tile and the text
		describing the overlay in the filter/overlay bar
	-->
	<Color x:Key="OverlayColor">#D63050</Color>
	<SolidColorBrush x:Key="OverlayFrameBorder" Color="{StaticResource OverlayColor}" />


	<!--  User targets for interaction: buttons, selectors  -->

	<!--  ── Buttons  ─────────────────────────────────────────────────────  -->
	<SolidColorBrush x:Key="ButtonBackground" Color="#bcdcff" />
	<SolidColorBrush x:Key="ButtonBorder" Color="#B8CCDF" />
	<SolidColorBrush x:Key="ButtonHover" Color="#a9d2fb" />
	<SolidColorBrush x:Key="ButtonPressed" Color="#94c6f7" />

	<!--  Filters and Overlays ────────────────────────────────  -->

	<SolidColorBrush x:Key="FilterBarBackground" Color="{StaticResource AppBackgroundColor}" />
	<!--  Background fill for the filter-selectors and overlay-selectors bordered groups, same as buttonbackground  -->
	<SolidColorBrush x:Key="FilterSelectorBackground" Color="#bcdcff" />

	<!--  Outer Border for the filter dropdowns  -->
	<SolidColorBrush x:Key="FilterExpanderBorder" Color="#C8DAEF" />

	<!--  Very light border that visually groups the filter choosers (and separately the overlay choosers) in the filter bar  -->
	<SolidColorBrush x:Key="FilterGroupBorder" Color="#8AAAC8" />

	<SolidColorBrush x:Key="FilterExpanderContent" Color="#bcdcff" />

	<!--  Sentinel row background in filter dropdowns (separates "Unstaffed" entries) Currently the same as FilterExpanderContent  -->
	<SolidColorBrush x:Key="FilterSentinelBackground" Color="#bcdcff" />
	<!--  The descriptive text describing each filter  -->
	<SolidColorBrush x:Key="FilterActiveHeader" Color="{StaticResource FilterColor}" />
	<SolidColorBrush x:Key="FilterInactiveHeader" Color="#2D3748" />

	<SolidColorBrush x:Key="OverlayActiveHeader" Color="{StaticResource OverlayColor}" />
	<SolidColorBrush x:Key="OverlayInactiveHeader" Color="#2D3748" />

	<!--  ── "Filtered by" text in panel header  ──────────────────────────  -->
	<!--  The color of the text in the overlay/filter bar labeling the active filter  -->
	<Color x:Key="FilterColor">#4A6FA5</Color>
	<SolidColorBrush x:Key="FilterBadgeText" Color="{StaticResource FilterColor}" />
	<!--  Overlay:  -->
	<SolidColorBrush x:Key="OverlayBadgeText" Color="{StaticResource OverlayColor}" />


	<!--  ── General UI structure  ─────────────────────────────────────────  -->
	<!--  Thin separator rules inside the menu bar and chrome areas  -->
	<SolidColorBrush x:Key="SeparatorLine" Color="Black" />
	<SolidColorBrush x:Key="GridSplitterColor" Color="#E0E8F0" />
	<!--  Subdued border for dialogs, secondary containers  -->
	<SolidColorBrush x:Key="SubduedBorder" Color="#C8D5E4" />
	<!--  Thin hairline between list items  -->
	<SolidColorBrush x:Key="ItemSeparator" Color="#E8EEF5" />
	<!--  Inline list borders — replaces raw #CCCCCC throughout views  -->
	<SolidColorBrush x:Key="InlineListBorder" Color="#E0E8F0" />
	<!--  Soft panel shadow  -->
	<BoxShadows x:Key="PanelBoxShadow">1 2 4 0 #80000000</BoxShadows>


	<!--  Schedule View Structure  -->
	<!--  Vertical lines separating day columns on the schedule grid  -->
	<SolidColorBrush x:Key="DaySeparators" Color="#a0a6ad" />
	<SolidColorBrush x:Key="GridRuleLine" Color="#c3ccda" />
	<SolidColorBrush x:Key="GridHourRuleLine" Color="#c3ccda" />
	<SolidColorBrush x:Key="GridGutterBackground" Color="#F2F5FA" />
	<SolidColorBrush x:Key="GridTimeHalfHourText" Color="#64748B" />
	<SolidColorBrush x:Key="GridDayHeaderText" Color="#8A9AB0" />
	<SolidColorBrush x:Key="WeekDayBar" Color="{StaticResource AppBackgroundColor}" />
	<SolidColorBrush x:Key="TimesColumn" Color="{StaticResource AppBackgroundColor}" />

	<!--  ── Loading curtain gradient  ───────────────────────────────────  -->
	<Color x:Key="SplashGradientStart">#0D1F3C</Color>
	<Color x:Key="SplashGradientEnd">#2E5899</Color>

	<!--  ── Text roles  ───────────────────────────────────────────────────  -->
	<!--  Primary: dark navy-gray — not pure black, but still high contrast  -->
	<SolidColorBrush x:Key="TextPrimary" Color="#1A2433" />
	<SolidColorBrush x:Key="TextSecondary" Color="#1e2938" />
	<SolidColorBrush x:Key="TextMuted" Color="#1e2836" />
	<SolidColorBrush x:Key="TextFaint" Color="#475569" />
	<SolidColorBrush x:Key="TextSubtle" Color="#4A5568" />
	<SolidColorBrush x:Key="TextLabel" Color="#64748B" />
	<SolidColorBrush x:Key="TextDimLabel" Color="#64748B" />
	<SolidColorBrush x:Key="TextSemesterLabel" Color="#475569" />
	<SolidColorBrush x:Key="TextValidationError" Color="#C53030" />
	<SolidColorBrush x:Key="TextError" Color="#C53030" />
	<SolidColorBrush x:Key="ToolTipTextBrush" Color="Black" />

	<!--  Subtle tint — zebra rows, inactive areas, empty-state fills  -->
	<SolidColorBrush x:Key="SubtleBackground" Color="#F0F4FA" />



	<!--  ── Error / warning banners  ─────────────────────────────────────  -->
	<!--  Write-lock / warning banner (warm amber)  -->
	<SolidColorBrush x:Key="ErrorBannerBackground" Color="#FEF3C7" />
	<SolidColorBrush x:Key="ErrorBannerBorder" Color="#D4900A" />
	<SolidColorBrush x:Key="ErrorBannerText" Color="#78440A" />

	<!--  Notification — Info (blue family)  -->
	<SolidColorBrush x:Key="NotificationInfoBackground" Color="#EEF4FC" />
	<SolidColorBrush x:Key="NotificationInfoBorder" Color="#7AAAD4" />
	<SolidColorBrush x:Key="NotificationInfoText" Color="#1A3A5C" />

	<!--  Notification — Warning (amber)  -->
	<SolidColorBrush x:Key="NotificationWarningBackground" Color="#FEF3C7" />
	<SolidColorBrush x:Key="NotificationWarningBorder" Color="#D4900A" />
	<SolidColorBrush x:Key="NotificationWarningText" Color="#78440A" />

	<!--  Notification — Error (red)  -->
	<SolidColorBrush x:Key="NotificationErrorBackground" Color="#FDECEA" />
	<SolidColorBrush x:Key="NotificationErrorBorder" Color="#C53030" />
	<SolidColorBrush x:Key="NotificationErrorText" Color="#7A0000" />


	<!--  ── Inline section editor highlight  ─────────────────────────────  -->

	<SolidColorBrush x:Key="EditorBackground" Color="#FFFFFE" />
	<SolidColorBrush x:Key="SectionScheduleArea" Color="#FFFFFE" />
	<!--  Editor left-border uses the accent color  -->
	<SolidColorBrush x:Key="EditorBorder" Color="#ac8eb2" />

	<!--  ── Flyout overlay  ───────────────────────────────────────────────  -->
	<SolidColorBrush x:Key="FlyoutScrim" Color="#50000000" />
	<SolidColorBrush x:Key="FlyoutBackground" Color="#FFFFFF" />
	<!--  Flyout header matches app background for a seamless feel  -->
	<SolidColorBrush x:Key="FlyoutHeaderBackground" Color="#F7F9FC" />
	<SolidColorBrush x:Key="FlyoutHeaderBorder" Color="#DDE6F0" />
	<SolidColorBrush x:Key="FlyoutShadow" Color="#50000000" />

	<!--
		── Semester banners (Section List group headers)  ─────────────────
		Muted, earthy tones — still distinguishable but not jarring.
	-->
	<SolidColorBrush x:Key="FallBackground" Color="#B06A3A" />
	<SolidColorBrush x:Key="FallBorder" Color="#B06A3A" />
	<SolidColorBrush x:Key="WinterBackground" Color="#607080" />
	<SolidColorBrush x:Key="WinterBorder" Color="#607080" />
	<SolidColorBrush x:Key="EarlySummerBackground" Color="#4A9660" />
	<SolidColorBrush x:Key="EarlySummerBorder" Color="#4A9660" />
	<SolidColorBrush x:Key="SummerBackground" Color="#3A8EC0" />
	<SolidColorBrush x:Key="SummerBorder" Color="#3A8EC0" />
	<SolidColorBrush x:Key="LateSummerBackground" Color="#C09428" />
	<SolidColorBrush x:Key="LateSummerBorder" Color="#C09428" />



	<!--
		section-prefix dialog badge colors  ────────────────────
	-->
	<SolidColorBrush x:Key="PrefixCourseBackground" Color="#DBEAFE" />
	<SolidColorBrush x:Key="PrefixSectionBackground" Color="#D1FAE5" />
	<SolidColorBrush x:Key="PrefixDesignatorBackground" Color="LightSalmon" />

	<!--  ── Help tooltips  ──────────────────────────────────────────────────  -->
	<!--  Light indigo-white fill — distinct from the cooler TileFill (#E2EDF8)  -->
	<SolidColorBrush x:Key="HelpTipBackground" Color="#F2F6FF" />
	<!--  Muted medium-blue border — pairs with the indigo accent  -->
	<SolidColorBrush x:Key="HelpTipBorder" Color="#9ABED8" />



</ResourceDictionary>
