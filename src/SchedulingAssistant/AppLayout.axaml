<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ══════════════════════════════════════════════════════════════════
        Application Layout Constants
        Non-color UI constants: spacing, padding, sizes.
        Change values here to adjust layout and spacing app-wide.
        ══════════════════════════════════════════════════════════════════
    -->

    <!--  ── Schedule grid tile padding  ────────────────────────────────  -->
    <!--  Vertical gap between the gridline and the top/bottom of a tile  -->
    <x:Double x:Key="TilePaddingVertical">2</x:Double>
    <!--
        Horizontal gap between the day-column edge and tile edges;
        also used as the slot-allocation gap when scaling tile widths
    -->
    <x:Double x:Key="TilePaddingHorizontal">8</x:Double>

    <!--
        Spacing inserted on each side of an internal semester boundary in multi-semester
        mode. Only applied between semesters within the same day group — not on the outer
        edges of the first or last semester. Total visual gap = 2 × this value.
    -->
    <x:Double x:Key="MultiSemesterInternalTilePadding">0</x:Double>

</ResourceDictionary>
