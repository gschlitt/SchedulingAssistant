<!--
    MainWindow — the desktop OS shell.

    WHY THIS IS A THIN WRAPPER:
    All application UI now lives in MainView (a UserControl) so that the exact same UI
    can be hosted by the browser (WASM) build via ISingleViewApplicationLifetime, which
    requires a plain Control rather than a Window.  This file retains only the
    window-specific concerns: title, initial size, and the MainView it contains.

    Desktop-only logic (startup splash, DB-path dialog, panel detaching, OnClosing)
    lives in MainWindow.axaml.cs.  Everything the user sees is in MainView.axaml(.cs).
-->
<Window
    x:Class="SchedulingAssistant.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SchedulingAssistant.Views"
    Title="Scheduling Assistant"
    Width="1400"
    Height="800"
    MinHeight="600"
    x:CompileBindings="False">

    <views:MainView x:Name="MainViewInstance" />

</Window>
