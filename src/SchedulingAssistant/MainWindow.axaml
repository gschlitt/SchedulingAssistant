<Window
    x:Class="SchedulingAssistant.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="using:SchedulingAssistant.Behaviors"
    xmlns:controls="using:SchedulingAssistant.Controls"
    xmlns:gridViews="using:SchedulingAssistant.Views.GridView"
    xmlns:panelViews="using:SchedulingAssistant.Views"
    xmlns:views="using:SchedulingAssistant.Views.Management"
    xmlns:vm="using:SchedulingAssistant.ViewModels"
    x:Name="RootWindow"
    Title="TermPoint"
    Width="1400"
    Height="800"
    MinHeight="600"
    b:DismissBehaviors.EscapeCommand="{Binding CloseFlyoutCommand}"
    x:CompileBindings="False"
    x:DataType="vm:MainWindowViewModel">

    <Window.Styles>
        <!--
            Notification banner colour schemes, selected by the CSS class applied to the
            Border via the NotificationSeverityClass binding. Colours are sourced from
            AppColors.axaml so they can be changed in one place.
        -->
        <Style Selector="Border.notification_info">
            <Setter Property="Background" Value="{StaticResource NotificationInfoBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource NotificationInfoBorder}" />
        </Style>
        <Style Selector="Border.notification_info TextBlock">
            <Setter Property="Foreground" Value="{StaticResource NotificationInfoText}" />
        </Style>
        <Style Selector="Border.notification_warning">
            <Setter Property="Background" Value="{StaticResource NotificationWarningBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource NotificationWarningBorder}" />
        </Style>
        <Style Selector="Border.notification_warning TextBlock">
            <Setter Property="Foreground" Value="{StaticResource NotificationWarningText}" />
        </Style>
        <Style Selector="Border.notification_error">
            <Setter Property="Background" Value="{StaticResource NotificationErrorBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource NotificationErrorBorder}" />
        </Style>
        <Style Selector="Border.notification_error TextBlock">
            <Setter Property="Foreground" Value="{StaticResource NotificationErrorText}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*" ShowGridLines="True">

        <!--  Top menu bar  -->
        <Border
            Grid.Row="0"
            Padding="12,0"
            Background="{StaticResource ChromeBackground}"
            BorderBrush="{StaticResource ChromeBorder}"
            BorderThickness="0,0,0,1">
            <DockPanel>

                <!--  Academic Year and Semester pickers, right-aligned — always visible  -->
                <StackPanel
                    Margin="8,4"
                    VerticalAlignment="Top"
                    DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Border
                        Width="1"
                        Margin="0,6"
                        Background="{StaticResource SeparatorLine}" />

                    <!--  Academic Year selector  -->
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextSemesterLabel}"
                        Text="Academic Year:" />
                    <ComboBox
                        MinWidth="120"
                        VerticalAlignment="Center"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{Binding SemesterContext.AcademicYears}"
                        SelectedItem="{Binding SemesterContext.SelectedAcademicYear}" />

                    <Border
                        Width="1"
                        Margin="0,6"
                        Background="{StaticResource SeparatorLine}" />

                    <!--  Semester multi-select picker  -->
                    <!--
                        Replaces the single-select ComboBox with a button + popup approach
                        so the user can check multiple semesters within the selected year.
                    -->
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextSemesterLabel}"
                        Text="Semester:" />
                    <Panel VerticalAlignment="Center">
                        <!--
                            The button label shows the current selection, e.g. "Fall 2025"
                            or "Early Summer, Summer". Clicking toggles the popup open/closed.
                        -->
                        <Button
                            x:Name="SemesterPickerButton"
                            MinWidth="120"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Command="{Binding SemesterContext.ToggleSemesterPickerCommand}"
                            Content="{Binding SemesterContext.SelectedSemestersLabel}" />

                        <!--
                            Popup with one CheckBox per semester in the selected year.
                            LightDismissOverlayMode closes it when the user clicks elsewhere.
                            Two-way binding on IsOpen lets the light-dismiss update the ViewModel.
                        -->
                        <Popup
                            IsLightDismissEnabled="True"
                            IsOpen="{Binding SemesterContext.IsSemesterPickerOpen, Mode=TwoWay}"
                            PlacementMode="Bottom"
                            PlacementTarget="{Binding ElementName=SemesterPickerButton}">
                            <Border
                                MinWidth="150"
                                Padding="4,4"
                                Background="{StaticResource FlyoutBackground}"
                                BorderBrush="{StaticResource ChromeBorder}"
                                BorderThickness="1"
                                CornerRadius="2">
                                <ItemsControl ItemsSource="{Binding SemesterContext.FilteredCheckItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                Padding="4,3"
                                                Content="{Binding DisplayName}"
                                                FontSize="12"
                                                IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Panel>
                </StackPanel>

                <!--  Nav buttons — wrap when space is tight  -->
                <WrapPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <!--  Files menu (far left)  -->
                    <Menu
                        Margin="0,4"
                        VerticalAlignment="Center"
                        Background="Transparent">
                        <MenuItem
                            Padding="14,8"
                            Classes="nav"
                            Header="Files">
                            <MenuItem Command="{Binding OpenDatabaseCommand}" Header="Open…" />
                            <MenuItem Command="{Binding NewDatabaseCommand}" Header="New…" />
                            <Separator IsVisible="{Binding RecentDatabases.Count}" />
                            <MenuItem
                                Header="Recent Files"
                                IsVisible="{Binding RecentDatabases.Count}"
                                ItemsSource="{Binding RecentDatabases}">
                                <MenuItem.ItemTemplate>
                                    <DataTemplate>
                                        <MenuItem
                                            Command="{Binding DataContext.OpenRecentDatabaseCommand, ElementName=RootWindow}"
                                            CommandParameter="{Binding Path}"
                                            Header="{Binding DisplayName}" />
                                    </DataTemplate>
                                </MenuItem.ItemTemplate>
                            </MenuItem>
                            <Separator />
                            <MenuItem Command="{Binding NavigateToShareCommand}" Header="Share…" />
                            <Separator />
                            <MenuItem Command="{Binding ExitCommand}" Header="Exit" />
                        </MenuItem>
                    </Menu>

                    <Border
                        Width="1"
                        Margin="0,10,8,10"
                        Background="{StaticResource SeparatorLine}" />

                    <TextBlock
                        Margin="4,4,8,4"
                        VerticalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Text="{Binding DatabaseName}" />

                    <Border
                        Width="1"
                        Margin="0,10,8,10"
                        Background="{StaticResource SeparatorLine}" />

                    <Button
                        Margin="0,4,4,4"
                        Classes="nav"
                        Command="{Binding NavigateToCoursesCommand}"
                        Content="Courses" />
                    <Button
                        Margin="0,4,4,4"
                        Classes="nav"
                        Command="{Binding NavigateToInstructorsCommand}"
                        Content="Instructors" />
                    <Button
                        Margin="0,4,4,4"
                        Classes="nav"
                        Command="{Binding NavigateToSectionPropertiesCommand}"
                        Content="Section Properties" />

                    <Border
                        Width="1"
                        Margin="4,10"
                        Background="{StaticResource SeparatorLine}" />

                    <Button
                        Margin="4,4,4,4"
                        Classes="nav"
                        Command="{Binding NavigateToAcademicYearsCommand}"
                        Content="Academic Years" />

                    <Border
                        Width="1"
                        Margin="4,10"
                        Background="{StaticResource SeparatorLine}" />

                    <!--  Settings dropdown menu  -->
                    <Menu
                        Margin="0,4"
                        VerticalAlignment="Center"
                        Background="Transparent">
                        <MenuItem
                            Padding="14,8"
                            Classes="nav"
                            Header="Settings">
                            <MenuItem Command="{Binding NavigateToBlockLengthsCommand}" Header="Scheduling" />
                            <MenuItem Command="{Binding NavigateToBlockPatternsCommand}" Header="Block Patterns" />
                            <MenuItem Command="{Binding NavigateToAcademicUnitsCommand}" Header="Academic Units" />
                            <MenuItem Command="{Binding NavigateToSectionPrefixesCommand}" Header="Section Prefixes" />
                            <Separator />
                            <MenuItem Command="{Binding NavigateToSettingsCommand}" Header="Backup &amp; Settings" />
                        </MenuItem>
                    </Menu>

                    <Border
                        Width="1"
                        Margin="4,10"
                        Background="{StaticResource SeparatorLine}" />

                    <!--  Export menu  -->
                    <Menu
                        Margin="0,4"
                        VerticalAlignment="Center"
                        Background="Transparent">
                        <MenuItem
                            Padding="14,8"
                            Classes="nav"
                            Header="Export">
                            <MenuItem Command="{Binding NavigateToExportCommand}" Header="Export Schedule PNG…" />
                            <MenuItem Command="{Binding NavigateToWorkloadReportCommand}" Header="Workload Report…" />
                            <Separator />
                            <MenuItem Command="{Binding NavigateToWorkloadMailerCommand}" Header="Workload Mailer…" />
                        </MenuItem>
                    </Menu>

                    <Border
                        Width="1"
                        Margin="4,10"
                        Background="{StaticResource SeparatorLine}" />

                    <!--  Help button — opens the Help documentation flyout  -->
                    <Button
                        Margin="4,4,0,4"
                        Classes="nav"
                        Command="{Binding NavigateToHelpCommand}"
                        Content="Help" />

                    <!--  Debug menu (added in code-behind in DEBUG mode)  -->
                    <Menu
                        x:Name="DebugMenu"
                        Margin="0,4"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        IsVisible="False">
                        <MenuItem
                            Padding="14,8"
                            Classes="nav"
                            Header="Debug">
                            <MenuItem Command="{Binding OpenDebugCommand}" Header="Debug View…" />
                            <Separator />
                            <!--  ONE-TIME MIGRATION UTILITY — remove after migration is complete  -->
                            <MenuItem Command="{Binding OpenMigrationCommand}" Header="Migration: CSV → JSON…" />
                        </MenuItem>
                    </Menu>
                </WrapPanel>

            </DockPanel>
        </Border>

        <!--
            Write-lock banner — visible only in read-only mode.
            Shown between the menu bar and the content area so it is always visible
            without displacing any panel content. The "Switch to edit mode" button
            appears only after the polling timer detects that the lock is available.
        -->
        <Border
            Grid.Row="1"
            Padding="12,4"
            Background="{StaticResource ErrorBannerBackground}"
            BorderBrush="{StaticResource ErrorBannerBorder}"
            BorderThickness="0,0,0,1"
            IsVisible="{Binding ShowLockBanner}">
            <DockPanel>
                <!--  "Switch to edit mode" — rightmost; only shown when lock is free  -->
                <Button
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Command="{Binding AcquireWriteLockCommand}"
                    Content="Switch to edit mode"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeNormal}"
                    IsVisible="{Binding ShowWriteLockAvailablePrompt}"
                    ToolTip.Tip="The write lock is no longer held. Click to acquire write access." />
                <!--  Refresh — always visible in read-only mode; reloads section data from DB  -->
                <Button
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Command="{Binding RefreshDataCommand}"
                    Content="Refresh View"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeNormal}"
                    ToolTip.Tip="{Binding RefreshButtonTooltip}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeNormal}"
                    Foreground="{StaticResource ErrorBannerText}"
                    Text="{Binding LockStatusMessage}" />
            </DockPanel>
        </Border>

        <!--
            Notification banner — shown between the lock banner and the content area.
            The CSS class on the Border is set by NotificationSeverityClass and drives
            the colour scheme via the Window.Styles block above.
        -->
        <Border
            Grid.Row="2"
            Padding="12,4"
            BorderThickness="0,0,0,1"
            Classes.notification_error="{Binding NotificationIsError}"
            Classes.notification_info="{Binding NotificationIsInfo}"
            Classes.notification_warning="{Binding NotificationIsWarning}"
            IsVisible="{Binding HasNotification}">
            <DockPanel>
                <!--  Dismiss button — rightmost, only when dismissable  -->
                <Button
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Command="{Binding DismissNotificationCommand}"
                    Content="Dismiss"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeNormal}"
                    IsVisible="{Binding NotificationIsDismissable}" />
                <!--  Hyperlink — shown when notification carries a link  -->
                <Button
                    Margin="8,0,0,0"
                    Padding="8,2"
                    Command="{Binding OpenNotificationLinkCommand}"
                    Content="{Binding NotificationLinkText}"
                    DockPanel.Dock="Right"
                    FontSize="{StaticResource FontSizeNormal}"
                    IsVisible="{Binding NotificationHasLink}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeNormal}"
                    Text="{Binding NotificationMessage}"
                    TextWrapping="NoWrap" />
            </DockPanel>
        </Border>

        <!--  Main body: layered panel (permanent grid beneath, flyout overlay above)  -->
        <Panel Grid.Row="3">

            <!--
                Layer 0: permanent three-panel grid.
                ConditionalColumnWidthBehavior toggles column 0 between 370px (collapsed)
                and 650px (editor open) by watching SectionListVm.IsEditing. This replaces
                the UpdateLeftColumnWidth code-behind method and its PropertyChanged subscription.
            -->
            <Grid
                x:Name="ThreePanelGrid"
                b:ConditionalColumnWidthBehavior.ColumnIndex="0"
                b:ConditionalColumnWidthBehavior.Condition="{Binding SectionListVm.IsEditing}"
                b:ConditionalColumnWidthBehavior.FalseWidth="370"
                b:ConditionalColumnWidthBehavior.TrueWidth="650"
                ColumnDefinitions="370,4,*">

                <!--  Left column: Section Editor (top) + Workload (bottom)  -->
                <Grid Grid.Column="0" RowDefinitions="*,4,200">

                    <!--  Section View (fixed panel — not detachable)  -->
                    <!--  Outer shell: soft shadow + 1 px light edge; matches DetachablePanel treatment  -->
                    <Border
                        Grid.Row="0"
                        BorderBrush="{StaticResource ChromeBorder}"
                        BorderThickness="1"
                        BoxShadow="0 1 6 0 #1A000000"
                        CornerRadius="2">
                        <Grid RowDefinitions="Auto,*">

                            <!--  Header  -->
                            <!--
                                MinHeight matches the combined height of the Schedule Grid's DetachablePanel header
                                + GridFilterView so both panel headers share the same bottom edge at full window width.
                            -->
                            <Border
                                Grid.Row="0"
                                Padding="10,6"
                                Background="{StaticResource ChromeBackground}"
                                BorderBrush="{StaticResource ChromeBorder}"
                                BorderThickness="0,0,0,1">
                                <Grid RowDefinitions="Auto,Auto">

                                    <!--  Title + sort-mode context (right-click to change sort)  -->

                                    <TextBlock
                                        Grid.Row="0"
                                        Margin="1,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource FontSizeLarge}"
                                        FontWeight="SemiBold"
                                        Text="Section View" />
                                    <!--
                                        Action buttons — the entire group is disabled in read-only mode
                                        via a single IsEnabled binding on the container.
                                    -->
                                    <StackPanel
                                        Grid.Row="1"
                                        Margin="0,12,0,0"
                                        VerticalAlignment="Top"
                                        DataContext="{Binding SectionListVm}"
                                        IsEnabled="{Binding DataContext.IsWriteEnabled, ElementName=RootWindow}"
                                        Orientation="Horizontal"
                                        Spacing="3">
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="4,1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding ExpandAllCommand}"
                                            Content="▼"
                                            FontSize="9"
                                            ToolTip.Tip="Expand all cards" />
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="4,1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding CollapseAllCommand}"
                                            Content="▶"
                                            FontSize="9"
                                            ToolTip.Tip="Collapse all cards" />
                                        <Border
                                            Width="1"
                                            Margin="2,2"
                                            Background="{StaticResource SeparatorLine}" />
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="5,1"
                                            Command="{Binding AddCommand}"
                                            Content="Add"
                                            FontSize="10" />
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="5,1"
                                            Command="{Binding EditCommand}"
                                            Content="Edit"
                                            FontSize="10"
                                            IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="5,1"
                                            Command="{Binding CopyCommand}"
                                            Content="Copy"
                                            FontSize="10"
                                            IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Button
                                            MinWidth="0"
                                            MinHeight="0"
                                            Padding="5,1"
                                            Command="{Binding DeleteCommand}"
                                            Content="Delete"
                                            FontSize="10"
                                            IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource FontSizeNormal}"
                                            Text="Sort:" />
                                        <ComboBox
                                            MinHeight="0"
                                            Padding="5,1"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource ButtonBackground}"
                                            BorderThickness="0"
                                            CornerRadius="4"
                                            FontSize="{StaticResource FontSizeNormal}"
                                            ItemsSource="{Binding SortModeOptions}"
                                            SelectedIndex="{Binding SelectedSortModeIndex}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--  Content  -->
                            <views:SectionListView Grid.Row="1" DataContext="{Binding SectionListVm}" />

                        </Grid>
                    </Border>

                    <GridSplitter
                        Grid.Row="1"
                        Height="4"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource GridSplitterColor}"
                        ResizeDirection="Rows" />

                    <!--  Workload slot (detachable)  -->
                    <controls:DetachablePanel
                        x:Name="WorkloadPanel"
                        Grid.Row="2"
                        DetachRequested="OnWorkloadDetach"
                        Header="Workload View">
                        <controls:DetachablePanel.PanelContent>
                            <panelViews:WorkloadPanelView DataContext="{Binding WorkloadPanelVm}" />
                        </controls:DetachablePanel.PanelContent>
                    </controls:DetachablePanel>

                </Grid>

                <!--  Column splitter  -->
                <GridSplitter
                    Grid.Column="1"
                    Width="4"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource GridSplitterColor}"
                    ResizeDirection="Columns" />

                <!--  Right column: Schedule Grid (permanent, detachable)  -->
                <controls:DetachablePanel
                    x:Name="ScheduleGridPanel"
                    Grid.Column="2"
                    DetachRequested="OnScheduleGridDetach"
                    Header="Schedule View">
                    <controls:DetachablePanel.HeaderContext>
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="6">

                            <!--  Academic Unit (only shown when available)  -->
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeLarge}"
                                IsVisible="{Binding ScheduleGridVm.AcademicUnitName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Text="{Binding ScheduleGridVm.AcademicUnitName}" />

                            <!--  Semester (with colored backgrounds per semester)  -->
                            <Border
                                Width="1"
                                Margin="0,3"
                                Background="{StaticResource SeparatorLine}"
                                IsVisible="{Binding ScheduleGridVm.AcademicUnitName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding ScheduleGridVm.SemesterLineSegments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="6,2"
                                            Background="{Binding Background}"
                                            BorderBrush="{Binding Border}"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                            <TextBlock FontSize="{StaticResource FontSizeLarge}" Text="{Binding DisplayText}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Stats (always shown)  -->
                            <Border
                                Width="1"
                                Margin="0,3"
                                Background="{StaticResource SeparatorLine}"
                                IsVisible="{Binding ScheduleGridVm.StatsLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeLarge}"
                                IsVisible="{Binding ScheduleGridVm.StatsLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Text="{Binding ScheduleGridVm.StatsLine}" />

                            <!--  Filtered by (only shown when filter active)  -->
                            <Border
                                Width="1"
                                Margin="0,3"
                                Background="{StaticResource SeparatorLine}"
                                IsVisible="{Binding ScheduleGridVm.Filter.IsActive}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeLarge}"
                                FontWeight="Bold"
                                Foreground="{StaticResource FilterBadgeText}"
                                IsVisible="{Binding ScheduleGridVm.Filter.IsActive}"
                                Text="Filtered by:" />
                            <TextBlock
                                MaxWidth="400"
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeLarge}"
                                FontWeight="Bold"
                                Foreground="{StaticResource FilterBadgeText}"
                                IsVisible="{Binding ScheduleGridVm.Filter.IsActive}"
                                Text="{Binding ScheduleGridVm.Filter.ActiveSummary}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  Overlay (only shown when active)  -->
                            <Border
                                Width="1"
                                Margin="0,3"
                                Background="{StaticResource SeparatorLine}"
                                IsVisible="{Binding ScheduleGridVm.Filter.OverlaySummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="{StaticResource FontSizeLarge}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource OverlayBadgeText}"
                                IsVisible="{Binding ScheduleGridVm.Filter.OverlaySummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Text="{Binding ScheduleGridVm.Filter.OverlaySummary}" />





                        </StackPanel>
                    </controls:DetachablePanel.HeaderContext>
                    <controls:DetachablePanel.PanelContent>
                        <gridViews:ScheduleGridView x:Name="ScheduleGridViewControl" DataContext="{Binding ScheduleGridVm}" />
                    </controls:DetachablePanel.PanelContent>
                </controls:DetachablePanel>

            </Grid>

            <!--  Layer 1: management flyout overlay  -->
            <Panel IsVisible="{Binding FlyoutPage, Converter={x:Static ObjectConverters.IsNotNull}}">

                <!--
                    Dim backdrop — clicking it closes the flyout.
                    DismissBehaviors.ClickCommand replaces the OnFlyoutBackdropPressed code-behind handler.
                -->
                <Border b:DismissBehaviors.ClickCommand="{Binding CloseFlyoutCommand}" Background="{StaticResource FlyoutScrim}" />

                <!--  Flyout panel (drops from top)  -->
                <Border
                    MaxHeight="650"
                    Margin="8,0,8,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{StaticResource FlyoutBackground}"
                    BoxShadow="0 4 20 2 #50000000"
                    CornerRadius="0,0,6,6">
                    <Grid RowDefinitions="Auto,*">

                        <!--  Flyout header  -->
                        <Border
                            Grid.Row="0"
                            Padding="16,10"
                            Background="{StaticResource FlyoutHeaderBackground}"
                            BorderBrush="{StaticResource FlyoutHeaderBorder}"
                            BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button
                                    Padding="8,4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding CloseFlyoutCommand}"
                                    Content="✕"
                                    DockPanel.Dock="Right" />
                                <TextBlock
                                    VerticalAlignment="Top"
                                    FontSize="{StaticResource FontSizeLarge}"
                                    FontWeight="SemiBold"
                                    Text="{Binding FlyoutTitle}" />
                            </DockPanel>
                        </Border>

                        <!--  Flyout content  -->

                        <ContentControl
                            Grid.Row="1"
                            Margin="0,15"
                            Content="{Binding FlyoutPage}" />


                    </Grid>
                </Border>

            </Panel>

        </Panel>

    </Grid>
</Window>
